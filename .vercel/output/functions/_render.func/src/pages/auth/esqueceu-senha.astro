---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { supabase } from '@/lib/supabase';

let errorMessage = '';
let emailSent = false;
let submittedEmail = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email    = formData.get('email')?.toString().trim() ?? '';

  const { error } = await supabase.auth.resetPasswordForEmail(email, {
    // Redireciona para página de redefinição após clique no e-mail
    redirectTo: `${Astro.url.origin}/auth/nova-senha`,
  });

  if (error) {
    errorMessage = 'Não foi possível enviar o e-mail. Verifique o endereço informado.';
  } else {
    emailSent      = true;
    submittedEmail = email;
  }
}
---

<AuthLayout title="Recuperar Senha">
  <div class="auth-form-card">
    <div class="auth-form-header">
      <img src="/images/logohorizontal.png" class="h-12 w-auto mx-auto mb-8" alt="MQ ACCESS" />
      <h1 class="auth-form-title">Recuperar acesso</h1>
      <p class="auth-form-subtitle">Enviaremos um link para o seu e-mail</p>
    </div>

    {emailSent ? (
      <!-- Estado de sucesso -->
      <div class="success-state">
        <div class="success-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <p class="success-title">E-mail enviado!</p>
        <p class="success-desc">
          Enviamos um link de recuperação para <strong>{submittedEmail}</strong>.<br />
          Verifique sua caixa de entrada e a pasta de spam.
        </p>
        <a href="/auth/login" class="btn-primary btn-full success-btn">Voltar ao Login</a>
      </div>
    ) : (
      <!-- Formulário -->
      <form class="auth-form" id="recovery-form" method="POST" novalidate>
        <div class="form-group">
          <label class="form-label" for="email">E-mail da conta</label>
          <input
            type="email"
            id="email"
            name="email"
            class="input"
            placeholder="seu@email.com"
            autocomplete="email"
            required
          />
        </div>

        {errorMessage && (
          <p class="auth-error" role="alert">{errorMessage}</p>
        )}

        <button type="submit" class="btn-primary btn-full" id="recovery-submit">
          Enviar Link de Recuperação
        </button>
      </form>
    )}

    <p class="auth-switch-text">
      Lembrou a senha?
      <a href="/auth/login" class="auth-switch-link">Voltar ao login</a>
    </p>
  </div>
</AuthLayout>

<script>
  document.getElementById('recovery-form')?.addEventListener('submit', () => {
    const btn = document.getElementById('recovery-submit') as HTMLButtonElement;
    if (btn) { btn.textContent = 'Enviando…'; btn.disabled = true; }
  });
</script>

<style>
  .auth-form-card {
    background-color: #0A0A0A;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 32px;
  }
  .auth-form-header { margin-bottom: 28px; text-align: center; }
  .auth-form-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 8px;
  }
  .auth-form-subtitle { font-size: 0.875rem; color: #A0A0A0; }
  .auth-form { display: flex; flex-direction: column; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 0.8125rem; font-weight: 500; color: #A0A0A0; }
  .btn-full { width: 100%; margin-top: 8px; height: 48px; font-size: 0.9375rem; }
  .auth-switch-text { text-align: center; font-size: 0.8125rem; color: #4A4A4A; margin-top: 20px; }
  .auth-switch-link { color: #C9A96E; font-weight: 500; transition: color 200ms ease; }
  .auth-switch-link:hover { color: #E8D5A3; }
  .auth-error {
    font-size: 0.8rem;
    color: #ef4444;
    text-align: center;
    font-family: 'Inter', sans-serif;
    margin-top: -4px;
  }

  /* Estado de sucesso */
  .success-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
    padding: 8px 0 16px;
  }
  .success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(201, 169, 110, 0.08);
    border: 1px solid rgba(201, 169, 110, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C9A96E;
    margin-bottom: 4px;
  }
  .success-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #F5F5F5;
  }
  .success-desc {
    font-size: 0.875rem;
    color: #A0A0A0;
    line-height: 1.6;
  }
  .success-desc strong { color: #C9A96E; font-weight: 500; }
  .success-btn { display: flex; align-items: center; justify-content: center; text-decoration: none; }
</style>
