---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { supabase } from '@/lib/supabase';

let errorMessage = '';
let emailConfirmRequired = false;
let submittedEmail = '';

if (Astro.request.method === 'POST') {
  const formData  = await Astro.request.formData();
  const fullName  = formData.get('name')?.toString().trim() ?? '';
  const email     = formData.get('email')?.toString().trim() ?? '';
  const password  = formData.get('password')?.toString() ?? '';
  const confirm   = formData.get('confirm-password')?.toString() ?? '';

  if (password !== confirm) {
    errorMessage = 'As senhas não coincidem. Verifique e tente novamente.';
  } else if (password.length < 8) {
    errorMessage = 'A senha deve ter pelo menos 8 caracteres.';
  } else {
    const { data, error } = await supabase.auth.signUp({
      email,
      password,
      options: {
        // O trigger `handle_new_user` usa este campo para preencher profiles.full_name
        data: { full_name: fullName },
      },
    });

    if (error) {
      errorMessage = error.message.toLowerCase().includes('already registered')
        ? 'Este e-mail já está cadastrado. Tente fazer login.'
        : error.message;
    } else if (data.user && data.session) {
      // Confirmação desabilitada — sessão imediata, grava cookies e entra no app
      const cookieOpts = {
        path:     '/',
        httpOnly: true,
        secure:   import.meta.env.PROD,
        sameSite: 'lax' as const,
        maxAge:   60 * 60 * 24 * 7,
      };
      Astro.cookies.set('sb-access-token',  data.session.access_token,  cookieOpts);
      Astro.cookies.set('sb-refresh-token', data.session.refresh_token, cookieOpts);
      return Astro.redirect('/app/home');
    } else if (data.user && !data.session) {
      // Supabase exige confirmação de e-mail — exibe estado de aguardo
      emailConfirmRequired = true;
      submittedEmail = email;
    }
  }
}
---

<AuthLayout title="Criar Conta">
  <div class="auth-form-card">
    <div class="auth-form-header">
      <img src="/images/logohorizontal.png" class="h-12 w-auto mx-auto mb-8" alt="MQ ACCESS" />
      <h1 class="auth-form-title">
        {emailConfirmRequired ? 'Verifique seu e-mail' : 'Crie sua conta'}
      </h1>
      <p class="auth-form-subtitle">
        {emailConfirmRequired ? 'Um link de confirmação foi enviado' : 'Junte-se à plataforma de executivos'}
      </p>
    </div>

    {emailConfirmRequired ? (
      <!-- Estado: aguardando confirmação de e-mail -->
      <div class="confirm-state">
        <div class="confirm-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <polyline points="2,4 12,13 22,4"/>
          </svg>
        </div>
        <p class="confirm-desc">
          Enviamos um e-mail de confirmação para <strong>{submittedEmail}</strong>.
          <br />Clique no link para ativar sua conta e fazer login.
        </p>
        <p class="confirm-hint">Não recebeu? Verifique a pasta de spam.</p>
        <a href="/auth/login" class="btn-primary btn-full confirm-btn">Ir para o Login</a>
      </div>
    ) : (
      <!-- Formulário de cadastro -->
      <form class="auth-form" id="cadastro-form" method="POST" novalidate>
        <div class="form-group">
          <label class="form-label" for="name">Nome completo</label>
          <input type="text" id="name" name="name" class="input" placeholder="Seu nome" autocomplete="name" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="email">E-mail</label>
          <input type="email" id="email" name="email" class="input" placeholder="seu@email.com" autocomplete="email" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Senha</label>
          <input type="password" id="password" name="password" class="input" placeholder="Mínimo 8 caracteres" autocomplete="new-password" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="confirm-password">Confirmar senha</label>
          <input type="password" id="confirm-password" name="confirm-password" class="input" placeholder="Repita a senha" autocomplete="new-password" required />
        </div>

        {errorMessage && (
          <p class="auth-error" role="alert">{errorMessage}</p>
        )}

        <button type="submit" class="btn-primary btn-full" id="cadastro-submit">
          Criar Minha Conta
        </button>
      </form>
    )}

    <p class="auth-switch-text">
      Já tem uma conta?
      <a href="/auth/login" class="auth-switch-link">Entrar</a>
    </p>
  </div>
</AuthLayout>

<script>
  document.getElementById('cadastro-form')?.addEventListener('submit', () => {
    const btn = document.getElementById('cadastro-submit') as HTMLButtonElement;
    if (btn) { btn.textContent = 'Criando conta…'; btn.disabled = true; }
  });
</script>

<style>
  .auth-form-card {
    background-color: #0A0A0A;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 32px;
  }
  .auth-form-header { margin-bottom: 28px; text-align: center; }
  .auth-form-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 8px;
  }
  .auth-form-subtitle { font-size: 0.875rem; color: #A0A0A0; }
  .auth-form { display: flex; flex-direction: column; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 0.8125rem; font-weight: 500; color: #A0A0A0; }
  .btn-full { width: 100%; margin-top: 8px; height: 48px; font-size: 0.9375rem; }
  .auth-switch-text { text-align: center; font-size: 0.8125rem; color: #4A4A4A; margin-top: 20px; }
  .auth-switch-link { color: #C9A96E; font-weight: 500; transition: color 200ms ease; }
  .auth-switch-link:hover { color: #E8D5A3; }
  .auth-error {
    font-size: 0.8rem;
    color: #ef4444;
    text-align: center;
    font-family: 'Inter', sans-serif;
    margin-top: -4px;
  }

  /* Estado de aguardar confirmação de e-mail */
  .confirm-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    padding: 8px 0 16px;
  }
  .confirm-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(201, 169, 110, 0.08);
    border: 1px solid rgba(201, 169, 110, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C9A96E;
  }
  .confirm-desc {
    font-size: 0.875rem;
    color: #A0A0A0;
    line-height: 1.65;
  }
  .confirm-desc strong { color: #E8D5A3; font-weight: 500; }
  .confirm-hint {
    font-size: 0.75rem;
    color: #3A3A3A;
    margin-top: -8px;
  }
  .confirm-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    margin-top: 4px;
  }
</style>
