---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Confirmar Entrega">
  <div class="sf-shell">

    <div class="sf-card" id="sf-card">

      <!-- Ícone -->
      <div class="sf-icon-wrap">
        <div class="sf-icon-bg"></div>
        <svg class="sf-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
      </div>

      <!-- Header -->
      <div class="sf-header">
        <p class="sf-tag">ENTREGA EXCLUSIVA</p>
        <h1 class="sf-title">Seu exemplar está reservado</h1>
        <p class="sf-subtitle">Para onde devemos enviar sua cópia física de <em>"A Engenharia do Networking"</em>?</p>
      </div>

      <!-- Formulário de endereço -->
      <form class="sf-form" x-data="{ loading: false }"
        @submit.prevent="loading = true; setTimeout(() => window.location.href = '/app/compras', 2000)">

        <!-- CEP -->
        <div class="sf-field sf-field--full">
          <label class="sf-label" for="cep">CEP</label>
          <input id="cep" class="sf-input" type="text" placeholder="00000-000" maxlength="9" autocomplete="postal-code" required />
        </div>

        <!-- Rua + Número -->
        <div class="sf-row sf-row--7030">
          <div class="sf-field">
            <label class="sf-label" for="rua">Rua / Avenida</label>
            <input id="rua" class="sf-input" type="text" placeholder="Av. Brigadeiro Faria Lima" autocomplete="address-line1" required />
          </div>
          <div class="sf-field">
            <label class="sf-label" for="numero">Número</label>
            <input id="numero" class="sf-input" type="text" placeholder="3144" required />
          </div>
        </div>

        <!-- Complemento + Bairro -->
        <div class="sf-row sf-row--equal">
          <div class="sf-field">
            <label class="sf-label" for="complemento">Complemento</label>
            <input id="complemento" class="sf-input" type="text" placeholder="Apto 42 (opcional)" />
          </div>
          <div class="sf-field">
            <label class="sf-label" for="bairro">Bairro</label>
            <input id="bairro" class="sf-input" type="text" placeholder="Itaim Bibi" required />
          </div>
        </div>

        <!-- Cidade + Estado -->
        <div class="sf-row sf-row--equal">
          <div class="sf-field">
            <label class="sf-label" for="cidade">Cidade</label>
            <input id="cidade" class="sf-input" type="text" placeholder="São Paulo" autocomplete="address-level2" required />
          </div>
          <div class="sf-field">
            <label class="sf-label" for="estado">Estado</label>
            <input id="estado" class="sf-input" type="text" placeholder="SP" maxlength="2" autocomplete="address-level1" required />
          </div>
        </div>

        <!-- Nota de entrega -->
        <div class="sf-delivery-note">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          <span>Entrega expressa disponível · Rastreamento em tempo real</span>
        </div>

        <!-- CTA -->
        <button type="submit" class="sf-cta" :disabled="loading">
          <span x-show="!loading">CONFIRMAR ENDEREÇO DE ENTREGA</span>
          <span x-show="loading" class="sf-loading">
            <svg class="sf-spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/>
            </svg>
            Confirmando...
          </span>
        </button>

        <!-- Skip -->
        <a href="/app/compras" class="sf-skip">Pular etapa — preencher depois</a>

      </form>

    </div>

    <p class="sf-footer">MQ ACCESS · Logística VIP</p>
  </div>
</BaseLayout>

<!-- Alpine.js -->
<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

<style>
  .sf-shell {
    min-height: 100dvh;
    background: #000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 16px 64px;
    font-family: 'Inter', sans-serif;
    position: relative;
  }

  .sf-card {
    width: 100%;
    max-width: 520px;
    animation: fade-in-up 0.6s ease both;
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Ícone */
  .sf-icon-wrap {
    position: relative;
    width: 64px; height: 64px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 28px;
  }
  .sf-icon-bg {
    position: absolute; inset: 0;
    border-radius: 50%;
    background: rgba(201,169,110,0.08);
    border: 1px solid rgba(201,169,110,0.2);
  }
  .sf-icon {
    position: relative; z-index: 1;
    color: #C9A96E;
  }

  /* Header */
  .sf-header { margin-bottom: 32px; }
  .sf-tag {
    font-size: .6rem; font-weight: 700; letter-spacing: .2em;
    color: #C9A96E; margin-bottom: 10px; display: block;
  }
  .sf-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.875rem; font-weight: 700;
    color: #F5F5F5; margin-bottom: 10px; line-height: 1.15;
  }
  .sf-subtitle {
    font-size: .875rem; font-weight: 300;
    color: #5A5A5A; line-height: 1.65;
  }
  .sf-subtitle em { color: #8A8A8A; font-style: normal; }

  /* Formulário */
  .sf-form { display: flex; flex-direction: column; gap: 0; }

  .sf-field {
    display: flex; flex-direction: column; gap: 8px;
    margin-bottom: 20px; flex: 1;
  }
  .sf-field--full { width: 100%; }

  .sf-label {
    font-size: .6rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: #3A3A3A;
  }
  .sf-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 10px 0;
    font-family: 'Inter', sans-serif;
    font-size: .9375rem; color: #F5F5F5;
    outline: none; width: 100%;
    transition: border-color 200ms ease;
  }
  .sf-input::placeholder { color: #252525; }
  .sf-input:focus { border-bottom-color: #C9A96E; }

  .sf-row {
    display: grid;
    gap: 20px;
    margin-bottom: 0;
  }
  .sf-row--7030 { grid-template-columns: 7fr 3fr; }
  .sf-row--equal { grid-template-columns: 1fr 1fr; }

  /* Nota de entrega */
  .sf-delivery-note {
    display: flex; align-items: center; gap: 8px;
    font-size: .6875rem; color: #2E2E2E;
    margin-bottom: 28px;
    padding: 12px 14px;
    background: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 8px;
  }
  .sf-delivery-note svg { color: #C9A96E; flex-shrink: 0; }

  /* CTA */
  .sf-cta {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; height: 54px;
    background: #C9A96E; color: #000;
    font-family: 'Inter', sans-serif;
    font-size: .8125rem; font-weight: 700; letter-spacing: .1em;
    border: none; border-radius: 8px; cursor: pointer;
    transition: background 250ms, opacity 200ms;
    margin-bottom: 16px;
  }
  .sf-cta:hover { background: #E8D5A3; }
  .sf-cta:disabled { opacity: .7; cursor: not-allowed; }

  .sf-loading {
    display: flex; align-items: center; gap: 8px;
  }
  .sf-spinner { animation: spin .8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Skip */
  .sf-skip {
    display: block; text-align: center;
    font-size: .75rem; color: #2A2A2A;
    text-decoration: none; transition: color 200ms;
  }
  .sf-skip:hover { color: #6A6A6A; }

  .sf-footer {
    position: fixed; bottom: 20px;
    font-size: .6rem; letter-spacing: .1em; color: #1A1A1A;
  }
</style>
