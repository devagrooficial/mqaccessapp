---
import AppLayout from '@/layouts/AppLayout.astro';
---

<AppLayout title="Avaliação - Passo 1" activeNav="analises">
  <div class="question-page">

    <!-- Indicador de Progresso -->
    <div class="progress-container">
      <div class="progress-bar">
        <div class="progress-fill" style="width: 33%;"></div>
      </div>
      <p class="progress-text">Passo 1 de 3</p>
    </div>

    <!-- Pergunta -->
    <div class="question-container">
      <h1 class="question-title">
        Em reuniões de alta pressão, como você costuma reagir a críticas diretas?
      </h1>

      <!-- Opções -->
      <div class="options-grid">
        <!-- Option 1 -->
        <label class="option-card">
          <input type="radio" name="answer" class="option-radio sr-only" />
          <div class="option-custom-radio"></div>
          <span class="option-text">Tento manter a calma e peço dados concretos que embasem a crítica.</span>
        </label>
        <!-- Option 2 -->
        <label class="option-card">
          <input type="radio" name="answer" class="option-radio sr-only" />
          <div class="option-custom-radio"></div>
          <span class="option-text">Respondo na mesma intensidade para garantir o controle da narrativa.</span>
        </label>
        <!-- Option 3 -->
        <label class="option-card">
          <input type="radio" name="answer" class="option-radio sr-only" />
          <div class="option-custom-radio"></div>
          <span class="option-text">Busco desviar o foco ou apaziguar os ânimos rapidamente para evitar atrito.</span>
        </label>
        <!-- Option 4 -->
        <label class="option-card">
          <input type="radio" name="answer" class="option-radio sr-only" />
          <div class="option-custom-radio"></div>
          <span class="option-text">Defendo firmemente minha equipe e assumo a responsabilidade imediatamente.</span>
        </label>
      </div>
    </div>

    <!-- Navegação -->
    <div class="question-footer">
      <a href="/app/analise-detalhes" class="btn-nav btn-outline">Anterior</a>
      <a href="/app/relatorio" class="btn-nav btn-solid">Finalizar</a>
    </div>

  </div>
</AppLayout>

<style>
  .question-page {
    padding: 24px 16px 80px; /* bottom padding for footer */
    max-width: 640px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
    min-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
  }

  /* Progresso */
  .progress-container {
    margin-bottom: 40px;
  }
  .progress-bar {
    width: 100%;
    height: 4px;
    background-color: rgba(255,255,255,0.05);
    border-radius: 2px;
    margin-bottom: 8px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background-color: #D4AF37;
    border-radius: 2px;
    transition: width 300ms ease;
  }
  .progress-text {
    font-size: 0.75rem;
    color: #5A5A5A;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Pergunta */
  .question-container {
    flex-grow: 1;
  }
  .question-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #F5F5F5;
    line-height: 1.3;
    margin-bottom: 32px;
  }

  /* Opções */
  .options-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .option-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 20px;
    cursor: pointer;
    transition: all 200ms ease;
  }
  .option-card:hover {
    border-color: #D4AF37;
    background-color: rgba(212, 175, 55, 0.05);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .option-custom-radio {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid #4A4A4A;
    flex-shrink: 0;
    margin-top: 2px;
    transition: all 200ms ease;
    position: relative;
  }
  
  /* Estado Checked */
  .option-radio:checked + .option-custom-radio {
    border-color: #D4AF37;
  }
  .option-radio:checked + .option-custom-radio::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #D4AF37;
  }

  .option-text {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #A0A0A0;
    transition: color 200ms ease;
  }
  .option-card:hover .option-text {
    color: #F5F5F5;
  }
  .option-radio:checked ~ .option-text {
    color: #F5F5F5;
  }

  /* Rodapé / Navegação */
  .question-footer {
    display: flex;
    gap: 16px;
    margin-top: 40px;
  }
  .btn-nav {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 200ms ease;
  }
  .btn-outline {
    background-color: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    color: #A0A0A0;
  }
  .btn-outline:hover {
    border-color: rgba(255,255,255,0.3);
    color: #F5F5F5;
  }
  .btn-solid {
    background-color: #D4AF37;
    border: 1px solid #D4AF37;
    color: #000;
  }
  .btn-solid:hover {
    background-color: #F5F5F5;
    border-color: #F5F5F5;
  }
</style>
