---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Finalizar Adesão">
<div class="ck-shell" x-data="{
  upsell: false,
  loading: false,
  basePrice: 1997,
  upsellPrice: 97,
  get total() { return this.basePrice + (this.upsell ? this.upsellPrice : 0) },
  get totalFmt() { return 'R$ ' + this.total.toLocaleString('pt-BR') },
  confirm() {
    this.loading = true;
    setTimeout(() => {
      window.location.href = this.upsell ? '/app/sucesso-fisico' : '/app/sucesso-digital';
    }, 2200);
  }
}">

  <!-- Logo minimalista -->
  <header class="ck-header">
    <a href="/app/home" class="ck-logo" aria-label="MQ ACCESS">
      <img src="/images/logohorizontal.png" alt="MQ Access" class="h-5 w-auto object-contain" />
    </a>
    <div class="ck-secure-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span>Ambiente Seguro</span>
    </div>
  </header>

  <!-- Grid 60/40 -->
  <main class="ck-grid">

    <!-- ═══ COLUNA ESQUERDA — Pagamento ═══ -->
    <div class="ck-payment-col">
      <h1 class="ck-title">Finalizar Adesão</h1>
      <p class="ck-subtitle">Insira os dados do seu cartão para concluir</p>

      <form class="ck-form" @submit.prevent="confirm()">

        <!-- Visualização do cartão -->
        <div class="ck-card-visual" aria-hidden="true">
          <div class="ck-card-chip"></div>
          <div class="ck-card-brand">
            <div class="ck-brand-circle ck-brand-circle--1"></div>
            <div class="ck-brand-circle ck-brand-circle--2"></div>
          </div>
          <p class="ck-card-num-preview">•••• •••• •••• ••••</p>
          <div class="ck-card-meta">
            <span>TITULAR</span>
            <span>MM/AA</span>
          </div>
        </div>

        <!-- Campos -->
        <div class="ck-field">
          <label class="ck-label" for="card-name">Nome no Cartão</label>
          <input id="card-name" class="ck-input" type="text" placeholder="MARIO QUIRINO" autocomplete="cc-name" required />
        </div>

        <div class="ck-field">
          <label class="ck-label" for="card-number">Número do Cartão</label>
          <input id="card-number" class="ck-input" type="text" placeholder="0000 0000 0000 0000" maxlength="19" autocomplete="cc-number" required />
        </div>

        <div class="ck-field-row">
          <div class="ck-field">
            <label class="ck-label" for="card-exp">Validade</label>
            <input id="card-exp" class="ck-input" type="text" placeholder="MM/AA" maxlength="5" autocomplete="cc-exp" required />
          </div>
          <div class="ck-field">
            <label class="ck-label" for="card-cvv">CVV</label>
            <input id="card-cvv" class="ck-input" type="text" placeholder="•••" maxlength="4" autocomplete="cc-csc" required />
          </div>
        </div>

        <!-- Parcelamento -->
        <div class="ck-field">
          <label class="ck-label" for="installments">Parcelamento</label>
          <select id="installments" class="ck-input ck-select">
            <option>1x de R$ 1.997 sem juros</option>
            <option>3x de R$ 665,67 sem juros</option>
            <option>6x de R$ 332,83 sem juros</option>
            <option>12x de R$ 166,42 sem juros</option>
          </select>
        </div>

        <!-- Selo de confiança -->
        <div class="ck-trust">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Conexão Criptografada · Processamento Prioritário</span>
        </div>

        <!-- CTA mobile (hidden desktop) -->
        <button type="submit" class="ck-cta ck-cta--mobile" :disabled="loading" @click="confirm()">
          <span x-show="!loading">CONFIRMAR PAGAMENTO</span>
          <span x-show="loading" class="ck-loading">
            <svg class="ck-spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/></svg>
            Processando...
          </span>
        </button>

      </form>
    </div>

    <!-- ═══ COLUNA DIREITA — Resumo + Upsell ═══ -->
    <div class="ck-summary-col">

      <!-- Resumo do pedido -->
      <div class="ck-summary-card">
        <p class="ck-summary-label">RESUMO DO PEDIDO</p>

        <div class="ck-order-item">
          <div class="ck-order-thumb" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/></svg>
          </div>
          <div class="ck-order-info">
            <p class="ck-order-name">Masterclass · Liderança de Alto Desempenho</p>
            <p class="ck-order-type">Acesso Vitalício · 6h+ de conteúdo</p>
          </div>
          <span class="ck-order-price">R$ 1.997</span>
        </div>

        <!-- Item upsell (condicional) -->
        <div class="ck-order-item" x-show="upsell" x-transition>
          <div class="ck-order-thumb ck-order-thumb--book" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          </div>
          <div class="ck-order-info">
            <p class="ck-order-name">A Engenharia do Networking · Autografado</p>
            <p class="ck-order-type">Livro Físico · Capa Dura · 1ª Edição</p>
          </div>
          <span class="ck-order-price">+R$ 97</span>
        </div>
      </div>

      <!-- Bloco de Upsell -->
      <div class="ck-upsell" :class="upsell ? 'ck-upsell--active' : ''">
        <div class="ck-upsell-top">
          <span class="ck-upsell-tag">EXPERIÊNCIA COMPLETA</span>
          <label class="ck-switch" aria-label="Adicionar livro físico">
            <input type="checkbox" x-model="upsell" />
            <span class="ck-switch-track"></span>
          </label>
        </div>
        <p class="ck-upsell-text">
          Adicionar exemplar físico <strong>"A Engenharia do Networking"</strong> autografado pelo Mario Quirino por apenas <strong>+R$ 97</strong>?
        </p>
        <button
          type="button"
          class="ck-upsell-btn"
          @click="upsell = !upsell"
          x-text="upsell ? '✓ Adicionado ao pedido' : 'Adicionar agora'"
          :class="upsell ? 'ck-upsell-btn--added' : ''"
        ></button>
      </div>

      <!-- Total -->
      <div class="ck-total-block">
        <div class="ck-total-row">
          <span class="ck-total-label">Total</span>
          <span class="ck-total-value" x-text="totalFmt">R$ 1.997</span>
        </div>
        <p class="ck-total-note" x-show="!upsell">ou 12x de R$ 166,42 sem juros</p>
        <p class="ck-total-note" x-show="upsell" x-transition>ou 12x de R$ 174,50 sem juros</p>
      </div>

      <!-- CTA Desktop -->
      <button
        type="button"
        class="ck-cta ck-cta--desktop"
        :disabled="loading"
        @click="confirm()"
      >
        <span x-show="!loading" class="ck-cta-inner">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          CONFIRMAR PAGAMENTO
        </span>
        <span x-show="loading" class="ck-loading">
          <svg class="ck-spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/></svg>
          Processando...
        </span>
      </button>

      <p class="ck-bottom-trust">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Checkout exclusivo MQ · 100% seguro e criptografado
      </p>

    </div>
  </main>
</div>

<!-- Alpine.js -->
<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</BaseLayout>

<style>
  :root { --gold: #C9A96E; --gold-light: #E8D5A3; }

  .ck-shell {
    min-height: 100dvh;
    background: #000;
    display: flex;
    flex-direction: column;
    font-family: 'Inter', sans-serif;
  }

  /* ── Header ── */
  .ck-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .ck-logo {
    display: flex;
    align-items: baseline;
    gap: 2px;
    text-decoration: none;
    line-height: 1;
  }
  .ck-logo-mq { font-family:'Inter',sans-serif; font-size:.7rem; font-weight:700; letter-spacing:.1em; color:#F5F5F5; }
  .ck-logo-a  { font-family:'Playfair Display',serif; font-size:.6rem; color:var(--gold); }

  .ck-secure-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6875rem;
    color: #3A3A3A;
  }

  /* ── Grid ── */
  .ck-grid {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 32px 16px 64px;
    gap: 40px;
  }
  @media (min-width: 860px) {
    .ck-grid {
      grid-template-columns: 3fr 2fr;
      gap: 64px;
      padding: 48px 32px 80px;
      align-items: start;
    }
  }

  /* ══ COLUNA ESQUERDA ══ */
  .ck-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 6px;
  }
  .ck-subtitle { font-size:.8125rem; color:#4A4A4A; margin-bottom:32px; }

  /* Visualização do cartão */
  .ck-card-visual {
    background: linear-gradient(140deg, #161208, #1a1610);
    border: 1px solid rgba(201,169,110,0.12);
    border-radius: 16px;
    padding: 24px;
    height: 160px;
    position: relative;
    overflow: hidden;
    margin-bottom: 32px;
  }
  .ck-card-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 20%, rgba(201,169,110,0.06), transparent 60%);
  }
  .ck-card-chip {
    width: 36px; height: 28px;
    background: linear-gradient(135deg, #C9A96E, #8C6D3F);
    border-radius: 5px;
    margin-bottom: 28px;
  }
  .ck-card-brand { position:absolute; top:20px; right:20px; display:flex; }
  .ck-brand-circle {
    width: 30px; height: 30px;
    border-radius: 50%;
    opacity: 0.6;
  }
  .ck-brand-circle--1 { background:#C9A96E; }
  .ck-brand-circle--2 { background:#8C6D3F; margin-left:-12px; }

  .ck-card-num-preview {
    font-family: 'Inter', monospace;
    font-size: 1rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 16px;
  }
  .ck-card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.2);
  }

  /* Campos */
  .ck-field { display:flex; flex-direction:column; gap:8px; margin-bottom:20px; }
  .ck-field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .ck-label { font-size:.6875rem; font-weight:500; letter-spacing:.06em; color:#4A4A4A; text-transform:uppercase; }

  .ck-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    padding: 10px 0;
    font-family: 'Inter', sans-serif;
    font-size: .9375rem;
    color: #F5F5F5;
    outline: none;
    transition: border-color 200ms ease;
    width: 100%;
  }
  .ck-input::placeholder { color: #2A2A2A; }
  .ck-input:focus { border-bottom-color: var(--gold); }

  .ck-select {
    -webkit-appearance: none;
    cursor: pointer;
    color: #A0A0A0;
  }
  .ck-select option { background: #0A0A0A; }

  /* Selo de confiança */
  .ck-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .6875rem;
    color: #2E2E2E;
    margin-top: 8px;
    margin-bottom: 24px;
  }

  /* ══ COLUNA DIREITA ══ */
  .ck-summary-card {
    background: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 16px;
  }
  .ck-summary-label {
    font-size:.625rem; font-weight:600; letter-spacing:.14em;
    color:#3A3A3A; margin-bottom:16px;
  }

  .ck-order-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .ck-order-item:last-child { border-bottom: none; padding-bottom: 0; }

  .ck-order-thumb {
    width: 40px; height: 40px;
    border-radius: 8px;
    background: #111;
    border: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold); flex-shrink: 0;
  }
  .ck-order-thumb--book { background: #110E08; }

  .ck-order-info { flex: 1; }
  .ck-order-name { font-size:.8125rem; font-weight:500; color:#E0E0E0; margin-bottom:3px; line-height:1.3; }
  .ck-order-type { font-size:.6875rem; color:#3A3A3A; }
  .ck-order-price { font-family:'Playfair Display',serif; font-size:.9375rem; color:#F5F5F5; white-space:nowrap; flex-shrink:0; }

  /* Upsell */
  .ck-upsell {
    border: 1px dashed rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px;
    margin-bottom: 16px;
    transition: border-color 300ms ease, background 300ms ease;
    background: #0A0A0A;
  }
  .ck-upsell--active {
    border-color: rgba(201,169,110,0.35);
    background: rgba(201,169,110,0.03);
  }

  .ck-upsell-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
  .ck-upsell-tag { font-size:.5625rem; font-weight:700; letter-spacing:.16em; color:var(--gold); }

  /* Switch */
  .ck-switch { position:relative; display:inline-block; width:40px; height:22px; cursor:pointer; }
  .ck-switch input { opacity:0; width:0; height:0; }
  .ck-switch-track {
    position:absolute; inset:0;
    background:#1A1A1A;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius:11px;
    transition:background 250ms ease;
  }
  .ck-switch-track::before {
    content:'';
    position:absolute;
    width:16px; height:16px;
    left:2px; top:50%; transform:translateY(-50%);
    background:#3A3A3A;
    border-radius:50%;
    transition:transform 250ms ease, background 250ms ease;
  }
  .ck-switch input:checked ~ .ck-switch-track { background:rgba(201,169,110,0.2); border-color:var(--gold); }
  .ck-switch input:checked ~ .ck-switch-track::before { transform:translate(18px,-50%); background:var(--gold); }

  .ck-upsell-text { font-size:.8125rem; color:#4A4A4A; line-height:1.6; margin-bottom:14px; }
  .ck-upsell-text strong { color:#8A8A8A; }

  .ck-upsell-btn {
    display:inline-flex; align-items:center; gap:6px;
    font-family:'Inter',sans-serif; font-size:.6875rem; font-weight:600;
    letter-spacing:.08em; color:var(--gold);
    background:transparent; border:1px solid rgba(201,169,110,0.25);
    border-radius:6px; padding:7px 14px; cursor:pointer;
    transition:background 200ms, border-color 200ms, color 200ms;
  }
  .ck-upsell-btn:hover { background:rgba(201,169,110,0.06); border-color:var(--gold); }
  .ck-upsell-btn--added { color:#000; background:var(--gold); border-color:var(--gold); }

  /* Total */
  .ck-total-block {
    padding: 16px 0;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 20px;
  }
  .ck-total-row { display:flex; align-items:baseline; justify-content:space-between; margin-bottom:4px; }
  .ck-total-label { font-size:.75rem; color:#4A4A4A; }
  .ck-total-value { font-family:'Playfair Display',serif; font-size:1.875rem; font-weight:700; color:#F5F5F5; }
  .ck-total-note { font-size:.6875rem; color:#2E2E2E; text-align:right; }

  /* CTA */
  .ck-cta {
    display:flex; align-items:center; justify-content:center; gap:10px;
    width:100%; height:54px;
    background:var(--gold); color:#000;
    font-family:'Inter',sans-serif; font-size:.8125rem; font-weight:700; letter-spacing:.12em;
    border:none; border-radius:8px; cursor:pointer;
    transition:background 250ms, opacity 200ms;
    margin-bottom:12px;
  }
  .ck-cta:hover { background:var(--gold-light); }
  .ck-cta:disabled { opacity:.7; cursor:not-allowed; }
  .ck-cta--mobile { display:flex; }
  .ck-cta--desktop { display:none; }
  @media (min-width:860px) {
    .ck-cta--mobile { display:none; }
    .ck-cta--desktop { display:flex; }
  }
  .ck-cta-inner { display:flex; align-items:center; gap:8px; }

  /* Loading spinner */
  .ck-loading { display:flex; align-items:center; gap:8px; }
  .ck-spinner {
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform:rotate(360deg); } }

  .ck-bottom-trust {
    display:flex; align-items:center; justify-content:center; gap:6px;
    font-size:.6875rem; color:#252525; text-align:center;
  }
</style>
