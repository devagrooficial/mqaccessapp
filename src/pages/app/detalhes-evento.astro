---
import AppLayout from '@/layouts/AppLayout.astro';

// ── SSR: Guard + Queries paralelas ───────────────────────────────────
const supabase = Astro.locals.supabase;
const eventId  = Astro.url.searchParams.get('id');

console.log('=========================================');
console.log('🎪 [DETALHES-EVENTO] Rota alcançada');
console.log('🎪 [DETALHES-EVENTO] eventId:', eventId ?? '⚠️ VAZIO — redirect iminente');

if (!eventId) {
  console.error('🚨 [DETALHES-EVENTO] sem ?id= na URL. Redirecionando para /app/home.');
  return Astro.redirect('/app/home');
}

// Queries paralelas — tiers/agenda/speakers só bloqueiam se EVENTO falhar
const [
  { data: event,      error: eventError   },
  { data: tiersRaw,   error: tiersError   },
  { data: agendaRaw,  error: agendaError  },
  { data: speakersRaw, error: speakersError },
] = await Promise.all([
  supabase
    .from('events')
    .select('id, title, tagline, banner_url, date, venue_name, venue_address, duration_hours, available_spots')
    .eq('id', eventId)
    .single(),
  supabase
    .from('event_ticket_tiers')
    .select('id, name, price_brl, perks')
    .eq('event_id', eventId)
    .order('price_brl', { ascending: true }),
  supabase
    .from('event_agenda')
    .select('id, time, title, description')
    .eq('event_id', eventId)
    .order('time', { ascending: true }),
  supabase
    .from('event_speakers')
    .select('id, name, role, avatar_url')
    .eq('event_id', eventId),
]);

// Logs de diagnóstico — leia no terminal ao acessar a rota
console.log('🎪 [DETALHES-EVENTO] eventError    :', eventError?.code    ?? 'nenhum', eventError?.message    ?? '');
console.log('🎪 [DETALHES-EVENTO] event.title  :', event?.title ?? '(null)');
console.log('🎪 [DETALHES-EVENTO] tiersError   :', tiersError?.code   ?? 'nenhum', tiersError?.message   ?? '');
console.log('🎪 [DETALHES-EVENTO] tiers count  :', tiersRaw?.length ?? 0);
console.log('🎪 [DETALHES-EVENTO] agendaError  :', agendaError?.code  ?? 'nenhum', agendaError?.message  ?? '');
console.log('🎪 [DETALHES-EVENTO] agenda count :', agendaRaw?.length ?? 0);
console.log('🎪 [DETALHES-EVENTO] speakersErr  :', speakersError?.code ?? 'nenhum', speakersError?.message ?? '');
console.log('🎪 [DETALHES-EVENTO] speakers cnt :', speakersRaw?.length ?? 0);

// 🚨 Só redireciona se o EVENTO em si não for encontrado
if (eventError || !event) {
  console.error('🚨 [DETALHES-EVENTO] Evento não encontrado. ID:', eventId);
  console.error('🚨 [DETALHES-EVENTO] Código:', eventError?.code, '| Detalhe:', eventError?.details);
  return Astro.redirect('/app/home');
}

// Dados secundários: só loga o warning, nunca bloqueia
if (tiersError)    console.warn('⚠️ [DETALHES-EVENTO] tiers error (continua):', tiersError.message);
if (agendaError)   console.warn('⚠️ [DETALHES-EVENTO] agenda error (continua):', agendaError.message);
if (speakersError) {
  console.error('🚨 [SPEAKERS] Erro completo:', JSON.stringify(speakersError));
}

// ── Diagnóstico detalhado de speakers ──────────────────────────────────────
console.log('🎤 [SPEAKERS] eventId usado na query :', eventId);
console.log('🎤 [SPEAKERS] speakersRaw            :', JSON.stringify(speakersRaw ?? null));
console.log('🎤 [SPEAKERS] speakersError           :', JSON.stringify(speakersError ?? null));

// Query de validação isolada — descobre se é problema de RLS ou nome de coluna
const { data: speakersCheck, error: speakersCheckErr } = await supabase
  .from('event_speakers')
  .select('*')
  .limit(3);
console.log('🎤 [SPEAKERS CHECK] Primeiros 3 registros da tabela:', JSON.stringify(speakersCheck ?? null));
console.log('🎤 [SPEAKERS CHECK] Erro sem filtro              :', JSON.stringify(speakersCheckErr ?? null));

const tiers    = tiersRaw    ?? [];
const agenda   = agendaRaw   ?? [];
const speakers = speakersRaw ?? [];

console.log('🎪 [DETALHES-EVENTO] ✅ Evento carregado. Renderizando...');
console.log('=========================================');

// ── Helpers de formatação ─────────────────────────────────────────────────
const brl = (cents: number) =>
  (cents / 100).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

// Formata time do banco: suporta "09:00:00", "09:00" e timestamps ISO completos
const formatTime = (t: string | null | undefined): string => {
  if (!t) return '--h--';
  // Timestamp ISO (ex: "2025-05-04T09:00:00" ou "2025-05-04T09:00:00.000Z")
  if (t.includes('T')) {
    const d = new Date(t);
    if (isNaN(d.getTime())) return '--h--';
    const h = String(d.getUTCHours()).padStart(2, '0');
    const m = String(d.getUTCMinutes()).padStart(2, '0');
    return `${h}h${m}`;
  }
  // String de hora simples (ex: "09:00:00" ou "09:00")
  const parts = t.split(':');
  const h = parts[0]?.padStart(2, '0') ?? '--';
  const m = parts[1]?.padStart(2, '0') ?? '--';
  return `${h}h${m}`;
};

// Guard defensivo: `date` pode ser null no banco
const dateObj    = event.date ? new Date(event.date) : null;
const isValidDate = dateObj instanceof Date && !isNaN(dateObj.getTime());

const dateLong   = isValidDate
  ? dateObj!.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })
  : 'Data a confirmar';
const datePill   = isValidDate
  ? dateObj!.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase()
  : 'EM BREVE';
const weekdayCap = isValidDate
  ? (() => { const w = dateObj!.toLocaleDateString('pt-BR', { weekday: 'long' }); return w.charAt(0).toUpperCase() + w.slice(1); })()
  : '';

// agenda e speakers agora v\u00eam do banco (agendaRaw / speakersRaw acima)
---

<AppLayout title={`${event.title} | MQ ACCESS`}>

  <!-- ─── HERO IMERSIVO ─── -->
  <div class="ev-hero">
    <div class="ev-hero-bg" style={`background-image: url('${event.banner_url ?? '/summit-mq-banner.png'}')`}></div>
    <div class="ev-hero-overlay"></div>

    <!-- Voltar -->
    <a href="/app/compras" class="ev-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Voltar
    </a>

    <!-- Conteúdo hero -->
    <div class="ev-hero-content" id="ev-hero-content">
      <span class="ev-tag">EVENTO PRESENCIAL EXCLUSIVO</span>
      <h1 class="ev-hero-title">{event.title}</h1>
      {event.tagline && <p class="ev-hero-sub">{event.tagline}</p>}

      <div class="ev-hero-pills">
        <div class="ev-pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {datePill}
        </div>
        <div class="ev-pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {event.venue_name}
        </div>
        {(event.available_spots !== null && event.available_spots <= 20) && (
          <div class="ev-pill ev-pill--vagas">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
            {event.available_spots === 0 ? 'Esgotado' : 'Poucas vagas'}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- ─── CORPO (2 colunas) ─── -->
  <div class="ev-body" x-data={`{ ticket: '${tiers.length > 0 ? tiers[tiers.length - 1].id : ''}' }`}>

    <!-- ── Coluna Esquerda ── -->
    <div class="ev-left" id="ev-left">

      <!-- Bloco: Data & Local -->
      <section class="ev-section">
        <p class="ev-section-label">LOGÍSTICA</p>
        <div class="ev-logistics">
          <div class="ev-logistic-item">
            <div class="ev-logistic-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <p class="ev-logistic-main">{dateLong}</p>
              <p class="ev-logistic-sub">{weekdayCap} · a partir das 09h</p>
            </div>
          </div>
          <div class="ev-logistic-item">
            <div class="ev-logistic-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="ev-logistic-main">{event.venue_name}</p>
              {event.venue_address && <p class="ev-logistic-sub">{event.venue_address}</p>}
            </div>
          </div>
          {event.duration_hours && (
            <div class="ev-logistic-item">
              <div class="ev-logistic-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <p class="ev-logistic-main">{event.duration_hours} horas de immersão</p>
                <p class="ev-logistic-sub">Credenciamento a partir das 08h30</p>
              </div>
            </div>
          )}
        </div>
      </section>

      <!-- Separador -->
      <div class="ev-sep"></div>

      <!-- Bloco: Agenda -->
      <section class="ev-section">
        <p class="ev-section-label">AGENDA DO DIA</p>
        <div class="ev-timeline">
          {Array.isArray(agenda) && agenda.length > 0 ? (
            agenda.map((item, i) => (
              <div class="ev-agenda-item">
                <div class="ev-agenda-left">
                  <span class="ev-agenda-time">{formatTime(item.time)}</span>
                  {i < agenda.length - 1 && <div class="ev-agenda-line"></div>}
                </div>
                <div class="ev-agenda-content">
                  <p class="ev-agenda-title">{item.title}</p>
                  <p class="ev-agenda-desc">{item.description}</p>
                </div>
              </div>
            ))
          ) : (
            <p class="ev-empty-state">Programação oficial em definição. Em breve divulgaremos os horários.</p>
          )}
        </div>
      </section>

      <!-- Separador -->
      <div class="ev-sep"></div>

      <!-- Bloco: Speakers -->
      <section class="ev-section">
        <p class="ev-section-label">CONFIRMADOS NO PALCO</p>

        {Array.isArray(speakers) && speakers.length > 0 ? (
          <div class="ev-speakers">
            {speakers.map(s => (
              <div class="ev-speaker">
                <!-- Avatar: imagem ou inicial dourada -->
                {s.avatar_url ? (
                  <img
                    src={s.avatar_url}
                    alt={s.name}
                    class="ev-speaker-avatar ev-speaker-avatar--img"
                  />
                ) : (
                  <div class="ev-speaker-avatar">
                    {s.name ? s.name.charAt(0).toUpperCase() : '?'}
                  </div>
                )}

                <!-- Info -->
                <div class="ev-speaker-info">
                  <p class="ev-speaker-name">{s.name}</p>
                  <p class="ev-speaker-role">{s.role}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="ev-empty-state">Line-up de palestrantes sendo finalizado. Aguarde novidades.</p>
        )}
      </section>

      <!-- Separador -->
      <div class="ev-sep"></div>

      <!-- Bloco: Garantia -->
      <section class="ev-section ev-guarantee">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        <div>
          <p class="ev-guarantee-title">Satisfação Garantida</p>
          <p class="ev-guarantee-text">Se por qualquer motivo você não puder comparecer, reembolsamos integralmente em até 30 dias antes do evento.</p>
        </div>
      </section>

    </div>

    <!-- ── Coluna Direita: Buy Box Sticky ── -->
    <div class="ev-right">
      <div class="ev-buybox" id="ev-buybox">

        <p class="ev-buybox-label">SELECIONE SEU ACESSO</p>

        {Array.isArray(tiers) && tiers.length > 0 ? (
          tiers.map((tier, idx) => {
            // Destaque visual no tier de maior preço (sem depender de is_featured)
            const isFeatured = idx === tiers.length - 1;
            const perksArr = Array.isArray(tier.perks) ? tier.perks as string[] : null;
            return (
              <label
                class={`ev-ticket-card${isFeatured ? ' ev-ticket-card--vip' : ''}`}
                :class={`ticket === '${tier.id}' && 'ev-ticket-card--selected'`}
                @click={`ticket = '${tier.id}'`}
              >
                {isFeatured && <div class="ev-ticket-badge-vip">MAIS POPULAR</div>}
                <div class="ev-ticket-header">
                  <div class="ev-ticket-radio" :class={`ticket === '${tier.id}' && 'ev-ticket-radio--on'`}></div>
                  <p class="ev-ticket-name">{tier.name}</p>
                </div>
                <p class={`ev-ticket-price${isFeatured ? ' ev-ticket-price--gold' : ''}`}>
                  {brl(tier.price_brl)}
                </p>
                {perksArr && (
                  <ul class="ev-ticket-perks">
                    {perksArr.map(perk => (
                      <li class={isFeatured ? 'ev-perk--gold' : ''}>✦ {perk}</li>
                    ))}
                  </ul>
                )}
              </label>
            );
          })
        ) : (
          <p class="ev-no-tiers">Ingressos disponíveis em breve.</p>
        )}

        <!-- CTA: form POST — ids enviados via hidden inputs, nunca pela URL -->
        <form
          action="/app/checkout-evento"
          method="POST"
          id="ev-reserve-form"
        >
          <input type="hidden" name="evento_id" value={eventId} />
          <!-- tier_id é atualizado pelo Alpine ao selecionar o card -->
          <input
            type="hidden"
            name="tier_id"
            id="ev-tier-hidden"
            :value="ticket"
            value={tiers.length > 0 ? tiers[tiers.length - 1].id : ''}
          />

          <button type="submit" class="ev-cta" @click.prevent={`
            const t = ticket || '${tiers.length > 0 ? tiers[tiers.length - 1].id : ''}';
            if (!t || t.length < 10) { alert('Selecione um tipo de ingresso.'); return; }
            document.getElementById('ev-tier-hidden').value = t;
            document.getElementById('ev-reserve-form').submit();
          `}>
            <span>RESERVAR MEU LUGAR</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </form>


        <p class="ev-microcopy">Vagas estritamente limitadas pela capacidade do local.</p>

        <!-- Selos de confiança -->
        <div class="ev-trust">
          <div class="ev-trust-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            Pagamento Seguro
          </div>
          <div class="ev-trust-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            30 dias de garantia
          </div>
          <div class="ev-trust-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Ingresso digital imediato
          </div>
        </div>

      </div>
    </div>

  </div>

</AppLayout>

<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    // Hero content
    gsap.from('#ev-hero-content', {
      y: 40, opacity: 0, duration: 1, ease: 'power3.out', delay: 0.1
    });

    // Left column sections cascade
    gsap.from('.ev-section', {
      y: 24, opacity: 0, duration: 0.5, stagger: 0.12, ease: 'power2.out',
      scrollTrigger: { trigger: '.ev-body', start: 'top 85%' }
    });

    // Agenda items cascade
    gsap.from('.ev-agenda-item', {
      x: -20, opacity: 0, duration: 0.4, stagger: 0.08, ease: 'power2.out', delay: 0.3,
      scrollTrigger: { trigger: '.ev-timeline', start: 'top 80%' }
    });

    // Buy box
    gsap.from('#ev-buybox', {
      y: 20, opacity: 0, duration: 0.6, ease: 'power2.out', delay: 0.4,
      scrollTrigger: { trigger: '.ev-body', start: 'top 80%' }
    });
  });
</script>

<style>
  /* ─── HERO ─── */
  .ev-hero {
    position: relative;
    height: 42vh; min-height: 300px;
    display: flex; align-items: flex-end;
    overflow: hidden;
  }
  .ev-hero-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center 30%;
    filter: grayscale(30%) brightness(0.45);
    transform: scale(1.03);
    transition: transform 8s ease;
  }
  .ev-hero:hover .ev-hero-bg { transform: scale(1.0); }

  .ev-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.25) 0%,
      rgba(0,0,0,0.5)  50%,
      rgba(0,0,0,0.92) 100%
    );
  }

  .ev-back {
    position: absolute; top: 16px; left: 16px; z-index: 10;
    display: flex; align-items: center; gap: 8px;
    font-size: .75rem; color: rgba(255,255,255,0.5);
    text-decoration: none; backdrop-filter: blur(4px);
    background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);
    padding: 6px 12px; border-radius: 20px;
    transition: color 200ms, background 200ms;
  }
  .ev-back:hover { color: #fff; background: rgba(0,0,0,0.5); }

  .ev-hero-content {
    position: relative; z-index: 1;
    padding: 0 20px 28px; width: 100%;
    max-width: 900px;
  }
  .ev-tag {
    display: inline-block;
    font-size: .575rem; font-weight: 700; letter-spacing: .2em;
    color: #C9A96E; margin-bottom: 10px;
  }
  .ev-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700; color: #F5F5F5; line-height: 1.1;
    margin-bottom: 10px;
  }
  .ev-hero-sub {
    font-size: clamp(.875rem, 2vw, 1rem);
    color: rgba(255,255,255,0.45); max-width: 500px;
    line-height: 1.5; margin-bottom: 18px;
  }

  .ev-hero-pills { display: flex; gap: 8px; flex-wrap: wrap; }
  .ev-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: .65rem; font-weight: 500; letter-spacing: .06em;
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.09);
    padding: 5px 12px; border-radius: 20px; backdrop-filter: blur(4px);
  }
  .ev-pill--vagas { color: #C9A96E; border-color: rgba(201,169,110,0.2); background: rgba(201,169,110,0.06); }
  .ev-pill--vagas svg { fill: #C9A96E; }

  /* ─── BODY LAYOUT ─── */
  .ev-body {
    background: #000;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding: 0 0 80px;
  }
  @media (min-width: 860px) {
    .ev-body {
      grid-template-columns: 2fr 1fr;
      align-items: start;
      gap: 48px;
      padding: 0 48px 60px;
    }
  }

  /* ─── LEFT ─── */
  .ev-left { padding: 32px 20px 0; }
  @media (min-width: 860px) { .ev-left { padding: 40px 32px 0 0; } }

  .ev-sep {
    height: 1px;
    background: rgba(255,255,255,0.04);
    margin: 28px 0;
  }

  .ev-section { }
  .ev-section-label {
    font-size: .575rem; font-weight: 700; letter-spacing: .18em;
    color: #2A2A2A; margin-bottom: 20px;
  }

  /* Logística */
  .ev-logistics { display: flex; flex-direction: column; gap: 16px; }
  .ev-logistic-item {
    display: flex; align-items: flex-start; gap: 14px;
  }
  .ev-logistic-icon {
    width: 36px; height: 36px; flex-shrink: 0;
    background: #0A0A0A; border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #C9A96E;
  }
  .ev-logistic-main { font-size: .9375rem; font-weight: 600; color: #E0E0E0; margin-bottom: 2px; }
  .ev-logistic-sub  { font-size: .75rem; color: #3A3A3A; }

  /* Agenda timeline */
  .ev-timeline { display: flex; flex-direction: column; }
  .ev-agenda-item { display: flex; gap: 16px; }
  .ev-agenda-left {
    display: flex; flex-direction: column; align-items: center;
    width: 48px; flex-shrink: 0;
  }
  .ev-agenda-time {
    font-size: .65rem; font-weight: 700; color: #C9A96E;
    letter-spacing: .04em; white-space: nowrap; padding-top: 2px;
  }
  .ev-agenda-line {
    flex: 1; width: 1px;
    background: linear-gradient(to bottom, rgba(201,169,110,0.2), rgba(255,255,255,0.04));
    margin: 6px 0;
  }
  .ev-agenda-content { padding-bottom: 22px; }
  .ev-agenda-title {
    font-family: 'Playfair Display', serif;
    font-size: .9375rem; font-weight: 700; color: #E0E0E0;
