---
import AppLayout from '@/layouts/AppLayout.astro';

const agenda = [
  { time: '09h00', title: 'Abertura — Mentalidade de Elite', desc: 'A mentalidade que separa líderes comuns de líderes excepcionais.' },
  { time: '10h30', title: 'Painel: Decisões que Constroem Legados', desc: 'Como os maiores executivos tomam decisões sob pressão.' },
  { time: '12h30', title: 'Almoço de Negócios', desc: 'Networking estruturado com outros líderes presentes.' },
  { time: '14h00', title: 'Engenharia do Networking de Alto Nível', desc: 'Metodologia exclusiva para conexões que geram resultados.' },
  { time: '16h00', title: 'Workshop: Pipeline de Decisões Críticas', desc: 'Prática aplicada com frameworks de gestão avançada.' },
  { time: '18h00', title: 'Networking de Alto Impacto + Encerramento', desc: 'Sessão final e networking livre com os presentes.' },
];

const speakers = [
  { name: 'Mario Quirino', role: 'Host & Palestrante Principal', initials: 'MQ' },
  { name: 'Convidado Especial', role: 'C-Level · Mercado Financeiro', initials: 'CE' },
  { name: 'Convidada Especial', role: 'Board Member · Tech & Inovação', initials: 'CE' },
];
---

<AppLayout title="Summit MQ · São Paulo | MQ ACCESS">

  <!-- ─── HERO IMERSIVO ─── -->
  <div class="ev-hero">
    <div class="ev-hero-bg" style="background-image: url('/summit-mq-banner.png')"></div>
    <div class="ev-hero-overlay"></div>

    <!-- Voltar -->
    <a href="/app/compras" class="ev-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Voltar
    </a>

    <!-- Conteúdo hero -->
    <div class="ev-hero-content" id="ev-hero-content">
      <span class="ev-tag">EVENTO PRESENCIAL EXCLUSIVO</span>
      <h1 class="ev-hero-title">Summit MQ<br>São Paulo</h1>
      <p class="ev-hero-sub">A reunião definitiva de líderes que moldam o mercado.</p>

      <div class="ev-hero-pills">
        <div class="ev-pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          15 AGO 2026
        </div>
        <div class="ev-pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Grand Hyatt · SP
        </div>
        <div class="ev-pill ev-pill--vagas">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
          Poucas vagas
        </div>
      </div>
    </div>
  </div>

  <!-- ─── CORPO (2 colunas) ─── -->
  <div class="ev-body" x-data="{ ticket: 'vip' }">

    <!-- ── Coluna Esquerda ── -->
    <div class="ev-left" id="ev-left">

      <!-- Bloco: Data & Local -->
      <section class="ev-section">
        <p class="ev-section-label">LOGÍSTICA</p>
        <div class="ev-logistics">
          <div class="ev-logistic-item">
            <div class="ev-logistic-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <p class="ev-logistic-main">15 de Agosto de 2026</p>
              <p class="ev-logistic-sub">Sexta-feira · 09h às 20h</p>
            </div>
          </div>
          <div class="ev-logistic-item">
            <div class="ev-logistic-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="ev-logistic-main">Grand Hyatt Hotel</p>
              <p class="ev-logistic-sub">Av. das Nações Unidas, 13.301 · São Paulo</p>
            </div>
          </div>
          <div class="ev-logistic-item">
            <div class="ev-logistic-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="ev-logistic-main">11 horas de imersão</p>
              <p class="ev-logistic-sub">Credenciamento a partir das 08h30</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Separador -->
      <div class="ev-sep"></div>

      <!-- Bloco: Agenda -->
      <section class="ev-section">
        <p class="ev-section-label">AGENDA DO DIA</p>
        <div class="ev-timeline">
          {agenda.map((item, i) => (
            <div class="ev-agenda-item">
              <div class="ev-agenda-left">
                <span class="ev-agenda-time">{item.time}</span>
                {i < agenda.length - 1 && <div class="ev-agenda-line"></div>}
              </div>
              <div class="ev-agenda-content">
                <p class="ev-agenda-title">{item.title}</p>
                <p class="ev-agenda-desc">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Separador -->
      <div class="ev-sep"></div>

      <!-- Bloco: Speakers -->
      <section class="ev-section">
        <p class="ev-section-label">CONFIRMADOS NO PALCO</p>
        <div class="ev-speakers">
          {speakers.map(s => (
            <div class="ev-speaker">
              <div class="ev-speaker-avatar">{s.initials}</div>
              <div>
                <p class="ev-speaker-name">{s.name}</p>
                <p class="ev-speaker-role">{s.role}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Separador -->
      <div class="ev-sep"></div>

      <!-- Bloco: Garantia -->
      <section class="ev-section ev-guarantee">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        <div>
          <p class="ev-guarantee-title">Satisfação Garantida</p>
          <p class="ev-guarantee-text">Se por qualquer motivo você não puder comparecer, reembolsamos integralmente em até 30 dias antes do evento.</p>
        </div>
      </section>

    </div>

    <!-- ── Coluna Direita: Buy Box Sticky ── -->
    <div class="ev-right">
      <div class="ev-buybox" id="ev-buybox">

        <p class="ev-buybox-label">SELECIONE SEU ACESSO</p>

        <!-- Opção 1: Executivo -->
        <label class="ev-ticket-card" :class="ticket === 'exec' && 'ev-ticket-card--selected'" @click="ticket = 'exec'">
          <div class="ev-ticket-header">
            <div class="ev-ticket-radio" :class="ticket === 'exec' && 'ev-ticket-radio--on'"></div>
            <p class="ev-ticket-name">Acesso Executivo</p>
          </div>
          <p class="ev-ticket-price">R$ 997 <span>ou 3× de R$ 332</span></p>
          <ul class="ev-ticket-perks">
            <li>Acesso completo ao evento</li>
            <li>Material de apoio impresso</li>
            <li>Coffee break incluso</li>
          </ul>
        </label>

        <!-- Opção 2: VIP (destaque) -->
        <label class="ev-ticket-card ev-ticket-card--vip" :class="ticket === 'vip' && 'ev-ticket-card--selected'" @click="ticket = 'vip'">
          <div class="ev-ticket-badge-vip">MAIS POPULAR</div>
          <div class="ev-ticket-header">
            <div class="ev-ticket-radio" :class="ticket === 'vip' && 'ev-ticket-radio--on'"></div>
            <p class="ev-ticket-name">Acesso VIP</p>
          </div>
          <p class="ev-ticket-price ev-ticket-price--gold">R$ 1.997 <span>ou 6× de R$ 332</span></p>
          <ul class="ev-ticket-perks">
            <li class="ev-perk--gold">✦ Assentos Frontais Reservados</li>
            <li class="ev-perk--gold">✦ Almoço exclusivo com Mario Quirino</li>
            <li class="ev-perk--gold">✦ Acesso ao VIP Lounge</li>
            <li>Material de apoio impresso</li>
            <li>Sessão de fotos com o palestrante</li>
          </ul>
        </label>

        <!-- CTA -->
        <a href="/app/checkout-evento" class="ev-cta">
          <span>RESERVAR MEU LUGAR</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <p class="ev-microcopy">Vagas estritamente limitadas pela capacidade do local.</p>

        <!-- Selos de confiança -->
        <div class="ev-trust">
          <div class="ev-trust-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            Pagamento Seguro
          </div>
          <div class="ev-trust-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            30 dias de garantia
          </div>
          <div class="ev-trust-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Ingresso digital imediato
          </div>
        </div>

      </div>
    </div>

  </div>

</AppLayout>

<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    // Hero content
    gsap.from('#ev-hero-content', {
      y: 40, opacity: 0, duration: 1, ease: 'power3.out', delay: 0.1
    });

    // Left column sections cascade
    gsap.from('.ev-section', {
      y: 24, opacity: 0, duration: 0.5, stagger: 0.12, ease: 'power2.out',
      scrollTrigger: { trigger: '.ev-body', start: 'top 85%' }
    });

    // Agenda items cascade
    gsap.from('.ev-agenda-item', {
      x: -20, opacity: 0, duration: 0.4, stagger: 0.08, ease: 'power2.out', delay: 0.3,
      scrollTrigger: { trigger: '.ev-timeline', start: 'top 80%' }
    });

    // Buy box
    gsap.from('#ev-buybox', {
      y: 20, opacity: 0, duration: 0.6, ease: 'power2.out', delay: 0.4,
      scrollTrigger: { trigger: '.ev-body', start: 'top 80%' }
    });
  });
</script>

<style>
  /* ─── HERO ─── */
  .ev-hero {
    position: relative;
    height: 42vh; min-height: 300px;
    display: flex; align-items: flex-end;
    overflow: hidden;
  }
  .ev-hero-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center 30%;
    filter: grayscale(30%) brightness(0.45);
    transform: scale(1.03);
    transition: transform 8s ease;
  }
  .ev-hero:hover .ev-hero-bg { transform: scale(1.0); }

  .ev-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.25) 0%,
      rgba(0,0,0,0.5)  50%,
      rgba(0,0,0,0.92) 100%
    );
  }

  .ev-back {
    position: absolute; top: 16px; left: 16px; z-index: 10;
    display: flex; align-items: center; gap: 8px;
    font-size: .75rem; color: rgba(255,255,255,0.5);
    text-decoration: none; backdrop-filter: blur(4px);
    background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.08);
    padding: 6px 12px; border-radius: 20px;
    transition: color 200ms, background 200ms;
  }
  .ev-back:hover { color: #fff; background: rgba(0,0,0,0.5); }

  .ev-hero-content {
    position: relative; z-index: 1;
    padding: 0 20px 28px; width: 100%;
    max-width: 900px;
  }
  .ev-tag {
    display: inline-block;
    font-size: .575rem; font-weight: 700; letter-spacing: .2em;
    color: #C9A96E; margin-bottom: 10px;
  }
  .ev-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700; color: #F5F5F5; line-height: 1.1;
    margin-bottom: 10px;
  }
  .ev-hero-sub {
    font-size: clamp(.875rem, 2vw, 1rem);
    color: rgba(255,255,255,0.45); max-width: 500px;
    line-height: 1.5; margin-bottom: 18px;
  }

  .ev-hero-pills { display: flex; gap: 8px; flex-wrap: wrap; }
  .ev-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: .65rem; font-weight: 500; letter-spacing: .06em;
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.09);
    padding: 5px 12px; border-radius: 20px; backdrop-filter: blur(4px);
  }
  .ev-pill--vagas { color: #C9A96E; border-color: rgba(201,169,110,0.2); background: rgba(201,169,110,0.06); }
  .ev-pill--vagas svg { fill: #C9A96E; }

  /* ─── BODY LAYOUT ─── */
  .ev-body {
    background: #000;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding: 0 0 80px;
  }
  @media (min-width: 860px) {
    .ev-body {
      grid-template-columns: 2fr 1fr;
      align-items: start;
      gap: 48px;
      padding: 0 48px 60px;
    }
  }

  /* ─── LEFT ─── */
  .ev-left { padding: 32px 20px 0; }
  @media (min-width: 860px) { .ev-left { padding: 40px 32px 0 0; } }

  .ev-sep {
    height: 1px;
    background: rgba(255,255,255,0.04);
    margin: 28px 0;
  }

  .ev-section { }
  .ev-section-label {
    font-size: .575rem; font-weight: 700; letter-spacing: .18em;
    color: #2A2A2A; margin-bottom: 20px;
  }

  /* Logística */
  .ev-logistics { display: flex; flex-direction: column; gap: 16px; }
  .ev-logistic-item {
    display: flex; align-items: flex-start; gap: 14px;
  }
  .ev-logistic-icon {
    width: 36px; height: 36px; flex-shrink: 0;
    background: #0A0A0A; border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #C9A96E;
  }
  .ev-logistic-main { font-size: .9375rem; font-weight: 600; color: #E0E0E0; margin-bottom: 2px; }
  .ev-logistic-sub  { font-size: .75rem; color: #3A3A3A; }

  /* Agenda timeline */
  .ev-timeline { display: flex; flex-direction: column; }
  .ev-agenda-item { display: flex; gap: 16px; }
  .ev-agenda-left {
    display: flex; flex-direction: column; align-items: center;
    width: 48px; flex-shrink: 0;
  }
  .ev-agenda-time {
    font-size: .65rem; font-weight: 700; color: #C9A96E;
    letter-spacing: .04em; white-space: nowrap; padding-top: 2px;
  }
  .ev-agenda-line {
    flex: 1; width: 1px;
    background: linear-gradient(to bottom, rgba(201,169,110,0.2), rgba(255,255,255,0.04));
    margin: 6px 0;
  }
  .ev-agenda-content { padding-bottom: 22px; }
  .ev-agenda-title {
    font-family: 'Playfair Display', serif;
    font-size: .9375rem; font-weight: 700; color: #E0E0E0;
    margin-bottom: 4px; line-height: 1.3;
  }
  .ev-agenda-desc { font-size: .8rem; color: #3A3A3A; line-height: 1.55; }

  /* Speakers */
  .ev-speakers { display: flex; flex-direction: column; gap: 14px; }
  .ev-speaker { display: flex; align-items: center; gap: 14px; }
  .ev-speaker-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    background: linear-gradient(135deg, #1A1510, #0D0B08);
    border: 1px solid rgba(201,169,110,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: .65rem; font-weight: 700; letter-spacing: .06em; color: #C9A96E;
    flex-shrink: 0;
  }
  .ev-speaker-name { font-size: .875rem; font-weight: 600; color: #E0E0E0; margin-bottom: 2px; }
  .ev-speaker-role { font-size: .75rem; color: #3A3A3A; }

  /* Garantia */
  .ev-guarantee {
    display: flex; align-items: flex-start; gap: 14px;
    background: #0A0A0A; border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px; padding: 18px;
  }
  .ev-guarantee svg { color: #C9A96E; flex-shrink: 0; margin-top: 2px; }
  .ev-guarantee-title { font-size: .875rem; font-weight: 600; color: #E0E0E0; margin-bottom: 4px; }
  .ev-guarantee-text  { font-size: .8rem; color: #3A3A3A; line-height: 1.55; }

  /* ─── BUY BOX ─── */
  .ev-right {
    padding: 32px 20px 0;
  }
  @media (min-width: 860px) {
    .ev-right { padding: 40px 0 0 0; }
    .ev-buybox { position: sticky; top: 24px; }
  }

  .ev-buybox {
    background: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 28px;
    width: 100%;
  }

  .ev-buybox-label {
    font-size: .55rem; font-weight: 700; letter-spacing: .18em;
    color: #2A2A2A; margin-bottom: 14px;
  }

  /* Ticket cards */
  .ev-ticket-card {
    display: block; cursor: pointer;
    background: #060606; border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px; padding: 14px; margin-bottom: 10px;
    transition: border-color 250ms, background 250ms;
    position: relative; overflow: hidden;
  }
  .ev-ticket-card--vip { border-color: rgba(201,169,110,0.15); }
  .ev-ticket-card--selected { background: #0D0D0D; border-color: rgba(201,169,110,0.35) !important; }

  .ev-ticket-badge-vip {
    position: absolute; top: -1px; right: -1px;
    font-size: .5rem; font-weight: 700; letter-spacing: .12em;
    background: #C9A96E; color: #000;
    padding: 4px 10px; border-radius: 0 10px 0 8px;
  }

  .ev-ticket-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .ev-ticket-radio {
    width: 16px; height: 16px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15); flex-shrink: 0;
    position: relative; transition: border-color 200ms;
  }
  .ev-ticket-radio--on { border-color: #C9A96E; }
  .ev-ticket-radio--on::after {
    content: ''; position: absolute;
    inset: 3px; border-radius: 50%; background: #C9A96E;
  }

  .ev-ticket-name { font-size: .875rem; font-weight: 600; color: #E0E0E0; }
  .ev-ticket-price {
    font-size: 1.25rem; font-weight: 700; color: #A0A0A0;
    margin-bottom: 10px;
  }
  .ev-ticket-price span { font-size: .7rem; font-weight: 400; color: #3A3A3A; }
  .ev-ticket-price--gold { color: #C9A96E; }

  .ev-ticket-perks { padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .ev-ticket-perks li { font-size: .75rem; color: #3A3A3A; }
  .ev-perk--gold { color: #C9A96E; font-weight: 500; }

  /* CTA */
  .ev-cta {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; height: 50px;
    background: #C9A96E; color: #000;
    font-family: 'Inter', sans-serif; font-size: .75rem; font-weight: 700;
    letter-spacing: .14em; text-decoration: none; border-radius: 10px;
    margin-top: 16px; margin-bottom: 10px;
    transition: background 200ms, transform 150ms;
  }
  .ev-cta:hover { background: #E8D5A3; transform: translateY(-1px); }
  .ev-cta:active { transform: translateY(0); }

  .ev-microcopy {
    text-align: center; font-size: .675rem; color: #2A2A2A;
    margin-bottom: 16px;
  }

  /* Trust badges */
  .ev-trust {
    display: flex; flex-direction: column; gap: 7px;
    border-top: 1px solid rgba(255,255,255,0.04);
    padding-top: 14px;
  }
  .ev-trust-item {
    display: flex; align-items: center; gap: 8px;
    font-size: .7rem; color: #2E2E2E;
  }
  .ev-trust-item svg { color: #C9A96E; flex-shrink: 0; }
</style>
