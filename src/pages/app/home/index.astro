---
import AppLayout from '@/layouts/AppLayout.astro';

// ── Helper: centavos → "R$ 1.997" ─────────────────────────────────────────
const brl = (cents: number) =>
  (cents / 100).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });

// ── Helper: Date → { day, month } ─────────────────────────────────────────
const dateParts = (iso: string) => {
  const d = new Date(iso);
  return {
    day:   d.getUTCDate().toString().padStart(2, '0'),
    month: d.toLocaleString('pt-BR', { month: 'short', timeZone: 'UTC' })
           .toUpperCase().replace('.', ''),
  };
};

// ── Cliente SSR autenticado (carrega cookies → passa no RLS) ───────────────
const supabase = Astro.locals.supabase;
const userId   = Astro.locals.user?.id ?? '';

// ── Helpers de cálculo de perfil predominante ────────────────────────────────
type BadgeResult = string | null;

async function calcDiscBadge(): Promise<BadgeResult> {
  if (!userId) return null;
  const { data: lastAssessment } = await supabase
    .from('disc_assessments')
    .select('id')
    .eq('user_id', userId)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  if (!lastAssessment?.id) return null;

  const { data: answers } = await supabase
    .from('disc_answers')
    .select('disc_type')
    .eq('assessment_id', lastAssessment.id);
  if (!answers || answers.length < 30) return null;

  const counts: Record<string, number> = { D: 0, I: 0, S: 0, C: 0 };
  for (const row of answers) {
    const t = String(row.disc_type).toUpperCase();
    if (t in counts) counts[t]++;
  }
  const dominant = (['D','I','S','C'] as const).reduce((a, b) => counts[b] > counts[a] ? b : a);
  const labelMap: Record<string, string> = {
    D: 'Executor (D)', I: 'Comunicador (I)', S: 'Planejador (S)', C: 'Analista (C)',
  };
  return `DISC: ${labelMap[dominant]}`;
}

async function calcEneagramaBadge(): Promise<BadgeResult> {
  if (!userId) return null;
  const { data: lastAssessment } = await supabase
    .from('enneagram_assessments')
    .select('id')
    .eq('user_id', userId)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  if (!lastAssessment?.id) return null;

  const { data: answers } = await supabase
    .from('enneagram_answers')
    .select('enneatype, resposta')
    .eq('assessment_id', lastAssessment.id);
  if (!answers || answers.length < 45) return null;

  const totals: Record<number, number> = {};
  for (let t = 1; t <= 9; t++) totals[t] = 0;
  for (const row of answers) {
    const t = Number(row.enneatype);
    if (t >= 1 && t <= 9) totals[t] += Number(row.resposta ?? 0);
  }
  const dominant = (Object.keys(totals) as unknown as number[])
    .reduce((a, b) => totals[b] > totals[a] ? b : a);
  const nameMap: Record<number, string> = {
    1: 'Perfeccionista', 2: 'Prestativo', 3: 'Bem-Sucedido',
    4: 'Individualista', 5: 'Observador', 6: 'Questionador',
    7: 'Otimista', 8: 'Líder', 9: 'Mediador',
  };
  return `Eneagrama: Tipo ${dominant}`;
}

async function calcEgogramaBadge(): Promise<BadgeResult> {
  if (!userId) return null;
  const { data: lastAssessment } = await supabase
    .from('egogram_assessments')
    .select('id')
    .eq('user_id', userId)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  if (!lastAssessment?.id) return null;

  const { data: answers } = await supabase
    .from('egogram_answers')
    .select('tipo, resposta')
    .eq('assessment_id', lastAssessment.id);
  if (!answers || answers.length < 50) return null;

  const scores: Record<string, number> = { PC: 0, PA: 0, A: 0, CL: 0, CA: 0 };
  for (const row of answers) {
    const t = String(row.tipo).toUpperCase();
    if (t in scores) scores[t] += Number(row.resposta ?? 0);
  }
  const dominant = Object.keys(scores).reduce((a, b) => scores[b] > scores[a] ? b : a);
  const labelMap: Record<string, string> = {
    PC: 'Pai Crítico', PA: 'Pai Nutritivo', A: 'Adulto',
    CL: 'Criança Livre', CA: 'Criança Adaptada',
  };
  return `Egograma: ${labelMap[dominant]}`;
}

const [
  { data: courses },
  { data: books },
  { data: events },
  { data: profile },
  badgeDisc,
  badgeEnea,
  badgeEgo,
  // ── KPI Counters — head:true = zero payload, apenas o inteiro ──────────────
  { count: cursosRaw },
  { count: eventosRaw },
  { count: livrosRaw },
] = await Promise.all([
  // Masterclasses em destaque (máx 6)
  supabase
    .from('products')
    .select('id, title, author, thumbnail_url, price_brl')
    .eq('type', 'masterclass')
    .eq('is_active', true)
    .order('created_at', { ascending: false })
    .limit(6),

  // Livros (ebook + physical_book)
  supabase
    .from('products')
    .select('id, title, author, cover_url, product_format')
    .in('type', ['ebook', 'physical_book'])
    .eq('is_active', true)
    .limit(4),

  // Próximos eventos (data futura)
  supabase
    .from('events')
    .select('id, title, date, venue_name, banner_url')
    .eq('is_active', true)
    .gte('date', new Date().toISOString())
    .order('date', { ascending: true })
    .limit(3),

  // Profile do usuário logado
  userId
    ? supabase.from('profiles').select('full_name').eq('id', userId).single()
    : Promise.resolve({ data: null }),

  // Badges comportamentais (paralelo — zero custo extra se não houver assessments)
  calcDiscBadge(),
  calcEneagramaBadge(),
  calcEgogramaBadge(),

  // ── KPI: Cursos adquiridos (approved) ────────────────────────────────────────
  // Espelha exatamente digitalPurchases em compras/index.astro:
  // purchases JOIN products WHERE type = 'masterclass' AND payment_status = 'approved'
  userId
    ? supabase
        .from('purchases')
        .select('id, products!inner(type)', { count: 'exact', head: true })
        .eq('user_id', userId)
        .eq('payment_status', 'approved')
        .eq('products.type', 'masterclass')
    : Promise.resolve({ count: 0, data: null, error: null, status: 200, statusText: 'OK' }),

  // ── KPI: Ingressos de Eventos ─────────────────────────────────────────────────
  // Espelha exatamente meusIngressos em compras/index.astro:
  // tickets WHERE user_id = userId
  userId
    ? supabase
        .from('tickets')
        .select('id', { count: 'exact', head: true })
        .eq('user_id', userId)
    : Promise.resolve({ count: 0, data: null, error: null, status: 200, statusText: 'OK' }),

  // ── KPI: Livros na Biblioteca ─────────────────────────────────────────────────
  // Espelha exatamente ebookPurchases em compras/index.astro:
  // purchases JOIN products WHERE type IN ('ebook','book') AND payment_status = 'approved'
  userId
    ? supabase
        .from('purchases')
        .select('id, products!inner(type)', { count: 'exact', head: true })
        .eq('user_id', userId)
        .eq('payment_status', 'approved')
        .in('products.type', ['ebook', 'book'])
    : Promise.resolve({ count: 0, data: null, error: null, status: 200, statusText: 'OK' }),
]);

// Fallback para quando o banco ainda não tem dados
const courseList  = courses  ?? [];
const bookList    = books    ?? [];
const eventList   = events   ?? [];
const firstName   = (profile as any)?.full_name?.split(' ')[0] ?? 'Executivo';
const hasBadges   = badgeDisc || badgeEnea || badgeEgo;

// KPI safe fallbacks
const cursosCount  = cursosRaw  ?? 0;
const eventosCount = eventosRaw ?? 0;
const livrosCount  = livrosRaw  ?? 0;
---

<AppLayout title="Home" activeNav="home">
  <div class="home-page">

    <!-- Saudação -->
    <section class="home-greeting">
      <p class="greeting-label">Bem-vindo de volta,</p>
      <h1 class="greeting-name">{firstName} <span class="greeting-badge badge-gold">PRO</span></h1>
    </section>

    <!-- KPIs / Análises -->
    <section class="home-section" id="analises">
      <h2 class="section-title">Análises</h2>
      <div class="kpi-grid">
        <div class="card card-reveal kpi-card">
          <p class="kpi-label">Cursos Adquiridos</p>
          <p class="kpi-value">{cursosCount}</p>
        </div>
        <div class="card card-reveal kpi-card">
          <p class="kpi-label">Eventos</p>
          <p class="kpi-value">{eventosCount}</p>
        </div>
        <div class="card card-reveal kpi-card">
          <p class="kpi-label">Assinatura</p>
          <p class="kpi-value kpi-value--gold">Ativa</p>
        </div>
        <div class="card card-reveal kpi-card">
          <p class="kpi-label">Livros na Biblioteca</p>
          <p class="kpi-value">{livrosCount}</p>
        </div>
      </div>
    </section>

    <!-- Mapeamento Comportamental Banner -->
    <section class="home-section">
      <div class="behavioral-banner">
        <!-- Ícone + Texto -->
        <div class="behavioral-left">
          <div class="behavioral-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <div class="behavioral-text">
            <h2 class="behavioral-title">Mapeamento Comportamental</h2>
            <p class="behavioral-desc">Descubra seus vieses de decisão e seu perfil de liderança sob pressão.</p>

            <!-- ── VIP Status Badges (apenas se concluído) ──────────────── -->
            {hasBadges && (
              <div class="vip-badges">
                {badgeDisc  && <span class="vip-badge">{badgeDisc}</span>}
                {badgeEnea  && <span class="vip-badge">{badgeEnea}</span>}
                {badgeEgo   && <span class="vip-badge">{badgeEgo}</span>}
              </div>
            )}
          </div>
        </div>

        <!-- CTA primário — sempre visível e dominante -->
        <a href="/app/analises" class="behavioral-cta">
          ACESSAR MINHAS ANÁLISES
        </a>
      </div>
    </section>

    <!-- Cursos em Destaque -->
    <section class="home-section" id="cursos">
      <div class="section-header">
        <h2 class="section-title">Cursos em Destaque</h2>
        <a href="/app/detalhes" class="section-link">Ver todos</a>
      </div>
      <div class="courses-scroll">
        {courseList.length > 0 ? courseList.map((course) => (
          <a href={`/app/detalhes?id=${course.id}`} class="card card-reveal course-card" style="text-decoration:none;display:block;">
            <div class="course-thumb">
              <img
                src={course.thumbnail_url ?? '/protocolo-clevel-thumb.png'}
                alt={course.title}
                class="course-thumb__img"
                loading="lazy"
              />
            </div>
            <div class="course-info">
              <p class="course-instructor">{course.author ?? 'Mario Quirino'}</p>
              <h3 class="course-title">{course.title}</h3>
              <div class="course-footer">
                <span class="badge-gold">Exclusivo</span>
                <span class="btn-primary course-cta">
                  {course.price_brl ? brl(course.price_brl) : 'Adquirir'}
                </span>
              </div>
            </div>
          </a>
        )) : (
          <p style="color:#4A4A4A;font-size:0.875rem;padding:8px 0">Nenhum curso disponível no momento.</p>
        )}
      </div>
    </section>

    <!-- Livros -->
    <section class="home-section" id="livros">
      <div class="section-header">
        <h2 class="section-title">Livros</h2>
        <a href="/app/detalhes-livro" class="section-link">Ver biblioteca</a>
      </div>
      <div class="books-grid">
        {bookList.length > 0 ? bookList.map((book) => (
          <a href={`/app/detalhes-livro?id=${book.id}`} class="card card-reveal book-card" style="text-decoration:none;display:flex;flex-direction:column;">
            <div class="book-cover">
              <img
                src={book.cover_url ?? '/codigo-executivo-cover.png'}
                alt={book.title}
                class="book-cover__img"
                loading="lazy"
              />
            </div>
            <p class="book-author">{book.author ?? 'Mario Quirino'}</p>
            <h3 class="book-title">{book.title}</h3>
            <span class="badge-gold" style="margin:0 12px 12px;">
              {book.product_format === 'physical' ? 'Físico + Digital' : 'Digital'}
            </span>
          </a>
        )) : (
          <p style="color:#4A4A4A;font-size:0.875rem;padding:8px 0">Nenhum livro disponível.</p>
        )}
      </div>
    </section>

    <!-- Próximos Eventos -->
    <section class="home-section" id="eventos">
      <div class="section-header">
        <h2 class="section-title">Próximos Eventos</h2>
        <a href="/app/detalhes-evento" class="section-link">Ver todos</a>
      </div>
      <div class="events-list">
        {eventList.length > 0 ? eventList.map((ev) => {
          const { day, month } = dateParts(ev.date);
          return (
            <a href={`/app/detalhes-evento?id=${ev.id}`} class="card card-reveal event-card" style="text-decoration:none;overflow:hidden;">
              <div class="event-img-col">
                <img
                  src={ev.banner_url ?? '/summit-mq-banner.png'}
                  alt={ev.title}
                  class="event-img"
                  loading="lazy"
                />
              </div>
              <div class="event-date">
                <p class="event-day">{day}</p>
                <p class="event-month">{month}</p>
              </div>
              <div class="event-info">
                <p class="event-location">{ev.venue_name ?? '—'}</p>
                <h3 class="event-name">{ev.title}</h3>
              </div>
              <span class="btn-primary event-cta">Garantir</span>
            </a>
          );
        }) : (
          <p style="color:#4A4A4A;font-size:0.875rem;padding:8px 0">Nenhum evento próximo agendado.</p>
        )}
      </div>
    </section>

  </div>
</AppLayout>

<style>
  .home-page {
    padding: 24px 16px 32px;
    max-width: 960px;
    margin: 0 auto;
  }

  .home-greeting {
    margin-bottom: 32px;
  }

  .greeting-label {
    font-size: 0.875rem;
    color: #A0A0A0;
    margin-bottom: 4px;
  }

  .greeting-name {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #F5F5F5;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* === Seções === */
  .home-section { margin-bottom: 40px; }
  .section-title {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4A4A4A;
    margin-bottom: 16px;
  }
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .section-header .section-title { margin-bottom: 0; }
  .section-link { font-size: 0.75rem; color: #C9A96E; transition: color 200ms ease; }
  .section-link:hover { color: #E8D5A3; }

  /* === KPI Grid === */
  .kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (min-width: 640px) { .kpi-grid { grid-template-columns: repeat(4, 1fr); } }

  .kpi-card { padding: 20px 16px; }
  .kpi-label { font-size: 0.75rem; color: #4A4A4A; margin-bottom: 8px; }
  .kpi-value { font-size: 2rem; font-weight: 600; color: #F5F5F5; line-height: 1; }
  .kpi-value--gold { color: #C9A96E; }

  /* === Courses Scroll === */
  .courses-scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: none;
  }
  .courses-scroll::-webkit-scrollbar { display: none; }

  .course-card { min-width: 240px; padding: 0; overflow: hidden; }
  .course-thumb {
    height: 140px;
    position: relative;
    overflow: hidden;
    background: #0A0A0A;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .course-thumb__img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 400ms ease;
    filter: brightness(0.75);
  }
  .course-card:hover .course-thumb__img { transform: scale(1.04); }
  .course-info { padding: 16px; }
  .course-instructor { font-size: 0.75rem; color: #C9A96E; margin-bottom: 4px; }
  .course-title {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: #F5F5F5;
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .course-footer { display: flex; align-items: center; justify-content: space-between; }
  .course-cta { padding: 8px 14px; font-size: 0.8125rem; }

  /* === Books Grid === */
  .books-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  @media (min-width: 640px) { .books-grid { grid-template-columns: repeat(4, 1fr); } }

  .book-card { display: flex; flex-direction: column; gap: 8px; align-items: flex-start; padding: 0; overflow: hidden; }
  .book-cover {
    width: 100%;
    aspect-ratio: 2/3;
    overflow: hidden;
    position: relative;
    background: #0A0A0A;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .book-cover__img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 400ms ease;
    filter: brightness(0.85);
  }
  .book-card:hover .book-cover__img { transform: scale(1.03); }
  .book-author { font-size: 0.6875rem; color: #4A4A4A; padding: 0 12px; }
  .book-title { font-family: 'Playfair Display', serif; font-size: 0.9375rem; color: #F5F5F5; line-height: 1.2; padding: 0 12px; }
  .book-card .badge-gold { margin: 0 12px 12px; }

  /* === Events List === */
  .events-list { display: flex; flex-direction: column; gap: 12px; }

  .event-card { display: flex; align-items: center; gap: 16px; position: relative; overflow: hidden; }
  .event-img-col {
    position: absolute; inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .event-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.18) saturate(0.4);
    transition: filter 400ms ease;
  }
  .event-card:hover .event-img { filter: brightness(0.25) saturate(0.5); }
  .event-card > *:not(.event-img-col) { position: relative; z-index: 1; }
  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 48px;
  }
  .event-day { font-size: 1.5rem; font-weight: 700; color: #C9A96E; line-height: 1; }
  .event-month { font-size: 0.6875rem; color: #6A6A6A; font-weight: 600; letter-spacing: 0.08em; }
  .event-info { flex: 1; }
  .event-location { font-size: 0.75rem; color: #5A5A5A; margin-bottom: 2px; }
  .event-name { font-family: 'Playfair Display', serif; font-size: 1rem; color: #F5F5F5; line-height: 1.3; margin-bottom: 4px; }
  .event-price { font-size: 0.8125rem; color: #A0A0A0; }
  .event-cta { padding: 8px 16px; font-size: 0.8125rem; white-space: nowrap; }

  /* ── Behavioral Banner ────────────────────────────────────────────────────── */
  .behavioral-banner {
    width: 100%;
    background: linear-gradient(135deg, #0E0E0E 0%, #080808 100%);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  @media (min-width: 768px) {
    .behavioral-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 28px 32px;
    }
  }

  .behavioral-left {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    flex: 1;
    min-width: 0;
  }

  .behavioral-icon {
    color: #C9A96E;
    flex-shrink: 0;
    margin-top: 2px;
    opacity: 0.85;
  }

  .behavioral-text { flex: 1; min-width: 0; }

  .behavioral-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.3125rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 6px;
    line-height: 1.2;
  }
  @media (min-width: 768px) {
    .behavioral-title { font-size: 1.5rem; }
  }

  .behavioral-desc {
    font-size: 0.875rem;
    color: #4A4A4A;
    line-height: 1.5;
  }

  /* ── VIP Status Badges — Stealth Wealth ──────────────────────────────────── */
  .vip-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
    animation: vip-reveal 400ms cubic-bezier(0.4, 0, 0.2, 1) both;
    animation-delay: 120ms;
  }

  @keyframes vip-reveal {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .vip-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    font-family: 'Inter', sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(160, 160, 160, 0.7);
    transition: border-color 250ms ease, color 250ms ease, background 250ms ease;
    white-space: nowrap;
    cursor: default;
  }

  .vip-badge:hover {
    background: rgba(201,169,110,0.05);
    border-color: rgba(201,169,110,0.18);
    color: rgba(201,169,110,0.8);
  }

  /* ── CTA Primário ─────────────────────────────────────────────────────────── */
  .behavioral-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    background: #C9A96E;
    color: #000;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-decoration: none;
    border-radius: 10px;
    white-space: nowrap;
    flex-shrink: 0;
