---
import AppLayout from '@/layouts/AppLayout.astro';

const steps = [
  {
    id: 1,
    label: 'Pedido Confirmado',
    desc: 'Pagamento processado com sucesso',
    date: '25 ABR · 14h32',
    state: 'done',
  },
  {
    id: 2,
    label: 'Preparando para Envio',
    desc: 'Seu exemplar está sendo separado e embalado com cuidado',
    date: '26 ABR · Prev. manhã',
    state: 'active',
  },
  {
    id: 3,
    label: 'Aguardando Coleta',
    desc: 'A transportadora realizará a coleta na editora',
    date: '',
    state: 'future',
  },
  {
    id: 4,
    label: 'Em Trânsito',
    desc: 'A caminho do centro de distribuição',
    date: '',
    state: 'future',
  },
  {
    id: 5,
    label: 'Em Rota de Entrega',
    desc: 'Saiu para entrega no seu endereço',
    date: '',
    state: 'future',
  },
  {
    id: 6,
    label: 'Entregue no Destino',
    desc: 'Seu exemplar chegou',
    date: '',
    state: 'future',
  },
];
---

<AppLayout title="Rastreio do Livro · MQ ACCESS">
  <div class="tr-shell">

    <!-- Header -->
    <div class="tr-header">
      <a href="/app/compras" class="tr-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Minha Biblioteca
      </a>

      <p class="tr-eyebrow">ACOMPANHAMENTO</p>
      <h1 class="tr-title">Cofre <span class="tr-title--gold">#0042</span></h1>
      <p class="tr-subtitle">A Engenharia do Networking — Capa Dura · 1ª Edição</p>

      <!-- Barra de progresso macro -->
      <div class="tr-macro-bar">
        <div class="tr-macro-fill"></div>
      </div>
      <p class="tr-macro-label">2 de 6 etapas concluídas</p>
    </div>

    <!-- Timeline -->
    <div class="tr-timeline" id="tr-timeline">
      {steps.map((step, i) => (
        <div class={`tr-step tr-step--${step.state}`} data-index={i}>
          <!-- Linha vertical -->
          {i < steps.length - 1 && (
            <div class={`tr-line ${step.state === 'done' ? 'tr-line--done' : ''}`}></div>
          )}
          <!-- Nó -->
          <div class="tr-node">
            {step.state === 'done' && (
              <div class="tr-node-done">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
            )}
            {step.state === 'active' && (
              <div class="tr-node-active">
                <div class="tr-node-pulse"></div>
                <div class="tr-node-pulse tr-node-pulse--2"></div>
                <div class="tr-node-core"></div>
              </div>
            )}
            {step.state === 'future' && (
              <div class="tr-node-future">
                <span class="tr-node-num">{step.id.toString().padStart(2,'0')}</span>
              </div>
            )}
          </div>
          <!-- Conteúdo -->
          <div class="tr-content">
            <div class="tr-content-head">
              <p class="tr-step-label">{step.label}</p>
              {step.date && <span class="tr-step-date">{step.date}</span>}
            </div>
            <p class="tr-step-desc">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Nota de entrega -->
    <div class="tr-note">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Previsão de entrega: <strong>28 Abr – 02 Mai</strong>. Rastreio expresso com atualizações em tempo real.
    </div>

    <!-- Código de rastreio -->
    <div class="tr-code-block">
      <p class="tr-code-label">CÓDIGO DE RASTREIO</p>
      <p class="tr-code">BR8849201047BR</p>
      <button class="tr-copy" onclick="navigator.clipboard.writeText('BR8849201047BR')">Copiar</button>
    </div>

  </div>
</AppLayout>

<script>
  import { gsap } from 'gsap';
  document.addEventListener('astro:page-load', () => {
    // Header
    gsap.from('.tr-header', { y: -20, opacity: 0, duration: 0.5, ease: 'power2.out' });

    // Timeline cascade
    const steps = document.querySelectorAll('.tr-step');
    gsap.from(steps, {
      x: -24,
      opacity: 0,
      duration: 0.45,
      stagger: 0.1,
      ease: 'power2.out',
      delay: 0.2,
    });

    // Nota e código
    gsap.from(['.tr-note', '.tr-code-block'], {
      y: 16, opacity: 0, duration: 0.4,
      stagger: 0.1, delay: 0.85, ease: 'power2.out'
    });
  });
</script>

<style>
  .tr-shell {
    min-height: 100dvh;
    background: #000;
    font-family: 'Inter', sans-serif;
    padding: 20px 20px 80px;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Header */
  .tr-back {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .75rem; color: #3A3A3A; text-decoration: none;
    transition: color 200ms; margin-bottom: 28px; display: flex;
  }
  .tr-back:hover { color: #E0E0E0; }

  .tr-eyebrow {
    font-size: .575rem; font-weight: 700; letter-spacing: .18em;
    color: #C9A96E; margin-bottom: 8px;
  }
  .tr-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; font-weight: 700; color: #F5F5F5;
    margin-bottom: 6px;
  }
  .tr-title--gold { color: #C9A96E; }
  .tr-subtitle { font-size: .8125rem; color: #3A3A3A; margin-bottom: 24px; }

  /* Macro progress */
  .tr-macro-bar {
    height: 2px; background: rgba(255,255,255,0.06);
    border-radius: 2px; margin-bottom: 8px; overflow: hidden;
  }
  .tr-macro-fill {
    height: 100%; width: 28%; /* 2/6 steps done + partial */
    background: linear-gradient(90deg, #C9A96E, #E8D5A3);
    border-radius: 2px;
  }
  .tr-macro-label { font-size: .7rem; color: #2E2E2E; margin-bottom: 40px; }

  /* Timeline */
  .tr-timeline { display: flex; flex-direction: column; gap: 0; }

  .tr-step {
    display: flex; align-items: flex-start; gap: 16px;
    position: relative; padding-bottom: 36px;
  }
  .tr-step:last-child { padding-bottom: 0; }

  /* Linha vertical */
  .tr-line {
    position: absolute; left: 15px; top: 32px;
    width: 1px; bottom: 0;
    background: rgba(255,255,255,0.07);
    z-index: 0;
  }
  .tr-line--done { background: rgba(201,169,110,0.2); }

  /* Nó */
  .tr-node {
    width: 32px; height: 32px;
    flex-shrink: 0; position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center;
  }

  /* Done */
  .tr-node-done {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(201,169,110,0.12);
    border: 1px solid rgba(201,169,110,0.4);
    display: flex; align-items: center; justify-content: center;
    color: #C9A96E;
  }

  /* Active */
  .tr-node-active {
    width: 32px; height: 32px;
    position: relative; display: flex; align-items: center; justify-content: center;
  }
  .tr-node-pulse {
    position: absolute; inset: 0; border-radius: 50%;
    border: 1px solid rgba(201,169,110,0.35);
    animation: pulse-ring 2s ease-out infinite;
  }
  .tr-node-pulse--2 { animation-delay: 0.75s; }
  .tr-node-core {
    width: 12px; height: 12px; border-radius: 50%;
    background: #C9A96E;
    box-shadow: 0 0 8px rgba(201,169,110,0.5);
  }
  @keyframes pulse-ring {
    0%   { transform: scale(0.85); opacity: 0.7; }
    70%  { transform: scale(1.35); opacity: 0; }
    100% { transform: scale(1.35); opacity: 0; }
  }

  /* Future */
  .tr-node-future {
    width: 32px; height: 32px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: center; justify-content: center;
  }
  .tr-node-num { font-size: .55rem; font-weight: 700; color: #2A2A2A; }

  /* Content */
  .tr-content { flex: 1; padding-top: 4px; }
  .tr-content-head {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: 8px;
    margin-bottom: 4px;
  }
  .tr-step-label {
    font-size: .9375rem; font-weight: 600;
    color: #F5F5F5; line-height: 1.3;
  }
  .tr-step--future .tr-step-label { color: #2A2A2A; }
  .tr-step--active .tr-step-label { color: #F5F5F5; }

  .tr-step-date {
    font-size: .65rem; color: #C9A96E;
    white-space: nowrap; flex-shrink: 0;
  }
  .tr-step-desc {
    font-size: .8rem; color: #3A3A3A; line-height: 1.55;
  }
  .tr-step--active .tr-step-desc { color: #5A5A5A; }

  /* Nota */
  .tr-note {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: .8rem; color: #3A3A3A; line-height: 1.6;
    background: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px; padding: 14px 16px;
    margin-top: 36px;
  }
  .tr-note svg { color: #C9A96E; flex-shrink: 0; margin-top: 2px; }
  .tr-note strong { color: #E0E0E0; font-weight: 600; }

  /* Código rastreio */
  .tr-code-block {
    margin-top: 14px; background: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px; padding: 14px 16px;
    display: flex; align-items: center; gap: 12px;
  }
  .tr-code-label {
    font-size: .5rem; font-weight: 700; letter-spacing: .12em;
    color: #2E2E2E; flex-shrink: 0;
  }
  .tr-code {
    flex: 1; font-family: monospace; font-size: .8125rem;
    color: #A0A0A0; letter-spacing: .05em;
  }
  .tr-copy {
    background: transparent; border: 1px solid rgba(255,255,255,0.07);
    color: #3A3A3A; font-family: 'Inter', sans-serif;
    font-size: .65rem; font-weight: 600; letter-spacing: .08em;
    padding: 5px 12px; border-radius: 6px; cursor: pointer;
    transition: border-color 200ms, color 200ms;
  }
  .tr-copy:hover { border-color: rgba(201,169,110,0.2); color: #C9A96E; }
</style>
