---
import AppLayout from '@/layouts/AppLayout.astro';
---

<AppLayout title="Ingresso VIP · Summit MQ">
  <div class="ig-shell">

    <!-- Voltar -->
    <div class="ig-nav">
      <a href="/app/compras" class="ig-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Minha Biblioteca
      </a>
    </div>

    <!-- Ticket central -->
    <div class="ig-ticket" id="ig-ticket">

      <!-- Cabeçalho do ticket -->
      <div class="ig-ticket-head">
        <div class="ig-logo-group">
          <img src="/images/logohorizontal.png" alt="MQ Access" class="h-4 w-auto object-contain" />
        </div>
        <span class="ig-vip-badge">INGRESSO VIP</span>
      </div>

      <!-- Divisor tracejado -->
      <div class="ig-divider-dash"></div>

      <!-- Info do evento -->
      <div class="ig-event-info">
        <h1 class="ig-event-title">Summit MQ · São Paulo</h1>
        <div class="ig-event-meta">
          <div class="ig-meta-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>15 DE AGOSTO DE 2026</span>
          </div>
          <div class="ig-meta-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Grand Hyatt Hotel · São Paulo</span>
          </div>
          <div class="ig-meta-item">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Credenciamento a partir das 08h00</span>
          </div>
        </div>
      </div>

      <!-- Divisor com cortes laterais (estilo ticket físico) -->
      <div class="ig-perforation">
        <div class="ig-perf-cut ig-perf-cut--l"></div>
        <div class="ig-perf-line"></div>
        <div class="ig-perf-cut ig-perf-cut--r"></div>
      </div>

      <!-- QR Code -->
      <div class="ig-qr-section" id="ig-qr">
        <div class="ig-qr-glow"></div>
        <div class="ig-qr-wrap">
          <!-- QR simulado com SVG pattern -->
          <svg class="ig-qr-svg" width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Corner TL -->
            <rect x="10" y="10" width="48" height="48" rx="4" stroke="#C9A96E" stroke-width="3" fill="none"/>
            <rect x="20" y="20" width="28" height="28" rx="2" fill="#C9A96E" opacity="0.9"/>
            <!-- Corner TR -->
            <rect x="122" y="10" width="48" height="48" rx="4" stroke="#C9A96E" stroke-width="3" fill="none"/>
            <rect x="132" y="20" width="28" height="28" rx="2" fill="#C9A96E" opacity="0.9"/>
            <!-- Corner BL -->
            <rect x="10" y="122" width="48" height="48" rx="4" stroke="#C9A96E" stroke-width="3" fill="none"/>
            <rect x="20" y="132" width="28" height="28" rx="2" fill="#C9A96E" opacity="0.9"/>
            <!-- Data dots pattern -->
            <rect x="74" y="10" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="86" y="10" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="98" y="10" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="110" y="10" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="74" y="22" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="86" y="22" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="98" y="22" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.2"/>
            <rect x="110" y="22" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="74" y="34" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="86" y="34" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="98" y="34" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="110" y="34" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <!-- Mid rows -->
            <rect x="10" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <rect x="22" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="34" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="46" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="58" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="70" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="82" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.2"/>
            <rect x="94" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="106" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="118" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="130" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="142" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="154" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="162" y="74" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <!-- Row 2 -->
            <rect x="10" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="22" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="34" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="46" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.2"/>
            <rect x="70" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="82" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="106" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="130" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="142" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="154" y="86" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <!-- Row 3 -->
            <rect x="10" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="34" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="58" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="82" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="94" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="118" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <rect x="130" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="154" y="98" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <!-- Row 4 -->
            <rect x="10" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <rect x="22" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="46" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="70" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="82" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="106" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="118" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="142" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="162" y="110" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <!-- Bottom rows -->
            <rect x="74" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="86" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="98" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="110" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="122" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="134" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <rect x="146" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="158" y="122" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="74" y="134" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="86" y="134" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="98" y="134" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <rect x="110" y="134" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="122" y="134" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.2"/>
            <rect x="146" y="134" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="74" y="146" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="98" y="146" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
            <rect x="110" y="146" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="134" y="146" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="158" y="146" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.6"/>
            <rect x="74" y="158" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.5"/>
            <rect x="86" y="158" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.8"/>
            <rect x="110" y="158" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.3"/>
            <rect x="122" y="158" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.7"/>
            <rect x="146" y="158" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.9"/>
            <rect x="162" y="158" width="8" height="8" rx="1" fill="#C9A96E" opacity="0.4"/>
          </svg>
        </div>
        <p class="ig-qr-hint">Apresente este código na portaria para validação prioritária.</p>
        <p class="ig-qr-code">#MQ-2026-0041</p>
      </div>

      <!-- Rodapé do ticket -->
      <div class="ig-ticket-foot">
        <div class="ig-foot-item">
          <span class="ig-foot-label">TITULAR</span>
          <span class="ig-foot-value">Mario Quirino</span>
        </div>
        <div class="ig-foot-item">
          <span class="ig-foot-label">CATEGORIA</span>
          <span class="ig-foot-value">VIP · Mesa Premium</span>
        </div>
        <div class="ig-foot-item">
          <span class="ig-foot-label">ACESSO</span>
          <span class="ig-foot-value ig-foot-value--gold">Irrestrito</span>
        </div>
      </div>

    </div>

    <!-- Ação de compartilhar -->
    <div class="ig-actions">
      <button class="ig-btn-secondary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Salvar Ingresso
      </button>
      <button class="ig-btn-secondary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Compartilhar
      </button>
    </div>

  </div>
</AppLayout>

<script>
  import { gsap } from 'gsap';
  document.addEventListener('astro:page-load', () => {
    gsap.from('#ig-ticket', {
      y: 30, opacity: 0, duration: 0.7, ease: 'power3.out'
    });
    gsap.from('#ig-qr', {
      scale: 0.9, opacity: 0, duration: 0.6, delay: 0.25, ease: 'back.out(1.5)'
    });
  });
</script>

<style>
  .ig-shell {
    min-height: 100dvh;
    background: #000;
    font-family: 'Inter', sans-serif;
    display: flex; flex-direction: column; align-items: center;
    padding: 16px 16px 60px;
  }

  .ig-nav { width: 100%; max-width: 440px; margin-bottom: 24px; }
  .ig-back {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .75rem; color: #3A3A3A; text-decoration: none;
    transition: color 200ms;
  }
  .ig-back:hover { color: #E0E0E0; }

  /* Ticket */
  .ig-ticket {
    width: 100%; max-width: 400px;
    background: #0A0A0A;
    border: 1px solid rgba(201,169,110,0.25);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  .ig-ticket-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .ig-logo-group { display: flex; align-items: baseline; gap: 2px; }
  .ig-logo-mq { font-size: .65rem; font-weight: 700; letter-spacing: .1em; color: #F5F5F5; }
  .ig-logo-a  { font-family: 'Playfair Display', serif; font-size: .55rem; color: #C9A96E; }
  .ig-vip-badge {
    font-size: .55rem; font-weight: 700; letter-spacing: .16em;
    color: #C9A96E; border: 1px solid rgba(201,169,110,0.25);
    padding: 3px 10px; border-radius: 20px;
  }

  /* Divisor tracejado */
  .ig-divider-dash {
    height: 1px;
    background-image: repeating-linear-gradient(
      90deg, rgba(201,169,110,0.2) 0px, rgba(201,169,110,0.2) 6px, transparent 6px, transparent 12px
    );
  }

  /* Info evento */
  .ig-event-info { padding: 20px 24px 16px; }
  .ig-event-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; font-weight: 700;
    color: #F5F5F5; margin-bottom: 14px;
  }
  .ig-event-meta { display: flex; flex-direction: column; gap: 8px; }
  .ig-meta-item {
    display: flex; align-items: center; gap: 8px;
    font-size: .75rem; color: #5A5A5A;
  }
  .ig-meta-item svg { color: #C9A96E; flex-shrink: 0; }

  /* Perfuração estilo ticket físico */
  .ig-perforation {
    display: flex; align-items: center;
    margin: 4px 0;
  }
  .ig-perf-cut {
    width: 20px; height: 20px;
    background: #000;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .ig-perf-cut--l { margin-left: -10px; }
  .ig-perf-cut--r { margin-right: -10px; }
  .ig-perf-line {
    flex: 1;
    height: 1px;
    background-image: repeating-linear-gradient(
      90deg, rgba(255,255,255,0.06) 0px, rgba(255,255,255,0.06) 6px, transparent 6px, transparent 12px
    );
  }

  /* QR */
  .ig-qr-section {
    display: flex; flex-direction: column; align-items: center;
    padding: 24px 24px 20px;
    position: relative;
  }
  .ig-qr-glow {
    position: absolute;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(201,169,110,0.12), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .ig-qr-wrap {
    position: relative; z-index: 1;
    background: #050505;
    border: 1px solid rgba(201,169,110,0.15);
    border-radius: 12px; padding: 12px;
    margin-bottom: 16px;
  }
  .ig-qr-svg { display: block; }
  .ig-qr-hint {
    font-size: .7rem; color: #3A3A3A;
    text-align: center; max-width: 260px;
    line-height: 1.6; margin-bottom: 8px;
  }
  .ig-qr-code {
    font-family: monospace; font-size: .7rem;
    color: #C9A96E; letter-spacing: .08em;
  }

  /* Rodapé */
  .ig-ticket-foot {
    display: flex;
    border-top: 1px solid rgba(255,255,255,0.04);
    padding: 16px 24px;
    gap: 8px;
  }
  .ig-foot-item {
    flex: 1; display: flex; flex-direction: column; gap: 4px;
  }
  .ig-foot-item + .ig-foot-item { border-left: 1px solid rgba(255,255,255,0.04); padding-left: 12px; }
  .ig-foot-label { font-size: .5rem; font-weight: 700; letter-spacing: .1em; color: #2E2E2E; }
  .ig-foot-value { font-size: .75rem; font-weight: 500; color: #A0A0A0; }
  .ig-foot-value--gold { color: #C9A96E; }

  /* Ações */
  .ig-actions {
    display: flex; gap: 12px; margin-top: 20px;
    width: 100%; max-width: 400px;
  }
  .ig-btn-secondary {
    flex: 1; height: 40px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    background: transparent; border: 1px solid rgba(255,255,255,0.07);
    color: #4A4A4A; font-family: 'Inter', sans-serif;
    font-size: .75rem; font-weight: 500; letter-spacing: .06em;
    border-radius: 8px; cursor: pointer;
    transition: border-color 200ms, color 200ms;
  }
  .ig-btn-secondary:hover { border-color: rgba(201,169,110,0.2); color: #C9A96E; }
</style>
