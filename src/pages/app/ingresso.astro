---
import AppLayout from '@/layouts/AppLayout.astro';

// ── CORREÇÃO CRÍTICA: usar cliente SSR autenticado (passa cookies → respeita RLS) ──
// ❌ ANTES: import { supabase } from '@/lib/supabase'; // cliente anônimo → RLS bloqueia
// ✅ AGORA: Astro.locals.supabase → cliente com sessão do usuário logado
const supabase = Astro.locals.supabase;
const user     = Astro.locals.user;

// ── 1. Validação do ID ─────────────────────────────────────────────────────
const ticketId = Astro.url.searchParams.get('id');

console.log('🎟 [INGRESSO SSR] ticketId recebido:', ticketId);
console.log('🎟 [INGRESSO SSR] userId da sessão:', user?.id ?? '⚠ VAZIO — sessão não autenticada!');

if (!ticketId) {
  console.error('🚨 [FATAL SSR] ticketId ausente na URL — redirect para compras');
  return Astro.redirect('/app/compras');
}

// ── 2. Ticket + Eventos + Categoria ────────────────────────────────────────
const { data: ticket, error: ticketError } = await supabase
  .from('tickets')
  .select('*, events(*), event_ticket_tiers(*)')
  .eq('id', ticketId)
  .single();

console.log('🎟 [INGRESSO SSR] ticketError:', ticketError?.code, ticketError?.message ?? 'null');
console.log('🎟 [INGRESSO SSR] ticket encontrado:', ticket ? '✅ SIM' : '❌ NÃO');

if (ticketError || !ticket) {
  console.error('🚨 [FATAL SSR] Ingresso não encontrado ou bloqueado por RLS.');
  console.error('   Ticket ID  :', ticketId);
  console.error('   User ID    :', user?.id ?? 'sem sessão');
  console.error('   Erro código:', ticketError?.code);
  console.error('   Erro msg   :', ticketError?.message);
  console.error('   Erro hint  :', ticketError?.hint);
  // ⚠ REDIRECT TEMPORARIAMENTE DESABILITADO para exposição do erro
  // Reabilite após confirmar que o RLS está correto:
  // return Astro.redirect('/app/compras');
}

// ── 3. Perfil do titular (query separada via user_id) ──────────────────────
const { data: profile } = await supabase
  .from('profiles')
  .select('full_name')
  .eq('id', (ticket as any).user_id)
  .single();

// ── Helpers ────────────────────────────────────────────────────────────────
const ev    = ticket.events             as any;
const tier  = ticket.event_ticket_tiers as any;

const formatDate = (dateString: string | null) => {
  if (!dateString) return '';
  const d = new Date(dateString);
  return d.toLocaleDateString('pt-BR', {
    day: '2-digit', month: 'long', year: 'numeric'
  }).toUpperCase();
};

const titular    = profile?.full_name                      ?? 'Titular do Ingresso';
const eventTitle = ev?.title                               ?? 'Evento';
const eventDate  = formatDate(ev?.date                     ?? null);
const eventVenue = ev?.venue_name ?? ev?.city              ?? 'Local a definir';
const tierName   = tier?.name                              ?? 'VIP';
const ticketCode = (ticket as any).ticket_code             ?? ticketId.slice(0, 8).toUpperCase();
const qrPayload  = (ticket as any).qr_payload              ?? `MQ-${ticketCode}`;
---

<AppLayout title={`Ingresso · ${eventTitle}`}>
  <div class="ig-shell">

    <!-- Voltar -->
    <div class="ig-nav">
      <a href="/app/compras" class="ig-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Minhas Compras
      </a>
    </div>

    <!-- ══ ÁREA DE CAPTURA (html2canvas) ══════════════════════════════════ -->
    <div id="ticket-capture-area" class="ig-capture-area">

      <!-- Ticket central -->
      <div class="ig-ticket" id="ig-ticket">

        <!-- Cabeçalho -->
        <div class="ig-ticket-head">
          <div class="ig-logo-group">
            <img src="/images/logohorizontal.png" alt="MQ Access" class="h-4 w-auto object-contain" />
          </div>
          <span class="ig-vip-badge">{tierName.toUpperCase()}</span>
        </div>

        <!-- Divisor tracejado -->
        <div class="ig-divider-dash"></div>

        <!-- Info do evento -->
        <div class="ig-event-info">
          <h1 class="ig-event-title">{eventTitle}</h1>
          <div class="ig-event-meta">
            {eventDate && (
              <div class="ig-meta-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>{eventDate}</span>
              </div>
            )}
            <div class="ig-meta-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{eventVenue}</span>
            </div>
          </div>
        </div>

        <!-- Perfuração estilo ticket físico -->
        <div class="ig-perforation">
          <div class="ig-perf-cut ig-perf-cut--l"></div>
          <div class="ig-perf-line"></div>
          <div class="ig-perf-cut ig-perf-cut--r"></div>
        </div>

        <!-- QR Code — container real (qrcodejs injeta aqui) -->
        <div class="ig-qr-section" id="ig-qr">
          <div class="ig-qr-glow"></div>
          <div class="ig-qr-wrap">
            <div
              id="qrcode-container"
              style="width:200px;height:200px;background:#fff;display:flex;align-items:center;justify-content:center;line-height:0;"
            ></div>
          </div>
          <p class="ig-qr-hint">Apresente este código na portaria para validação prioritária.</p>
          <p class="ig-qr-code">#{ticketCode}</p>
        </div>

        <!-- Rodapé -->
        <div class="ig-ticket-foot">
          <div class="ig-foot-item">
            <span class="ig-foot-label">TITULAR</span>
            <span class="ig-foot-value">{titular}</span>
          </div>
          <div class="ig-foot-item">
            <span class="ig-foot-label">CATEGORIA</span>
            <span class="ig-foot-value">{tierName}</span>
          </div>
          <div class="ig-foot-item">
            <span class="ig-foot-label">ACESSO</span>
            <span class="ig-foot-value ig-foot-value--gold">Confirmado</span>
          </div>
        </div>

      </div><!-- /ig-ticket -->
    </div><!-- /ticket-capture-area -->

    <!-- Botões de ação -->
    <div class="ig-actions">
      <button id="btn-save" class="ig-btn-secondary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Salvar Ingresso
      </button>
      <button id="btn-share" class="ig-btn-secondary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Compartilhar
      </button>
    </div>

  </div>
</AppLayout>

<!-- ── GSAP: animação de entrada ──────────────────────────────────────────── -->
<script>
  import { gsap } from 'gsap';
  document.addEventListener('astro:page-load', () => {
    gsap.from('#ig-ticket', { y: 30, opacity: 0, duration: 0.7, ease: 'power3.out' });
    gsap.from('#ig-qr',     { scale: 0.9, opacity: 0, duration: 0.6, delay: 0.25, ease: 'back.out(1.5)' });
  });
</script>

<!-- ── CDN: QR Code + html2canvas ────────────────────────────────────────── -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" is:inline></script>

<!-- ── Motor interativo (define:vars injeta SSR → client) ────────────────── -->
<script is:inline define:vars={{ qrPayload, ticketCode, eventTitle }}>
  // CORREÇÃO: função nomeada no escopo global do script (não IIFE) para
  // poder ser referenciada pelo listener astro:page-load sem ReferenceError
  function initTicket() {
    // 1. GERAR QR CODE REAL ──────────────────────────────────────────────────
    var container = document.getElementById('qrcode-container');
    if (container && qrPayload && typeof QRCode !== 'undefined') {
      container.innerHTML = ''; // limpa render anterior (SPA / hot-reload)
      new QRCode(container, {
        text:         qrPayload,
        width:        200,
        height:       200,
        colorDark:    '#000000',
        colorLight:   '#ffffff',
        correctLevel: QRCode.CorrectLevel.H,
      });
    }

    // 2. COMPARTILHAR ────────────────────────────────────────────────────────
    var btnShare = document.getElementById('btn-share');
    if (btnShare) {
      // Remove listener anterior antes de adicionar novo (evita duplicatas no VT)
      var newBtnShare = btnShare.cloneNode(true);
      btnShare.parentNode.replaceChild(newBtnShare, btnShare);
      newBtnShare.addEventListener('click', async function() {
        if (navigator.share) {
          try {
            await navigator.share({
              title: 'Ingresso: ' + eventTitle,
              text:  'Aqui está meu ingresso para o evento!',
              url:   window.location.href,
            });
          } catch (err) {
            // Cancelado pelo usuário — silencioso
          }
        } else {
          navigator.clipboard.writeText(window.location.href);
          var orig = newBtnShare.innerHTML;
          newBtnShare.innerHTML = '✓ Link copiado!';
          setTimeout(function() { newBtnShare.innerHTML = orig; }, 2200);
        }
      });
    }

    // 3. SALVAR COMO IMAGEM ──────────────────────────────────────────────────
    var btnSave     = document.getElementById('btn-save');
    var captureArea = document.getElementById('ticket-capture-area');
    if (btnSave && captureArea && typeof html2canvas !== 'undefined') {
      var newBtnSave = btnSave.cloneNode(true);
      btnSave.parentNode.replaceChild(newBtnSave, btnSave);
      newBtnSave.addEventListener('click', function() {
        var orig = newBtnSave.innerHTML;
        newBtnSave.innerHTML = 'Gerando...';
        newBtnSave.disabled  = true;

        html2canvas(captureArea, {
          backgroundColor: '#0a0a0a',
          scale:           2,
          useCORS:         true,
          logging:         false,
        }).then(function(canvas) {
          var link      = document.createElement('a');
          link.download = 'ingresso-' + ticketCode + '.png';
          link.href     = canvas.toDataURL('image/png');
          link.click();

          newBtnSave.innerHTML = '✓ Salvo';
          setTimeout(function() {
            newBtnSave.innerHTML = orig;
            newBtnSave.disabled  = false;
          }, 3000);
        }).catch(function(err) {
          console.error('html2canvas error:', err);
          newBtnSave.innerHTML = orig;
          newBtnSave.disabled  = false;
        });
      });
    }
  }

  // Roda na carga inicial
  initTicket();

  // Re-inicializa após View Transitions (função agora acessível no escopo)
  document.addEventListener('astro:page-load', initTicket);
</script>

<style>
  .ig-shell {
    min-height: 100dvh;
    background: #000;
    font-family: 'Inter', sans-serif;
    display: flex; flex-direction: column; align-items: center;
    padding: 16px 16px 60px;
  }

  .ig-nav { width: 100%; max-width: 440px; margin-bottom: 24px; }
  .ig-back {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .75rem; color: #3A3A3A; text-decoration: none;
    transition: color 200ms;
  }
  .ig-back:hover { color: #E0E0E0; }

  /* Área de captura — invisible wrapper */
  .ig-capture-area { width: 100%; max-width: 400px; background: #0A0A0A; border-radius: 20px; }

  /* Ticket */
  .ig-ticket {
    width: 100%;
    background: #0A0A0A;
    border: 1px solid rgba(201,169,110,0.25);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  .ig-ticket-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .ig-logo-group { display: flex; align-items: baseline; gap: 2px; }
  .ig-vip-badge {
    font-size: .55rem; font-weight: 700; letter-spacing: .16em;
    color: #C9A96E; border: 1px solid rgba(201,169,110,0.25);
    padding: 3px 10px; border-radius: 20px;
  }

  .ig-divider-dash {
    height: 1px;
    background-image: repeating-linear-gradient(
      90deg, rgba(201,169,110,0.2) 0px, rgba(201,169,110,0.2) 6px, transparent 6px, transparent 12px
    );
  }

  .ig-event-info { padding: 20px 24px 16px; }
  .ig-event-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; font-weight: 700;
    color: #F5F5F5; margin-bottom: 14px;
  }
  .ig-event-meta { display: flex; flex-direction: column; gap: 8px; }
  .ig-meta-item {
    display: flex; align-items: center; gap: 8px;
    font-size: .75rem; color: #5A5A5A;
  }
  .ig-meta-item svg { color: #C9A96E; flex-shrink: 0; }

  .ig-perforation { display: flex; align-items: center; margin: 4px 0; }
  .ig-perf-cut { width: 20px; height: 20px; background: #000; border-radius: 50%; flex-shrink: 0; }
  .ig-perf-cut--l { margin-left: -10px; }
  .ig-perf-cut--r { margin-right: -10px; }
  .ig-perf-line {
    flex: 1; height: 1px;
    background-image: repeating-linear-gradient(
      90deg, rgba(255,255,255,0.06) 0px, rgba(255,255,255,0.06) 6px, transparent 6px, transparent 12px
    );
  }

  /* QR */
  .ig-qr-section {
    display: flex; flex-direction: column; align-items: center;
    padding: 24px 24px 20px;
    position: relative;
  }
  .ig-qr-glow {
    position: absolute;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(201,169,110,0.10), transparent 70%);
    border-radius: 50%; pointer-events: none;
  }
  .ig-qr-wrap {
    position: relative; z-index: 1;
    border-radius: 12px; padding: 10px;
    margin-bottom: 16px;
  }
  /* Garante que qrcodejs não adicione whitespace ao redor */
  #qrcode-container img,
  #qrcode-container canvas { display: block; }

  .ig-qr-hint {
    font-size: .7rem; color: #3A3A3A;
    text-align: center; max-width: 260px;
    line-height: 1.6; margin-bottom: 8px;
  }
  .ig-qr-code { font-family: monospace; font-size: .7rem; color: #C9A96E; letter-spacing: .08em; }

  /* Rodapé */
  .ig-ticket-foot {
    display: flex;
    border-top: 1px solid rgba(255,255,255,0.04);
    padding: 16px 24px; gap: 8px;
  }
  .ig-foot-item { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .ig-foot-item + .ig-foot-item { border-left: 1px solid rgba(255,255,255,0.04); padding-left: 12px; }
  .ig-foot-label { font-size: .5rem; font-weight: 700; letter-spacing: .1em; color: #2E2E2E; }
  .ig-foot-value { font-size: .75rem; font-weight: 500; color: #A0A0A0; }
  .ig-foot-value--gold { color: #C9A96E; }

  /* Ações */
  .ig-actions { display: flex; gap: 12px; margin-top: 20px; width: 100%; max-width: 400px; }
  .ig-btn-secondary {
    flex: 1; height: 40px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    background: transparent; border: 1px solid rgba(255,255,255,0.07);
    color: #4A4A4A; font-family: 'Inter', sans-serif;
    font-size: .75rem; font-weight: 500; letter-spacing: .06em;
    border-radius: 8px; cursor: pointer;
    transition: border-color 200ms, color 200ms;
  }
  .ig-btn-secondary:hover   { border-color: rgba(201,169,110,0.2); color: #C9A96E; }
  .ig-btn-secondary:disabled { opacity: 0.5; cursor: default; }
</style>
