---
import AppLayout from '@/layouts/AppLayout.astro';
import { supabase } from '@/lib/supabase';

// ── Parâmetros da URL ──────────────────────────────────────────────────────
const productId  = Astro.url.searchParams.get('id');
const lessonIdQS = Astro.url.searchParams.get('lesson_id') ?? '';
const userId     = Astro.locals.user?.id ?? '';

// Sem produto → redireciona para compras
if (!productId) return Astro.redirect('/app/compras');

// ── Busca produto + módulos antes do POST (allLessons necessário para percent) ───
const { data: product } = await supabase
  .from('products')
  .select('id, title, thumbnail_url, description')
  .eq('id', productId)
  .single();
if (!product) return Astro.redirect('/app/compras');

const { data: modules } = await supabase
  .from('course_modules')
  .select('id, title, order, course_lessons(id, title, description, video_url, duration_seconds, order)')
  .eq('product_id', productId)
  .order('order', { ascending: true });

const sortedModules = (modules ?? []).map(mod => ({
  ...mod,
  course_lessons: [...(mod.course_lessons ?? [])].sort((a, b) => a.order - b.order),
}));
const allLessons   = sortedModules.flatMap(m => m.course_lessons);
const totalLessons = allLessons.length;

// ── POST: Marcar aula como concluída ──────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form     = await Astro.request.formData();
  const action   = form.get('action');
  const lessonId = form.get('lesson_id') as string;

  if (action === 'mark_completed' && lessonId && userId) {
    const { data: existing } = await supabase
      .from('course_progress')
      .select('id, completed_lessons')
      .eq('user_id', userId)
      .eq('product_id', productId)
      .maybeSingle();

    if (!existing) {
      await supabase.from('course_progress').insert({
        user_id:           userId,
        product_id:        productId,
        completed_lessons: [lessonId],
        overall_percent:   allLessons.length ? Math.round(1 / allLessons.length * 100) : 0,
      });
    } else {
      const current: string[] = existing.completed_lessons ?? [];
      if (!current.includes(lessonId)) {
        const updated = [...current, lessonId];
        await supabase.from('course_progress')
          .update({
            completed_lessons: updated,
            overall_percent: allLessons.length ? Math.round(updated.length / allLessons.length * 100) : 0,
          })
          .eq('id', existing.id);
      }
    }
  }

  // ── Salvar anotação ────────────────────────────────────────────────────────
  if (action === 'save_note' && userId) {
    const noteLesson = form.get('lesson_id') as string;
    const content    = (form.get('content') as string ?? '').trim();
    if (noteLesson) {
      await supabase.from('lesson_notes').upsert(
        { user_id: userId, lesson_id: noteLesson, content },
        { onConflict: 'user_id,lesson_id' },
      );
    }
  }

  // PRG — usa o lesson_id do form para manter a aula correta + flag para feedback visual
  const lid      = (form.get('lesson_id') as string) || lessonIdQS;
  const noteSaved = ''; // notas salvas via AJAX — sem param na URL
  const qs        = lid ? `?id=${productId}&lesson_id=${lid}${noteSaved}` : `?id=${productId}${noteSaved}`;
  return Astro.redirect(`/app/player${qs}`);
}

// ── Produto + módulos já buscados acima ────────────────────────────────────────────
const activeLesson =
  (lessonIdQS ? allLessons.find(l => l.id === lessonIdQS) : null)
  ?? sortedModules[0]?.course_lessons?.[0]
  ?? null;

// ── Anotação salva da aula ativa ────────────────────────────────────────────
const { data: savedNote } = (userId && activeLesson?.id) ? await supabase
  .from('lesson_notes')
  .select('content')
  .eq('user_id', userId)
  .eq('lesson_id', activeLesson.id)
  .maybeSingle() : { data: null };

const savedContent   = savedNote?.content ?? '';
// Notas persistidas via AJAX — não precisa ler searchParam

// ── Busca progresso do usuário ────────────────────────────────────────────
const { data: progress } = userId ? await supabase
  .from('course_progress')
  .select('completed_lessons, overall_percent')
  .eq('user_id', userId)
  .eq('product_id', productId)
  .maybeSingle() : { data: null };

const completedLessons: string[] = progress?.completed_lessons ?? [];
// Percentual calculado em tempo real a partir de allLessons (sempre correto pós-redirect)
const progressPercent = totalLessons > 0
  ? Math.round(completedLessons.length / totalLessons * 100)
  : 0;
const isActiveDone = activeLesson ? completedLessons.includes(activeLesson.id) : false;

// ── Arquivos da aula ativa (blindado) ─────────────────────────────────────
let lessonFiles: any[] = [];
if (activeLesson?.id) {
  const { data: filesData, error: filesError } = await supabase
    .from('course_lesson_files')
    .select('*')
    .eq('lesson_id', activeLesson.id);

  if (filesError) {
    console.error('❌ Supabase files error:', filesError.message, filesError.details);
  } else {
    lessonFiles = filesData ?? [];
  }
}

// ── Helpers ───────────────────────────────────────────────────────────────
const fmtDur = (secs: number) => {
  const m = Math.floor(secs / 60).toString().padStart(2, '0');
  const s = (secs % 60).toString().padStart(2, '0');
  return `${m}:${s}`;
};

/**
 * Converte QUALQUER formato de URL do YouTube para o formato /embed/.
 * Suporta: watch?v=, youtu.be/, /shorts/, /live/, /v/, /embed/ (já correto).
 * Adiciona rel=0 para evitar vídeos sugeridos de outros canais no final.
 * Retorna a URL original intacta se não for do YouTube.
 */
const getYouTubeEmbedUrl = (url: string | null | undefined): string => {
  if (!url) return '';
  const regExp = /^.*(youtu\.be\/|v\/|u\/\w\/|embed\/|shorts\/|live\/|watch\?v=|&v=)([^#&?]{11}).*/;
  const match  = url.match(regExp);
  if (match && match[2]?.length === 11) {
    return `https://www.youtube.com/embed/${match[2]}?rel=0&modestbranding=1`;
  }
  return url; // URL não-YouTube retorna intacta (Vimeo, Panda, etc.)
};

const formatBytes = (bytes: number) => {
  if (!bytes || bytes === 0) return '—';
  const k     = 1024;
  const sizes = ['Bytes', 'KB', 'MB', 'GB'];
  const i     = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
};

const hasCurriculum = sortedModules.length > 0;
---

<AppLayout title={`Player · ${product.title}`}>
  <div class="pl-shell">

    <!-- Top bar compacto -->
    <header class="pl-topbar">
      <a href="/app/compras" class="pl-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Minha Biblioteca
      </a>
      <p class="pl-course-name">{product.title}</p>
      <div class="pl-topbar-right">
        <span class="pl-prog-pill">
          <span class="pl-prog-pill-fill" style={`width:${progressPercent}%`}></span>
        </span>
        <span class="pl-prog-text">{progressPercent}%</span>
      </div>
    </header>

    <!-- Layout principal -->
    <div class="pl-layout">

      <!-- ═══ ÁREA DO PLAYER ═══ -->
      <main class="pl-main">

        <!-- Vídeo / Embed -->
        <div class="pl-video-wrap" id="pl-video">
          <div class="pl-video-screen">

            {activeLesson?.video_url ? (
              /* Renderiza iframe — URL é normalizada para /embed/ pelo parser SSR */
              activeLesson.video_url.startsWith('http') ? (
                <iframe
                  src={getYouTubeEmbedUrl(activeLesson.video_url)}
                  class="pl-video-iframe"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
                  allowfullscreen
                  title={activeLesson.title}
                />
              ) : (
                <video class="pl-video-iframe" controls>
                  <source src={activeLesson.video_url} />
                </video>
              )
            ) : (
              /* Sem URL de vídeo: tela de placeholder premium */
              <>
                <img
                  src={product.thumbnail_url ?? 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=800&auto=format&fit=crop'}
                  alt="Thumbnail do curso"
                  class="pl-video-bg"
                  loading="eager"
                />
                <div class="pl-video-glow"></div>
                <div class="pl-no-video-state">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="pl-no-video-icon">
                    <polygon points="5 3 19 12 5 21 5 3"/>
                  </svg>
                  <p class="pl-no-video-text">Vídeo será disponibilizado em breve</p>
                </div>
              </>
            )}

            <!-- Overlay info da aula (sobre o vídeo) -->
            {!activeLesson?.video_url && (
              <div class="pl-video-info">
                <p class="pl-video-ep">Aula ativa</p>
                <p class="pl-video-title-overlay">{activeLesson?.title ?? product.title}</p>
              </div>
            )}
          </div>

          <!-- Controles customizados (apenas no modo placeholder) -->
          {!activeLesson?.video_url && (
            <div class="pl-controls">
              <div class="pl-seek-wrap">
                <div class="pl-seek-bg">
                  <div class="pl-seek-fill" style="width:0%"></div>
                  <div class="pl-seek-thumb" style="left:0%"></div>
                </div>
              </div>
              <div class="pl-controls-row">
                <div class="pl-controls-left">
                  <span class="pl-time">00:00 / {activeLesson?.duration_seconds ? fmtDur(activeLesson.duration_seconds) : '--:--'}</span>
                </div>
                <div class="pl-controls-right">
                  <button class="pl-ctrl-btn pl-speed" aria-label="Velocidade">1.0×</button>
                </div>
              </div>
            </div>
          )}
        </div>

        <!-- Botão Marcar como Concluída -->
        {activeLesson && (
          <div class="pl-complete-bar">
            <form
              method="POST"
              action={`/app/player?id=${productId}&lesson_id=${activeLesson.id}`}
              onsubmit={!isActiveDone ? 'dispararConfetePremium(event,this)' : undefined}
            >
              <input type="hidden" name="action" value="mark_completed" />
              <input type="hidden" name="lesson_id" value={activeLesson.id} />
              {isActiveDone ? (
                <button type="button" class="pl-complete-btn pl-complete-btn--done" disabled>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  Aula Concluída
                </button>
              ) : (
                <button type="submit" class="pl-complete-btn">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  Marcar como Concluída
                </button>
              )}
            </form>
          </div>
        )}

        <!-- Abas (is:inline — funciona com SSR + View Transitions) -->
        <div class="pl-tabs">
          <div class="pl-tab-bar" role="tablist">
            <button class="pl-tab pl-tab--active" data-tab-target="pl-panel-desc">Descrição</button>
            <button class="pl-tab" data-tab-target="pl-panel-files">Downloads</button>
            <button class="pl-tab" data-tab-target="pl-panel-notes">Anotações</button>
          </div>

          <!-- Descrição -->
          <div class="pl-tab-content" id="pl-panel-desc">
            <h3 class="pl-tab-title">{activeLesson?.title ?? product.title}</h3>
            <p class="pl-tab-text">
              {activeLesson?.description ?? product.description ?? 'Conteúdo desta aula disponível em breve.'}
            </p>
          </div>

          <!-- Downloads -->
          <div class="pl-tab-content pl-panel-hidden" id="pl-panel-files">
            {lessonFiles && lessonFiles.length > 0 ? (
              <div class="pl-file-list">
                {lessonFiles.map(file => (
                  <a
                    href={file.url}
                    class="pl-file-item"
                    target="_blank"
                    rel="noopener noreferrer"
                    download
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                      <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <span class="pl-file-name">{file.name}</span>
                    <span class="pl-file-size">{formatBytes(file.size_bytes)}</span>
                    <svg class="pl-file-dl" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                      <polyline points="7 10 12 15 17 10"/>
                      <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                  </a>
                ))}
              </div>
            ) : (
              <p class="pl-files-empty">Nenhum material complementar disponível para esta aula.</p>
            )}
          </div>

          <!-- Anotações -->
          <div class="pl-tab-content pl-panel-hidden" id="pl-panel-notes">
            <form id="form-anotacao">
              <input type="hidden" name="action"    value="save_note" />
              <input type="hidden" name="lesson_id" value={activeLesson?.id ?? ''} />

              <textarea
                class="pl-notes"
                name="content"
                placeholder="Escreva suas anotações aqui..."
              >{savedContent}</textarea>

              <div class="pl-notes-actions">
                <button type="submit" id="btn-salvar-nota" class="pl-notes-save">
                  Salvar anotação
                </button>
                <span id="note-success-msg" class="pl-note-success pl-note-success--hidden">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  Salvo com sucesso
                </span>
              </div>
            </form>
          </div>
        </div>

      </main>

      <!-- ═══ SIDEBAR — CURRÍCULO REAL (SSR) ═══ -->
      <aside class="pl-sidebar">
        <p class="pl-sidebar-heading">CONTEÚDO DO CURSO</p>

        {hasCurriculum ? (
          <div class="pl-curriculum">
            {sortedModules.map((mod, mi) => (
              <details class="pl-module" open={mi === 0}>
                <summary class="pl-module-header">
                  <div class="pl-module-meta">
                    <span class="pl-module-num">{String(mi + 1).padStart(2, '0')}</span>
                    <div>
                      <p class="pl-module-title">{mod.title}</p>
                      <p class="pl-module-count">{mod.course_lessons.length} aulas</p>
                    </div>
                  </div>
                  <svg class="pl-module-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </summary>

                <div class="pl-lesson-list">
                  {mod.course_lessons.map((lesson, li) => {
                    const isActive    = lesson.id === activeLesson?.id;
                    const isDone      = completedLessons.includes(lesson.id);
                    const isDoneIdle  = isDone && !isActive; // concluída mas não é a ativa
                    return (
                      <a
                        href={`/app/player?id=${productId}&lesson_id=${lesson.id}`}
                        class={`pl-lesson${isActive ? ' pl-lesson--active' : ''}${isDoneIdle ? ' pl-lesson--done' : ''}`}
                      >
                        {/* Ícone: play (ativa) | check (concluída) | número (pendente) */}
                        <div class={`pl-lesson-icon${isActive ? ' pl-lesson-icon--active' : ''}${isDone && !isActive ? ' pl-lesson-icon--done' : ''}`}>
                          {isActive ? (
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                          ) : isDone ? (
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                          ) : (
                            <span class="pl-lesson-num">{String((mi * 100) + li + 1).padStart(2, '0')}</span>
                          )}
                        </div>
                        <div class={`pl-lesson-info${isDoneIdle ? ' pl-lesson-info--done' : ''}`}>
                          <p class={`pl-lesson-title${isActive ? ' pl-lesson-title--active' : ''}`}>
                            {lesson.title}
                          </p>
                          <p class="pl-lesson-dur">
                            {lesson.duration_seconds ? fmtDur(lesson.duration_seconds) : '--:--'}
                          </p>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </details>
            ))}
          </div>
        ) : (
          /* Fallback estático quando o banco ainda não tem módulos cadastrados */
          <div class="pl-lesson-list">
            {['Introdução: A Mentalidade do Executivo', 'O Fator Alfa nas Negociações', 'Posicionamento Estratégico de Alto Nível', 'Delegação sem Abdicação', 'Comunicação de Autoridade'].map((title, i) => (
              <div class={`pl-lesson${i === 0 ? ' pl-lesson--active' : ''}`} role="button">
                <div class={`pl-lesson-icon${i === 0 ? ' pl-lesson-icon--active' : ''}`}>
                  {i === 0
                    ? <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    : <span class="pl-lesson-num">{String(i + 1).padStart(2, '0')}</span>
                  }
                </div>
                <div class="pl-lesson-info">
                  <p class={`pl-lesson-title${i === 0 ? ' pl-lesson-title--active' : ''}`}>{title}</p>
                  <p class="pl-lesson-dur">--:--</p>
                </div>
              </div>
            ))}
          </div>
        )}
      </aside>

    </div>
  </div>
</AppLayout>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>

<script is:inline>
  // ── Golden Spark — efeito premium de conclusão de aula ────────────────────
  function dispararConfetePremium(event, formElement) {
    event.preventDefault();

    var colors = ['#D4AF37', '#AA8822', '#FFFFFF', '#C9A96E'];

    // Burst central
    confetti({
      particleCount: 80,
      spread: 70,
      origin: { y: 0.6 },
      colors: colors,
      shapes: ['circle'],
      gravity: 0.8,
      scalar: 0.8,
    });

    // Segunda rajada com leve delay — dá o efeito de "ondas de luz"
    setTimeout(function() {
      confetti({
        particleCount: 40,
        spread: 50,
        origin: { x: 0.3, y: 0.55 },
        colors: colors,
        shapes: ['circle'],
        gravity: 0.9,
        scalar: 0.6,
      });
      confetti({
        particleCount: 40,
        spread: 50,
        origin: { x: 0.7, y: 0.55 },
        colors: colors,
        shapes: ['circle'],
        gravity: 0.9,
        scalar: 0.6,
      });
    }, 200);

    // Envia o formulário após a animação brilhar
    setTimeout(function() {
      formElement.submit();
    }, 1200);
  }

  // ── Tabs ──────────────────────────────────────────────────────────────
  function initPlayerTabs() {
    var btns   = document.querySelectorAll('[data-tab-target]');
    var panels = document.querySelectorAll('.pl-tab-content');
    if (!btns.length) return;

    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.getAttribute('data-tab-target');
        panels.forEach(function(p) {
          p.classList.toggle('pl-panel-hidden', p.id !== target);
        });
        btns.forEach(function(b) {
          b.classList.toggle('pl-tab--active', b === btn);
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initPlayerTabs);

  // ── Salvamento assíncrono de anotações (AJAX — sem reload) ─────────────────
  function initNotesForm() {
    var form    = document.getElementById('form-anotacao');
    var btnSave = document.getElementById('btn-salvar-nota');
    var msgOk   = document.getElementById('note-success-msg');
    if (!form || !btnSave || !msgOk) return;

    // Garante que não duplica o listener em navegações SPA
    form.removeEventListener('submit', form.__noteHandler);

    form.__noteHandler = async function(e) {
      e.preventDefault();

      var label = btnSave.innerText;
      btnSave.innerText  = 'Salvando...';
      btnSave.disabled   = true;
      btnSave.style.opacity = '0.6';

      try {
        // POST para a URL atual com os query params intactos
        var target = new URL(window.location.href);
        target.searchParams.delete('note_saved'); // limpeza preventiva
        await fetch(target.toString(), {
          method: 'POST',
          body:   new FormData(form),
          // Impede que o fetch siga o redirect 302 do Astro
          redirect: 'manual',
        });

        // Feedback visual — aparece por 3s depois some
        msgOk.classList.remove('pl-note-success--hidden');
        clearTimeout(form.__noteTimer);
        form.__noteTimer = setTimeout(function() {
          msgOk.classList.add('pl-note-success--hidden');
        }, 3000);

      } catch (err) {
        console.error('❌ Erro ao salvar anotação:', err);
      } finally {
        btnSave.innerText     = label;
        btnSave.disabled      = false;
        btnSave.style.opacity = '1';
      }
    };

    form.addEventListener('submit', form.__noteHandler);
  }

  initNotesForm();
  document.addEventListener('astro:page-load', initNotesForm);
</script>

<script>
  import { gsap } from 'gsap';
  document.addEventListener('astro:page-load', () => {
    gsap.from('#pl-video', { scale: 0.97, opacity: 0, duration: 0.6, ease: 'power2.out' });
    gsap.from('.pl-sidebar', { x: 20, opacity: 0, duration: 0.5, delay: 0.15, ease: 'power2.out' });
  });
</script>

<style>
  /* ── Reset / Shell ───────────────────────────────────────────────────────── */
  .pl-shell { min-height:100dvh; background:#000; font-family:'Inter',sans-serif; display:flex; flex-direction:column; }

  /* ── Topbar ──────────────────────────────────────────────────────────────── */
  .pl-topbar { display:flex; align-items:center; justify-content:space-between; padding:14px 20px; border-bottom:1px solid rgba(255,255,255,0.05); gap:16px; flex-wrap:wrap; }
  .pl-back { display:flex; align-items:center; gap:8px; font-size:.75rem; color:#4A4A4A; text-decoration:none; transition:color 200ms; flex-shrink:0; }
  .pl-back:hover { color:#E0E0E0; }
  .pl-course-name { font-size:.8125rem; font-weight:500; color:#A0A0A0; flex:1; text-align:center; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .pl-topbar-right { display:flex; align-items:center; gap:10px; flex-shrink:0; }
  .pl-prog-pill { display:block; width:80px; height:3px; background:rgba(255,255,255,0.06); border-radius:2px; position:relative; overflow:hidden; }
  .pl-prog-pill-fill { position:absolute; left:0; top:0; height:100%; background:#C9A96E; border-radius:2px; }
  .pl-prog-text { font-size:.6875rem; color:#3A3A3A; }

  /* ── Layout ──────────────────────────────────────────────────────────────── */
  .pl-layout { display:flex; flex-direction:column; flex:1; }
  @media(min-width:960px) { .pl-layout { flex-direction:row; overflow:hidden; } }

  /* ── Main ────────────────────────────────────────────────────────────────── */
  .pl-main { flex:1; display:flex; flex-direction:column; overflow:hidden; }

  /* ── Vídeo ───────────────────────────────────────────────────────────────── */
