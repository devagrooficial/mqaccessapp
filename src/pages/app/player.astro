---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Player · Protocolo C-Level: A Arquitetura da Decisão">
  <div class="pl-shell" x-data="{
    activeLesson: 0,
    activeTab: 'desc',
    playing: false,
    progress: 34,
    lessons: [
      { title:'Introdução: A Mentalidade do Executivo', dur:'08:32', done:true },
      { title:'O Fator Alfa nas Negociações', dur:'14:10', done:true },
      { title:'Posicionamento Estratégico de Alto Nível', dur:'22:47', done:false },
      { title:'Delegação sem Abdicação', dur:'18:05', done:false },
      { title:'Comunicação de Autoridade', dur:'16:33', done:false },
      { title:'Gestão de Conflitos Executivos', dur:'20:14', done:false },
      { title:'Pipeline de Decisões Críticas', dur:'24:01', done:false },
      { title:'Encerramento: O Protocolo de 90 Dias', dur:'11:28', done:false },
    ]
  }">

    <!-- Top bar compacto -->
    <header class="pl-topbar">
      <a href="/app/compras" class="pl-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Minha Biblioteca
      </a>
      <p class="pl-course-name">Protocolo C-Level: A Arquitetura da Decisão</p>
      <div class="pl-topbar-right">
        <span class="pl-prog-pill">
          <span class="pl-prog-pill-fill" style="width:34%"></span>
        </span>
        <span class="pl-prog-text">34%</span>
      </div>
    </header>

    <!-- Layout principal -->
    <div class="pl-layout">

      <!-- ═══ ÁREA DO PLAYER ═══ -->
      <main class="pl-main">

        <!-- Vídeo -->
        <div class="pl-video-wrap" id="pl-video">
          <div class="pl-video-screen">
            <!-- Imagem de fundo real -->
            <img
              src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=800&auto=format&fit=crop"
              alt="Thumbnail do curso"
              class="pl-video-bg"
              loading="eager"
            />
            <div class="pl-video-glow"></div>
            <!-- Ícone play/pause central -->
            <button class="pl-center-play" @click="playing=!playing" aria-label="Play / Pause">
              <svg x-show="!playing" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              <svg x-show="playing"  width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
            </button>
            <!-- Overlay módulo info -->
            <div class="pl-video-info">
              <p class="pl-video-ep">Aula 03 · Módulo 1</p>
              <p class="pl-video-title-overlay" x-text="lessons[activeLesson].title"></p>
            </div>
          </div>

          <!-- Controles customizados -->
          <div class="pl-controls">
            <!-- Barra de progresso -->
            <div class="pl-seek-wrap">
              <div class="pl-seek-bg">
                <div class="pl-seek-fill" :style="`width:${progress}%`"></div>
                <div class="pl-seek-thumb" :style="`left:${progress}%`"></div>
              </div>
            </div>
            <div class="pl-controls-row">
              <div class="pl-controls-left">
                <button class="pl-ctrl-btn" @click="playing=!playing" aria-label="Play">
                  <svg x-show="!playing" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  <svg x-show="playing"  width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                </button>
                <button class="pl-ctrl-btn" aria-label="Avançar 10s">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
                </button>
                <span class="pl-time">08:47 / 22:47</span>
              </div>
              <div class="pl-controls-right">
                <button class="pl-ctrl-btn pl-speed" aria-label="Velocidade">1.0×</button>
                <button class="pl-ctrl-btn" aria-label="Volume">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 010 7.07"/></svg>
                </button>
                <button class="pl-ctrl-btn" aria-label="Fullscreen">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3"/></svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Abas -->
        <div class="pl-tabs" x-data>
          <div class="pl-tab-bar" role="tablist">
            <button class="pl-tab" :class="activeTab==='desc' && 'pl-tab--active'" @click="activeTab='desc'">Descrição</button>
            <button class="pl-tab" :class="activeTab==='files' && 'pl-tab--active'" @click="activeTab='files'">Downloads</button>
            <button class="pl-tab" :class="activeTab==='notes' && 'pl-tab--active'" @click="activeTab='notes'">Anotações</button>
          </div>

          <!-- Descrição -->
          <div class="pl-tab-content" x-show="activeTab==='desc'">
            <h3 class="pl-tab-title" x-text="lessons[activeLesson].title"></h3>
            <p class="pl-tab-text">Nesta aula você vai descobrir como líderes de elite estabelecem posicionamento antes mesmo de entrar em qualquer sala de decisão. O conceito de "Fator Alfa" define quem conduz e quem reage — e a diferença começa no preparo mental e no protocolo de entrada.</p>
            <ul class="pl-tab-points">
              <li>Como calibrar presença antes de reuniões de alto impacto</li>
              <li>O mapa de stakeholders que todo C-Level precisa dominar</li>
              <li>Técnica de âncora comportamental para contextos de pressão</li>
            </ul>
          </div>

          <!-- Downloads -->
          <div class="pl-tab-content" x-show="activeTab==='files'">
            <div class="pl-file-list">
              <a href="#" class="pl-file-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <span class="pl-file-name">Mapa Mental — Fator Alfa.pdf</span>
                <span class="pl-file-size">2.4 MB</span>
                <svg class="pl-file-dl" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
              <a href="#" class="pl-file-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <span class="pl-file-name">Protocolo de Posicionamento.pdf</span>
                <span class="pl-file-size">1.1 MB</span>
                <svg class="pl-file-dl" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              </a>
            </div>
          </div>

          <!-- Anotações -->
          <div class="pl-tab-content" x-show="activeTab==='notes'">
            <textarea class="pl-notes" placeholder="Escreva suas anotações aqui..."></textarea>
            <button class="pl-notes-save">Salvar anotação</button>
          </div>
        </div>

      </main>

      <!-- ═══ SIDEBAR DE AULAS ═══ -->
      <aside class="pl-sidebar">
        <p class="pl-sidebar-heading">CONTEÚDO DO CURSO</p>
        <div class="pl-lesson-list">
          <template x-for="(lesson, i) in lessons" :key="i">
            <button
              class="pl-lesson"
              :class="{ 'pl-lesson--active': activeLesson === i, 'pl-lesson--done': lesson.done }"
              @click="activeLesson = i"
            >
              <div class="pl-lesson-icon">
                <svg x-show="activeLesson === i" class="pl-now-icon" width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                <svg x-show="lesson.done && activeLesson !== i" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                <span x-show="!lesson.done && activeLesson !== i" class="pl-lesson-num" x-text="(i+1).toString().padStart(2,'0')"></span>
              </div>
              <div class="pl-lesson-info">
                <p class="pl-lesson-title" x-text="lesson.title"></p>
                <p class="pl-lesson-dur" x-text="lesson.dur"></p>
              </div>
            </button>
          </template>
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  document.addEventListener('astro:page-load', () => {
    gsap.from('#pl-video', {
      scale: 0.97,
      opacity: 0,
      duration: 0.6,
      ease: 'power2.out',
    });
    gsap.from('.pl-sidebar', {
      x: 20,
      opacity: 0,
      duration: 0.5,
      delay: 0.15,
      ease: 'power2.out',
    });
  });
</script>

<style>
  .pl-shell { min-height:100dvh; background:#000; font-family:'Inter',sans-serif; display:flex; flex-direction:column; }

  /* Topbar */
  .pl-topbar { display:flex; align-items:center; justify-content:space-between; padding:14px 20px; border-bottom:1px solid rgba(255,255,255,0.05); gap:16px; flex-wrap:wrap; }
  .pl-back { display:flex; align-items:center; gap:8px; font-size:.75rem; color:#4A4A4A; text-decoration:none; transition:color 200ms; flex-shrink:0; }
  .pl-back:hover { color:#E0E0E0; }
  .pl-course-name { font-size:.8125rem; font-weight:500; color:#A0A0A0; flex:1; text-align:center; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .pl-topbar-right { display:flex; align-items:center; gap:10px; flex-shrink:0; }
  .pl-prog-pill { display:block; width:80px; height:3px; background:rgba(255,255,255,0.06); border-radius:2px; position:relative; overflow:hidden; }
  .pl-prog-pill-fill { position:absolute; left:0; top:0; height:100%; background:#C9A96E; border-radius:2px; }
  .pl-prog-text { font-size:.6875rem; color:#3A3A3A; }

  /* Layout */
  .pl-layout { display:flex; flex-direction:column; flex:1; }
  @media(min-width:960px) { .pl-layout { flex-direction:row; overflow:hidden; } }

  /* Main */
  .pl-main { flex:1; display:flex; flex-direction:column; overflow:hidden; }

  /* Video */
  .pl-video-wrap { background:#000; position:relative; }
  .pl-video-screen {
    aspect-ratio:16/9;
    background:linear-gradient(160deg,#0A0807,#111208);
    position:relative; overflow:hidden;
    display:flex; align-items:center; justify-content:center;
  }
  /* Imagem de fundo real do player */
  .pl-video-bg {
    position:absolute; inset:0;
    width:100%; height:100%;
    object-fit:cover; object-position:center;
    filter:brightness(0.25) saturate(0.5);
  }
  .pl-video-glow { position:absolute; inset:0; background:radial-gradient(ellipse at 50% 40%,rgba(201,169,110,0.04),transparent 70%); }
  .pl-center-play { position:relative; z-index:2; background:rgba(0,0,0,0.4); border:1px solid rgba(201,169,110,0.25); color:#C9A96E; width:72px; height:72px; border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; backdrop-filter:blur(8px); transition:background 200ms,border-color 200ms; }
  .pl-center-play:hover { background:rgba(201,169,110,0.1); border-color:#C9A96E; }
  .pl-video-info { position:absolute; bottom:0; left:0; right:0; padding:24px 20px 10px; background:linear-gradient(to top,rgba(0,0,0,0.75),transparent); }
  .pl-video-ep    { font-size:.6rem; font-weight:700; letter-spacing:.14em; color:#C9A96E; margin-bottom:4px; }
  .pl-video-title-overlay { font-family:'Playfair Display',serif; font-size:1.125rem; color:#F5F5F5; }

  /* Controls */
  .pl-controls { padding:10px 16px 12px; background:#050505; border-bottom:1px solid rgba(255,255,255,0.04); }
  .pl-seek-wrap { margin-bottom:10px; padding:4px 0; cursor:pointer; }
  .pl-seek-bg { height:2px; background:rgba(255,255,255,0.08); border-radius:2px; position:relative; }
  .pl-seek-fill { height:100%; background:#C9A96E; border-radius:2px; position:absolute; top:0; left:0; }
  .pl-seek-thumb { position:absolute; top:50%; transform:translate(-50%,-50%); width:10px; height:10px; background:#C9A96E; border-radius:50%; box-shadow:0 0 6px rgba(201,169,110,0.5); }
  .pl-controls-row { display:flex; align-items:center; justify-content:space-between; }
  .pl-controls-left,.pl-controls-right { display:flex; align-items:center; gap:14px; }
  .pl-ctrl-btn { background:none; border:none; cursor:pointer; color:#4A4A4A; display:flex; align-items:center; font-family:'Inter',sans-serif; font-size:.75rem; transition:color 200ms; }
  .pl-ctrl-btn:hover { color:#E0E0E0; }
  .pl-speed { font-weight:600; letter-spacing:.04em; }
  .pl-time { font-size:.7rem; color:#3A3A3A; }

  /* Tabs */
  .pl-tabs { border-top:1px solid rgba(255,255,255,0.05); }
  .pl-tab-bar { display:flex; padding:0 20px; border-bottom:1px solid rgba(255,255,255,0.05); }
  .pl-tab { background:none; border:none; cursor:pointer; font-family:'Inter',sans-serif; font-size:.625rem; font-weight:700; letter-spacing:.12em; color:#3A3A3A; padding:12px 0; margin-right:24px; border-bottom:2px solid transparent; transition:color 200ms,border-color 200ms; position:relative; bottom:-1px; }
  .pl-tab--active { color:#F5F5F5; border-bottom-color:#C9A96E; }
  .pl-tab-content { padding:20px; }
  .pl-tab-title { font-family:'Playfair Display',serif; font-size:1.125rem; font-weight:700; color:#F5F5F5; margin-bottom:12px; }
  .pl-tab-text { font-size:.875rem; color:#5A5A5A; line-height:1.7; margin-bottom:16px; }
  .pl-tab-points { padding-left:16px; }
  .pl-tab-points li { font-size:.8125rem; color:#4A4A4A; line-height:1.7; list-style:disc; margin-bottom:4px; }

  .pl-file-list { display:flex; flex-direction:column; gap:8px; }
  .pl-file-item { display:flex; align-items:center; gap:12px; background:#0A0A0A; border:1px solid rgba(255,255,255,0.05); border-radius:8px; padding:12px 14px; text-decoration:none; color:#A0A0A0; transition:border-color 200ms; }
  .pl-file-item:hover { border-color:rgba(201,169,110,0.2); }
  .pl-file-item svg { color:#C9A96E; flex-shrink:0; }
  .pl-file-name { flex:1; font-size:.8125rem; }
  .pl-file-size { font-size:.7rem; color:#3A3A3A; }
  .pl-file-dl { color:#3A3A3A; }

  .pl-notes { width:100%; height:120px; background:#0A0A0A; border:1px solid rgba(255,255,255,0.08); border-radius:8px; color:#E0E0E0; font-family:'Inter',sans-serif; font-size:.875rem; padding:12px; outline:none; resize:vertical; transition:border-color 200ms; }
  .pl-notes:focus { border-color:rgba(201,169,110,0.3); }
  .pl-notes-save { margin-top:10px; background:transparent; border:1px solid rgba(201,169,110,0.2); color:#C9A96E; font-family:'Inter',sans-serif; font-size:.75rem; font-weight:600; letter-spacing:.08em; padding:8px 18px; border-radius:6px; cursor:pointer; transition:background 200ms; }
  .pl-notes-save:hover { background:rgba(201,169,110,0.06); }

  /* Sidebar */
  .pl-sidebar { width:100%; background:#050505; border-top:1px solid rgba(255,255,255,0.05); overflow-y:auto; }
  @media(min-width:960px) { .pl-sidebar { width:300px; flex-shrink:0; border-top:none; border-left:1px solid rgba(255,255,255,0.05); } }

  .pl-sidebar-heading { font-size:.575rem; font-weight:700; letter-spacing:.16em; color:#2A2A2A; padding:16px 16px 10px; }
  .pl-lesson-list { display:flex; flex-direction:column; }

  .pl-lesson { display:flex; align-items:flex-start; gap:12px; padding:12px 16px; background:transparent; border:none; cursor:pointer; text-align:left; border-bottom:1px solid rgba(255,255,255,0.03); transition:background 200ms; }
  .pl-lesson:hover { background:rgba(255,255,255,0.02); }
  .pl-lesson--active { background:#111 !important; }
  .pl-lesson--done .pl-lesson-title { color:#3A3A3A; }

  .pl-lesson-icon { width:24px; height:24px; border-radius:50%; border:1px solid rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center; flex-shrink:0; color:#5A5A5A; margin-top:1px; }
  .pl-lesson--active .pl-lesson-icon { border-color:#C9A96E; }
  .pl-now-icon { color:#C9A96E; }
  .pl-lesson-num { font-size:.6rem; font-weight:700; color:#3A3A3A; }
  .pl-lesson--done .pl-lesson-icon { border-color:rgba(34,197,94,0.3); color:#22c55e; }

  .pl-lesson-info { flex:1; }
  .pl-lesson-title { font-size:.8125rem; font-weight:500; color:#A0A0A0; margin-bottom:3px; line-height:1.35; }
  .pl-lesson--active .pl-lesson-title { color:#F5F5F5; }
  .pl-lesson-dur { font-size:.7rem; color:#2E2E2E; }
</style>
