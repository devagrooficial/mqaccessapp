---
import AppLayout from '@/layouts/AppLayout.astro';
---

<AppLayout title="Relatório: Egograma" activeNav="analises">
  <div class="report-page">
    
    <!-- Header -->
    <div class="report-header">
      <a href="/app/analises" class="report-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Voltar às Análises
      </a>
      <h1 class="report-title">Relatório: Egograma</h1>
    </div>

    <!-- O Veredito -->
    <section class="report-verdict">
      <p class="verdict-subtitle">PERFIL PREDOMINANTE</p>
      <h2 class="verdict-title">Adulto Estratégico</h2>
      <p class="verdict-desc">
        Seu mapeamento indica uma forte inclinação para a racionalidade sob pressão, priorizando fatos e mitigando a reatividade emocional.
      </p>
    </section>

    <!-- Mapeamento Analítico -->
    <section class="report-section">
      <h3 class="section-title">Mapeamento Analítico</h3>
      <div class="chart-container">
        <!-- Pai -->
        <div class="bar-group">
          <div class="bar-header">
            <span class="bar-label">Pai <span class="bar-label-sub">(Normativo/Protetor)</span></span>
            <span class="bar-percent">35%</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style="width: 35%;"></div>
          </div>
        </div>
        
        <!-- Adulto -->
        <div class="bar-group">
          <div class="bar-header">
            <span class="bar-label">Adulto <span class="bar-label-sub">(Racional/Analítico)</span></span>
            <span class="bar-percent text-gold">80%</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill bar-fill--highlight" style="width: 80%;"></div>
          </div>
        </div>
        
        <!-- Criança -->
        <div class="bar-group">
          <div class="bar-header">
            <span class="bar-label">Criança <span class="bar-label-sub">(Rebelde/Adaptada)</span></span>
            <span class="bar-percent">20%</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style="width: 20%;"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- O Plano de Calibragem -->
    <section class="report-section">
      <h3 class="section-title">O Plano de Calibragem</h3>
      <div class="calibragem-grid">
        <!-- Pontos Fortes -->
        <div class="calibragem-card">
          <h4 class="calibragem-card__title text-green">Pontos Fortes</h4>
          <ul class="calibragem-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Clareza em negociações hostis
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Foco em métricas
            </li>
          </ul>
        </div>
        <!-- Pontos Cegos -->
        <div class="calibragem-card">
          <h4 class="calibragem-card__title text-red">Pontos Cegos</h4>
          <ul class="calibragem-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              Pode soar frio ou distante
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              Dificuldade em gerar rapport emocional rápido.
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- O Upsell Inteligente -->
    <section class="upsell-section">
      <div class="upsell-card">
        <p class="upsell-subtitle">Recomendação de Alta Performance</p>
        <div class="upsell-content">
          <div class="upsell-course-img">
            <img src="/negociacao-alto-ticket-thumb.png" alt="Negociação de Alto Ticket" class="course-img" loading="lazy" />
          </div>
          <div class="upsell-info">
            <h3 class="upsell-title">Negociação de Alto Ticket: O Poder do Rapport</h3>
            <p class="upsell-desc">Domine a conexão emocional para equilibrar sua racionalidade e fechar contratos maiores.</p>
          </div>
        </div>
        <a href="/app/detalhes" class="btn-upsell">ACESSAR MASTERCLASS</a>
      </div>
    </section>

  </div>
</AppLayout>

<style>
  .report-page {
    padding: 24px 16px 60px;
    max-width: 768px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
  }

  /* Header */
  .report-header {
    margin-bottom: 32px;
  }
  .report-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #4A4A4A;
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 200ms;
  }
  .report-back:hover { color: #C9A96E; }
  .report-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #F5F5F5;
  }

  /* Veredito Hero */
  .report-verdict {
    background-color: #0A0A0A;
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    margin-bottom: 40px;
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.05);
  }
  .verdict-subtitle {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: #C9A96E;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .verdict-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 16px;
    line-height: 1.1;
  }
  .verdict-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: #A0A0A0;
    max-width: 540px;
    margin: 0 auto;
  }

  /* Seções Gerais */
  .report-section {
    margin-bottom: 40px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #F5F5F5;
    margin-bottom: 24px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 12px;
  }

  /* Gráficos / Barras */
  .chart-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 24px;
  }
  .bar-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bar-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .bar-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #F5F5F5;
  }
  .bar-label-sub {
    font-weight: 400;
    color: #6A6A6A;
    font-size: 0.75rem;
    margin-left: 4px;
  }
  .bar-percent {
    font-size: 0.875rem;
    font-weight: 700;
    color: #A0A0A0;
  }
  .text-gold { color: #C9A96E; }
  .bar-track {
    width: 100%;
    height: 12px;
    background-color: rgba(255,255,255,0.05);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background-color: #4A4A4A;
    border-radius: 999px;
  }
  .bar-fill--highlight {
    background-color: #D4AF37;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.4);
  }

  /* Calibragem Grid */
  .calibragem-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .calibragem-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .calibragem-card {
    background-color: #050505;
    border: 1px solid rgba(255,255,255,0.03);
    border-radius: 12px;
    padding: 24px;
  }
  .calibragem-card__title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }
  .text-green { color: #C9A96E; } /* Using Gold as positive brand color */
  .text-red { color: #EF4444; }
  .calibragem-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .calibragem-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #A0A0A0;
  }
  .calibragem-list svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Upsell */
  .upsell-section {
    margin-top: 60px;
  }
  .upsell-card {
    background-color: #0A0A0A;
    border: 1px dashed rgba(212, 175, 55, 0.5);
    border-radius: 16px;
    padding: 24px;
    position: relative;
    overflow: hidden;
  }
  .upsell-subtitle {
    font-size: 0.75rem;
    font-weight: 600;
    color: #C9A96E;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }
  .upsell-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (min-width: 640px) {
    .upsell-content {
      flex-direction: row;
      align-items: center;
    }
  }
  .upsell-course-img {
    width: 100%;
    max-width: 160px;
    height: 90px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .course-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .upsell-info {
    flex-grow: 1;
  }
  .upsell-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 8px;
  }
  .upsell-desc {
    font-size: 0.875rem;
    color: #A0A0A0;
    line-height: 1.5;
  }
  .btn-upsell {
    display: block;
    width: 100%;
    background-color: #D4AF37;
    color: #000;
    padding: 16px 24px;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: background-color 200ms ease;
  }
  .btn-upsell:hover {
    background-color: #F5F5F5;
  }
</style>
