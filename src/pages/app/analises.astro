---
import AppLayout from '@/layouts/AppLayout.astro';
import { createServerClient } from '@supabase/ssr';

// ── 1. Cliente SSR isolado por request — zero context leak em Node.js ─────────
//    Cada request constrói seu próprio cliente lendo os cookies DESTA requisição.
//    Isso elimina o vazamento de estado entre requests concorrentes no Render/Node.
const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll: () => Astro.cookies.getAll().map(({ name, value }) => ({ name, value })),
      setAll: (toSet) => toSet.forEach(({ name, value, options }) => Astro.cookies.set(name, value, options)),
    },
  }
);

// ── 2. Sessão validada a partir dos cookies do request atual ──────────────────
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect('/auth/login');
}

// ── Helpers de tipo ───────────────────────────────────────────────────────────
type AssessmentStatus = 'done' | 'in_progress' | 'not_started';
interface CardState {
  status: AssessmentStatus;
  href:   string;
  action: string;
  badgeLabel: string;
}

/**
 * Resolve o status real do card aplicando prioridade A → B → C:
 *   A) Existe sessão COMPLETA (>= maxAnswers respostas)?  → done
 *   B) Existe sessão com > 0 respostas?                   → in_progress
 *   C) Nenhuma sessão ou todas vazias                     → not_started
 *
 * Isso ignora "ghost rows" (sessões criadas mas jamais respondidas)
 * que enganavam a query .limit(1) anterior.
 */
async function resolveAssessmentStatus(opts: {
  assessmentTable: string;
  answersTable:    string;
  maxAnswers:      number;
  reportPath:      string;
  questionPath:    string;
}): Promise<CardState> {
  const { assessmentTable, answersTable, maxAnswers, reportPath, questionPath } = opts;

  // Busca TODAS as sessões do usuário (ordenadas da mais recente para a mais antiga)
  const { data: sessions } = await supabase
    .from(assessmentTable)
    .select('id')
    .eq('user_id', user!.id)   // 🔒 anti-leak: sempre filtra pelo user logado
    .order('created_at', { ascending: false });

  if (!sessions || sessions.length === 0) {
    return { status: 'not_started', href: questionPath, action: 'Iniciar mapeamento →', badgeLabel: 'PENDENTE' };
  }

  // Para cada sessão, busca a contagem de respostas em paralelo
  const counts = await Promise.all(
    sessions.map(async (s) => {
      const { count } = await supabase
        .from(answersTable)
        .select('id', { count: 'exact', head: true })
        .eq('assessment_id', s.id);
      return { id: s.id, count: count ?? 0 };
    })
  );

  // A) Prioridade máxima: sessão COMPLETA (>= maxAnswers) — ignora ghost rows
  const completedSession = counts.find(c => c.count >= maxAnswers);
  if (completedSession) {
    return {
      status: 'done',
      href:   `${reportPath}?id=${completedSession.id}`,
      action: 'Ver resultado →',
      badgeLabel: 'CONCLUÍDO',
    };
  }

  // B) Sessão iniciada mas incompleta (> 0 respostas)
  const inProgressSession = counts.find(c => c.count > 0);
  if (inProgressSession) {
    return {
      status: 'in_progress',
      href:   questionPath,
      action: 'Continuar mapeamento →',
      badgeLabel: 'PENDENTE',
    };
  }

  // C) Só ghost rows (0 respostas em todas as sessões) ou nenhuma sessão
  return { status: 'not_started', href: questionPath, action: 'Iniciar mapeamento →', badgeLabel: 'PENDENTE' };
}

// ── 3. Resolve os 3 testes em paralelo ───────────────────────────────────────
const [egoCard, enneCard, discCard] = await Promise.all([
  resolveAssessmentStatus({
    assessmentTable: 'egogram_assessments',
    answersTable:    'egogram_answers',
    maxAnswers:      50,
    reportPath:      '/app/relatorio',
    questionPath:    '/app/pergunta',
  }),
  resolveAssessmentStatus({
    assessmentTable: 'enneagram_assessments',
    answersTable:    'enneagram_answers',
    maxAnswers:      45,
    reportPath:      '/app/eneagrama/relatorio',
    questionPath:    '/app/eneagrama/pergunta',
  }),
  resolveAssessmentStatus({
    assessmentTable: 'disc_assessments',
    answersTable:    'disc_answers',
    maxAnswers:      30,
    reportPath:      '/app/disc/relatorio',
    questionPath:    '/app/disc/pergunta',
  }),
]);
---

<AppLayout title="Central de Análises" activeNav="analises">
  <div class="analises-page">
    
    <!-- Header -->
    <div class="analises-header">
      <a href="/app/home" class="analises-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Voltar
      </a>
      <h1 class="analises-title">Central de Análises</h1>
    </div>

    <!-- Grid -->
    <div class="analises-grid">
      <!-- Egograma — status dinâmico -->
      <a href={egoCard.href} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">Egograma</h2>
          <span class={`status-badge ${egoCard.status === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {egoCard.badgeLabel}
          </span>
        </div>
        <p class="analise-card__desc">Mapeie seus estados de ego e entenda como você reage a conflitos internos e externos.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            15 min
          </div>
          <span class="analise-action">{egoCard.action}</span>
        </div>
      </a>

      <!-- Eneagrama -->
      <a href={enneCard.href} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">Eneagrama</h2>
          <span class={`status-badge ${enneCard.status === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {enneCard.badgeLabel}
          </span>
        </div>
        <p class="analise-card__desc">Descubra seu tipo de personalidade principal e seus padrões de motivação profunda.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            25 min
          </div>
          <span class="analise-action">{enneCard.action}</span>
        </div>
      </a>

      <!-- DISC -->
      <a href={discCard.href} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">DISC</h2>
          <span class={`status-badge ${discCard.status === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {discCard.badgeLabel}
          </span>
        </div>
        <p class="analise-card__desc">Identifique seu perfil comportamental predominante: Dominante, Influente, Estável ou Criterioso.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            15 min
          </div>
          <span class="analise-action">{discCard.action}</span>
        </div>
      </a>
    </div>

  </div>
</AppLayout>

<style>
  .analises-page {
    padding: 24px 16px 32px;
    max-width: 960px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
  }

  .analises-header {
    margin-bottom: 32px;
  }
  .analises-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #4A4A4A;
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 200ms;
  }
  .analises-back:hover { color: #C9A96E; }
  .analises-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #F5F5F5;
  }

  .analises-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .analises-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .analise-card {
    display: flex;
    flex-direction: column;
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    transition: border-color 300ms ease;
  }
  .analise-card:hover {
    border-color: rgba(212, 175, 55, 0.5);
  }

  .analise-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }
  .analise-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #F5F5F5;
  }

  .status-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    border-radius: 4px;
  }
  .status-badge--pending {
    background-color: #2A2A2A;
    color: #A0A0A0;
  }
  .status-badge--done {
    background-color: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
    border: 1px solid rgba(212, 175, 55, 0.2);
  }

  .analise-card__desc {
    font-size: 0.875rem;
    line-height: 1.5;
    color: #A0A0A0;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .analise-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 16px;
  }

  .analise-time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: #5A5A5A;
  }
  .analise-time svg {
    color: #C9A96E;
  }

  .analise-action {
    font-size: 0.75rem;
    font-weight: 500;
    color: #C9A96E;
    transition: color 200ms;
  }
  .analise-card:hover .analise-action {
    color: #F5F5F5;
  }
</style>
