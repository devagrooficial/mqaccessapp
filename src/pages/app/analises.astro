---
import AppLayout from '@/layouts/AppLayout.astro';

const supabase = Astro.locals.supabase;
const user     = Astro.locals.user;

// ── Busca o último assessment do usuário + contagem de respostas ─────────────
let egoStatus: 'done' | 'pending' = 'pending';
let egoHref   = '/app/pergunta';
let egoAction = 'Iniciar mapeamento →';
let egoAssessmentId: string | null = null;

if (user) {
  const { data: lastAssessment } = await supabase
    .from('egogram_assessments')
    .select('id')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();

  if (lastAssessment?.id) {
    egoAssessmentId = lastAssessment.id;

    // Conta quantas respostas este assessment tem
    const { count } = await supabase
      .from('egogram_answers')
      .select('id', { count: 'exact', head: true })
      .eq('assessment_id', lastAssessment.id);

    if ((count ?? 0) >= 50) {
      egoStatus = 'done';
      egoHref   = `/app/relatorio?id=${lastAssessment.id}`;
      egoAction = 'Ver resultado →';
    } else {
      egoHref   = '/app/pergunta';
      egoAction = 'Continuar mapeamento →';
    }
  }
}

// ── Status do Eneagrama ────────────────────────────────────────────────────────
let enneStatus: 'done' | 'pending' = 'pending';
let enneHref   = '/app/eneagrama/pergunta';
let enneAction = 'Iniciar mapeamento →';

if (user) {
  const { data: lastEnne } = await supabase
    .from('enneagram_assessments')
    .select('id')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();

  if (lastEnne?.id) {
    const { count: enneCount } = await supabase
      .from('enneagram_answers')
      .select('id', { count: 'exact', head: true })
      .eq('assessment_id', lastEnne.id);

    if ((enneCount ?? 0) >= 45) {
      enneStatus = 'done';
      enneHref   = `/app/eneagrama/relatorio?id=${lastEnne.id}`;
      enneAction = 'Ver resultado →';
    } else {
      enneHref   = '/app/eneagrama/pergunta';
      enneAction = 'Continuar mapeamento →';
    }
  }
}

// ── Status do DISC ───────────────────────────────────────────────────
let discStatus: 'done' | 'pending' = 'pending';
let discHref   = '/app/disc/pergunta';
let discAction = 'Iniciar mapeamento →';

if (user) {
  const { data: lastDisc } = await supabase
    .from('disc_assessments')
    .select('id')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();

  if (lastDisc?.id) {
    const { count: discCount } = await supabase
      .from('disc_answers')
      .select('id', { count: 'exact', head: true })
      .eq('assessment_id', lastDisc.id);

    if ((discCount ?? 0) >= 30) {
      discStatus = 'done';
      discHref   = `/app/disc/relatorio?id=${lastDisc.id}`;
      discAction = 'Ver resultado →';
    } else {
      discHref   = '/app/disc/pergunta';
      discAction = 'Continuar mapeamento →';
    }
  }
}
---

<AppLayout title="Central de Análises" activeNav="analises">
  <div class="analises-page">
    
    <!-- Header -->
    <div class="analises-header">
      <a href="/app/home" class="analises-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Voltar
      </a>
      <h1 class="analises-title">Central de Análises</h1>
    </div>

    <!-- Grid -->
    <div class="analises-grid">
      <!-- Egograma — status dinâmico -->
      <a href={egoHref} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">Egograma</h2>
          {egoStatus === 'done'
            ? <span class="status-badge status-badge--done">CONCLUÍDO</span>
            : <span class="status-badge status-badge--pending">PENDENTE</span>
          }
        </div>
        <p class="analise-card__desc">Mapeie seus estados de ego e entenda como você reage a conflitos internos e externos.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            15 min
          </div>
          <span class="analise-action">{egoAction}</span>
        </div>
      </a>

      <!-- Eneagrama -->
      <a href={enneHref} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">Eneagrama</h2>
          <span class={`status-badge ${enneStatus === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {enneStatus === 'done' ? 'CONCLUÍDO' : 'PENDENTE'}
          </span>
        </div>
        <p class="analise-card__desc">Descubra seu tipo de personalidade principal e seus padrões de motivação profunda.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            25 min
          </div>
          <span class="analise-action">{enneAction}</span>
        </div>
      </a>

      <!-- DISC -->
      <a href={discHref} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">DISC</h2>
          <span class={`status-badge ${discStatus === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {discStatus === 'done' ? 'CONCLUÍDO' : 'PENDENTE'}
          </span>
        </div>
        <p class="analise-card__desc">Identifique seu perfil comportamental predominante: Dominante, Influente, Estável ou Criterioso.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            15 min
          </div>
          <span class="analise-action">{discAction}</span>
        </div>
      </a>
    </div>

  </div>
</AppLayout>

<style>
  .analises-page {
    padding: 24px 16px 32px;
    max-width: 960px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
  }

  .analises-header {
    margin-bottom: 32px;
  }
  .analises-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #4A4A4A;
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 200ms;
  }
  .analises-back:hover { color: #C9A96E; }
  .analises-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #F5F5F5;
  }

  .analises-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .analises-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .analise-card {
    display: flex;
    flex-direction: column;
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    transition: border-color 300ms ease;
  }
  .analise-card:hover {
    border-color: rgba(212, 175, 55, 0.5);
  }

  .analise-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }
  .analise-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #F5F5F5;
  }

  .status-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    border-radius: 4px;
  }
  .status-badge--pending {
    background-color: #2A2A2A;
    color: #A0A0A0;
  }
  .status-badge--done {
    background-color: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
    border: 1px solid rgba(212, 175, 55, 0.2);
  }

  .analise-card__desc {
    font-size: 0.875rem;
    line-height: 1.5;
    color: #A0A0A0;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .analise-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 16px;
  }

  .analise-time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: #5A5A5A;
  }
  .analise-time svg {
    color: #C9A96E;
  }

  .analise-action {
    font-size: 0.75rem;
    font-weight: 500;
    color: #C9A96E;
    transition: color 200ms;
  }
  .analise-card:hover .analise-action {
    color: #F5F5F5;
  }
</style>
