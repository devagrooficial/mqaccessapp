---
import AppLayout from '@/layouts/AppLayout.astro';
import { createServerClient } from '@supabase/ssr';

// ── 1. Cliente SSR blindado por request — interface get/set/remove ─────────────
//    Usa a API de cookie individual (compatível com todos os adapters Astro/Render).
//    Cada request constrói seu próprio client — zero context leak em Node.js.
const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      get(key: string)                         { return Astro.cookies.get(key)?.value; },
      set(key: string, value: string, options) { Astro.cookies.set(key, value, options); },
      remove(key: string, options)             { Astro.cookies.delete(key, options); },
    },
  }
);

// ── 2. Validação de sessão — guarda contra authError E user nulo ───────────────
const { data: { user }, error: authError } = await supabase.auth.getUser();

if (authError || !user) {
  return Astro.redirect('/auth/login');
}

// ── Tipos ─────────────────────────────────────────────────────────────────────
type AssessmentStatus = 'done' | 'in_progress' | 'not_started';
interface CardState {
  status:     AssessmentStatus;
  href:       string;
  action:     string;
  badgeLabel: string;
}

// Estado padrão seguro — fallback silencioso em qualquer falha
const defaultCard = (questionPath: string): CardState => ({
  status:     'not_started',
  href:       questionPath,
  action:     'Iniciar mapeamento →',
  badgeLabel: 'PENDENTE',
});

/**
 * Resolve o status do card com prioridade A → B → C.
 * TOTALMENTE DEFENSIVO — nunca lança exceção, nunca causa HTTP 500.
 *
 *   A) Sessão COMPLETA (>= maxAnswers)  → done
 *   B) Sessão em andamento (> 0)        → in_progress
 *   C) Ghost rows / sem sessão          → not_started
 */
async function resolveAssessmentStatus(opts: {
  assessmentTable: string;
  answersTable:    string;
  maxAnswers:      number;
  reportPath:      string;
  questionPath:    string;
}): Promise<CardState> {
  const { assessmentTable, answersTable, maxAnswers, reportPath, questionPath } = opts;

  try {
    // Busca TODAS as sessões do usuário — nunca .limit(1) (evita ghost row bug)
    const { data: sessions, error: sessionsError } = await supabase
      .from(assessmentTable)
      .select('id')
      .eq('user_id', user!.id)   // 🔒 anti-leak: filtra estritamente pelo user logado
      .order('created_at', { ascending: false });

    if (sessionsError) {
      console.error(`[analises] Erro ao buscar ${assessmentTable}:`, sessionsError.message);
      return defaultCard(questionPath);
    }

    if (!sessions || sessions.length === 0) {
      return defaultCard(questionPath);
    }

    // Conta respostas de cada sessão em paralelo
    const counts = await Promise.all(
      sessions.map(async (s) => {
        const { count, error: countError } = await supabase
          .from(answersTable)
          .select('id', { count: 'exact', head: true })
          .eq('assessment_id', s.id);

        if (countError) {
          console.error(`[analises] Erro ao contar ${answersTable} (id=${s.id}):`, countError.message);
        }
        return { id: s.id, count: count ?? 0 };
      })
    );

    // A) Sessão COMPLETA — ignora ghost rows
    const completedSession = counts.find(c => c.count >= maxAnswers);
    if (completedSession) {
      return {
        status:     'done',
        href:       `${reportPath}?id=${completedSession.id}`,
        action:     'Ver resultado →',
        badgeLabel: 'CONCLUÍDO',
      };
    }

    // B) Sessão em andamento
    const inProgressSession = counts.find(c => c.count > 0);
    if (inProgressSession) {
      return {
        status:     'in_progress',
        href:       questionPath,
        action:     'Continuar mapeamento →',
        badgeLabel: 'PENDENTE',
      };
    }

    // C) Só ghost rows (0 respostas em todas) ou nenhuma sessão real
    return defaultCard(questionPath);

  } catch (err: any) {
    // Nunca deixa o SSR explodir — loga e retorna estado seguro
    console.error(`[analises] Exceção em resolveAssessmentStatus(${assessmentTable}):`, err?.message ?? err);
    return defaultCard(questionPath);
  }
}

// ── 3. Resolve os 3 testes em paralelo com fallback global ────────────────────
let egoCard:  CardState = defaultCard('/app/pergunta');
let enneCard: CardState = defaultCard('/app/eneagrama/pergunta');
let discCard: CardState = defaultCard('/app/disc/pergunta');

try {
  [egoCard, enneCard, discCard] = await Promise.all([
    resolveAssessmentStatus({
      assessmentTable: 'egogram_assessments',
      answersTable:    'egogram_answers',
      maxAnswers:      50,
      reportPath:      '/app/relatorio',
      questionPath:    '/app/pergunta',
    }),
    resolveAssessmentStatus({
      assessmentTable: 'enneagram_assessments',
      answersTable:    'enneagram_answers',
      maxAnswers:      45,
      reportPath:      '/app/eneagrama/relatorio',
      questionPath:    '/app/eneagrama/pergunta',
    }),
    resolveAssessmentStatus({
      assessmentTable: 'disc_assessments',
      answersTable:    'disc_answers',
      maxAnswers:      30,
      reportPath:      '/app/disc/relatorio',
      questionPath:    '/app/disc/pergunta',
    }),
  ]);
} catch (err: any) {
  console.error('[analises] Falha crítica no Promise.all — renderizando com fallback:', err?.message ?? err);
}
---

<AppLayout title="Central de Análises" activeNav="analises">
  <div class="analises-page">
    
    <!-- Header -->
    <div class="analises-header">
      <a href="/app/home" class="analises-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Voltar
      </a>
      <h1 class="analises-title">Central de Análises</h1>
    </div>

    <!-- Grid -->
    <div class="analises-grid">
      <!-- Egograma — status dinâmico -->
      <a href={egoCard.href} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">Egograma</h2>
          <span class={`status-badge ${egoCard.status === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {egoCard.badgeLabel}
          </span>
        </div>
        <p class="analise-card__desc">Mapeie seus estados de ego e entenda como você reage a conflitos internos e externos.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            15 min
          </div>
          <span class="analise-action">{egoCard.action}</span>
        </div>
      </a>

      <!-- Eneagrama -->
      <a href={enneCard.href} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">Eneagrama</h2>
          <span class={`status-badge ${enneCard.status === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {enneCard.badgeLabel}
          </span>
        </div>
        <p class="analise-card__desc">Descubra seu tipo de personalidade principal e seus padrões de motivação profunda.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            25 min
          </div>
          <span class="analise-action">{enneCard.action}</span>
        </div>
      </a>

      <!-- DISC -->
      <a href={discCard.href} class="analise-card">
        <div class="analise-card__header">
          <h2 class="analise-card__title">DISC</h2>
          <span class={`status-badge ${discCard.status === 'done' ? 'status-badge--done' : 'status-badge--pending'}`}>
            {discCard.badgeLabel}
          </span>
        </div>
        <p class="analise-card__desc">Identifique seu perfil comportamental predominante: Dominante, Influente, Estável ou Criterioso.</p>
        <div class="analise-card__footer">
          <div class="analise-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            15 min
          </div>
          <span class="analise-action">{discCard.action}</span>
        </div>
      </a>
    </div>

  </div>
</AppLayout>

<style>
  .analises-page {
    padding: 24px 16px 32px;
    max-width: 960px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
  }

  .analises-header {
    margin-bottom: 32px;
  }
  .analises-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #4A4A4A;
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 200ms;
  }
  .analises-back:hover { color: #C9A96E; }
  .analises-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #F5F5F5;
  }

  .analises-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .analises-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .analise-card {
    display: flex;
    flex-direction: column;
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    transition: border-color 300ms ease;
  }
  .analise-card:hover {
    border-color: rgba(212, 175, 55, 0.5);
  }

  .analise-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }
  .analise-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #F5F5F5;
  }

  .status-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    border-radius: 4px;
  }
  .status-badge--pending {
    background-color: #2A2A2A;
    color: #A0A0A0;
  }
  .status-badge--done {
    background-color: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
    border: 1px solid rgba(212, 175, 55, 0.2);
  }

  .analise-card__desc {
    font-size: 0.875rem;
    line-height: 1.5;
    color: #A0A0A0;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .analise-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 16px;
  }

  .analise-time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: #5A5A5A;
  }
  .analise-time svg {
    color: #C9A96E;
  }

  .analise-action {
    font-size: 0.75rem;
    font-weight: 500;
    color: #C9A96E;
    transition: color 200ms;
  }
  .analise-card:hover .analise-action {
    color: #F5F5F5;
  }
</style>
