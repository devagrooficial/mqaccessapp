---
import AppLayout from '@/layouts/AppLayout.astro';

const supabase = Astro.locals.supabase;
const user     = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const assessmentId = Astro.url.searchParams.get('id');
if (!assessmentId) return Astro.redirect('/app/analises');

// ── POST: reset de assessment sabotado ─────────────────────────────────────
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  if (fd.get('action') === 'reset_assessment') {
    await supabase.from('enneagram_assessments').delete()
      .eq('id', assessmentId).eq('user_id', user.id);
    return Astro.redirect('/app/eneagrama/pergunta');
  }
}

const { data: assessment, error: assessmentError } = await supabase
  .from('enneagram_assessments')
  .select('id, user_id, created_at')
  .eq('id', assessmentId).eq('user_id', user.id).single();

if (assessmentError || !assessment) return Astro.redirect('/app/analises');

// ── Busca respostas ─────────────────────────────────────────────────────────
const { data: answers } = await supabase
  .from('enneagram_answers')
  .select('enneatype, resposta')
  .eq('assessment_id', assessmentId);

const safeAnswers = answers ?? [];

// ── Trava de sabotagem ──────────────────────────────────────────────────────
const isSabotaged =
  safeAnswers.length === 45 &&
  safeAnswers.every(a => Number(a.resposta) === Number(safeAnswers[0].resposta));

// ── Motor de cálculo: agrupa por enneatype 1–9 ─────────────────────────────
const MAX_SCORE = 30; // 5 perguntas × valor máx 6
const totals: Record<number, number> = {};
for (let t = 1; t <= 9; t++) totals[t] = 0;

for (const row of safeAnswers) {
  const t = Number(row.enneatype);
  if (t >= 1 && t <= 9) totals[t] += Number(row.resposta ?? 0);
}

const pct = (v: number) => Math.round((v / MAX_SCORE) * 100);

const dimensions = Array.from({ length: 9 }, (_, i) => {
  const t = i + 1;
  return { tipo: t, score: totals[t], percent: pct(totals[t]) };
});

// Perfil predominante
const dominant = dimensions.reduce((a, b) => b.score > a.score ? b : a);

// ── Dicionário de perfis ────────────────────────────────────────────────────
const enneagramDict: Record<number, any> = {
  1: { nome: 'O Perfeccionista', vicio: 'Raiva', estresse: 4, seguranca: 7,
       resumo: 'Foco em excelência e disciplina. Risco de rigidez extrema e intolerância com erros.',
       detalhes: 'O Perfeccionista opera sob um forte senso interno de certo e errado. No ambiente corporativo, são pilares de ética e qualidade — os guardiões dos padrões. Sob pressão, porém, tendem a microgerenciar e criticar a equipe de forma desproporcional, bloqueando a velocidade de execução. O desenvolvimento executivo deste tipo passa por aprender que excelência e perfeição são objetivos distintos.' },
  2: { nome: 'O Prestativo', vicio: 'Orgulho', estresse: 8, seguranca: 4,
       resumo: 'Empatia e capacidade de motivar. Risco de esquecer próprias necessidades buscando aprovação.',
       detalhes: 'O Prestativo constrói redes de influência através da generosidade genuína. Em liderança, criam times extremamente leais e motivados. O risco executivo está na tendência de tomar decisões baseadas em aprovação, evitando feedbacks difíceis para não perder vínculos. O crescimento deste perfil exige a calibração entre cuidado com pessoas e clareza de resultados.' },
  3: { nome: 'O Bem-sucedido', vicio: 'Ganância/Ambição', estresse: 9, seguranca: 6,
       resumo: 'Foco em metas, resiliência e eficiência. Risco de competitividade tóxica e vaidade.',
       detalhes: 'O Bem-sucedido é o arquétipo do executor de alta performance — adaptável, magnético e orientado a resultados. No C-Level, são catalisadores de crescimento. O risco está na construção de uma persona de sucesso descolada da identidade real, levando à liderança superficial. A calibragem deste tipo exige autenticidade sobre performance.' },
  4: { nome: 'O Individualista', vicio: 'Inveja', estresse: 2, seguranca: 1,
       resumo: 'Criatividade e busca por originalidade. Risco de introspecção excessiva e melancolia.',
       detalhes: 'O Individualista traz profundidade criativa e visão única ao ambiente corporativo. São os inovadores que enxergam o que outros ignoram. O risco executivo está na instabilidade emocional e na tendência de sabotar oportunidades por sentir que o trabalho "não os representa". O desenvolvimento passa por ancorar a criatividade em processos e metas concretas.' },
  5: { nome: 'O Observador', vicio: 'Avareza', estresse: 7, seguranca: 8,
       resumo: 'Perfil analítico e estrategista. Risco de isolamento e frieza emocional sob pressão.',
       detalhes: 'O Observador é o estrategista silencioso — analítico, autossuficiente e com capacidade singular de síntese de informações complexas. Em posições de liderança, produzem planos de alta precisão. O ponto cego é a tendência ao isolamento e à retenção de conhecimento, o que fragiliza times e processos. O avanço executivo exige presença e compartilhamento ativo.' },
  6: { nome: 'O Questionador', vicio: 'Medo', estresse: 3, seguranca: 9,
       resumo: 'Cautela, lealdade e previsão de riscos. Risco de ansiedade paralisante e pessimismo.',
       detalhes: 'O Questionador é o gestor de risco natural da organização — leal, sistemático e extraordinariamente capaz de antecipar crises. Em equipes, criam estruturas sólidas e confiáveis. O limitador executivo é a paralisia analítica: a busca excessiva por segurança antes de agir pode custar janelas de oportunidade críticas. O desenvolvimento requer confiança na própria competência.' },
  7: { nome: 'O Otimista', vicio: 'Gula', estresse: 1, seguranca: 5,
       resumo: 'Proatividade, criatividade e adaptabilidade. Risco de dispersão e fuga de rotinas.',
       detalhes: 'O Otimista é o catalisador de energia e inovação — visionário, entusiasta e com capacidade única de transformar ambientes estagnados. Em liderança, são motores de cultura. O risco executivo está na dificuldade de manter foco em projetos de longa duração e na fuga de situações desconfortáveis via novas ideias. O crescimento exige disciplina de execução e tolerância ao desconforto.' },
  8: { nome: 'O Líder', vicio: 'Luxúria/Excesso', estresse: 5, seguranca: 2,
       resumo: 'Dinamismo, objetividade e liderança nata. Risco de autoritarismo e insensibilidade.',
       detalhes: 'O Líder é o arquétipo do executivo de comando — decisivo, protetor dos seus e com presença que domina ambientes. Em crises, são os primeiros a avançar. O ponto cego está na intensidade: a tendência à confrontação direta e ao excesso de controle pode intimidar talentos e criar culturas de medo. O desenvolvimento deste perfil passa pela inteligência emocional aplicada ao poder.' },
  9: { nome: 'O Mediador', vicio: 'Indolência', estresse: 6, seguranca: 3,
       resumo: 'Capacidade mediadora e agregadora. Risco de omissão, apatia e fuga de conflitos.',
       detalhes: 'O Mediador é o arquiteto da harmonia corporativa — empático, integrador e capaz de unir visões opostas em torno de um propósito comum. Em ambientes de alta tensão, são âncoras de equilíbrio. O risco executivo é a tendência à omissão: evitar conflitos necessários, postergar decisões difíceis e perder a própria agenda em prol da coletividade. O crescimento exige presença e assertividade estratégica.' },
};

const perfil          = enneagramDict[dominant.tipo];
const perfilEstresse  = enneagramDict[perfil.estresse];
const perfilSeguranca = enneagramDict[perfil.seguranca];

const completedDate = new Date(assessment.created_at).toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric',
});

// Radar chart: 9 pontos distribuídos em 360°
const chartData = dimensions.map(d => ({ label: String(d.tipo), value: d.percent }));

// ── Tríades: Motores de Inteligência (Centros do Eneagrama) ─────────────────
const motorExecucao  = Math.round(((totals[8] + totals[9] + totals[1]) / 90) * 100);
const motorConexao   = Math.round(((totals[2] + totals[3] + totals[4]) / 90) * 100);
const motorVisao     = Math.round(((totals[5] + totals[6] + totals[7]) / 90) * 100);

// ── DNA de Ação (Estilos Hornevianos) ───────────────────────────────────────
const dnaAssertivo   = Math.round(((totals[3] + totals[7] + totals[8]) / 90) * 100);
const dnaEstruturado = Math.round(((totals[1] + totals[2] + totals[6]) / 90) * 100);
const dnaEstrategista= Math.round(((totals[4] + totals[5] + totals[9]) / 90) * 100);

// ── Cross-sell: Recomendação de Livro ───────────────────────────────────────
const bookRecommendations: Record<number, string> = {
  1: '631ee11f-9835-463d-9259-1fcb505cb46d',
  2: '1015df84-c597-4b37-9d27-357a39d353d2',
  3: '631ee11f-9835-463d-9259-1fcb505cb46d',
  4: '1015df84-c597-4b37-9d27-357a39d353d2',
  5: '631ee11f-9835-463d-9259-1fcb505cb46d',
  6: '1015df84-c597-4b37-9d27-357a39d353d2',
  7: '1015df84-c597-4b37-9d27-357a39d353d2',
  8: '631ee11f-9835-463d-9259-1fcb505cb46d',
  9: '1015df84-c597-4b37-9d27-357a39d353d2',
};

const recommendedBookId = bookRecommendations[dominant.tipo];
const { data: recommendedBook } = await supabase
  .from('products')
  .select('id, title, cover_url')
  .eq('id', recommendedBookId)
  .maybeSingle();
---

<AppLayout
  title={isSabotaged ? 'Análise Inconclusiva — Eneagrama' : `Relatório: Tipo ${dominant.tipo} — ${perfil.nome}`}
  activeNav="analises"
>
  <div class="report-page">

    <!-- Header -->
    <div class="report-header">
      <a href="/app/analises" class="report-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Voltar às Análises
      </a>
      <div style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:8px;">
        <h1 class="report-title">Relatório: Eneagrama</h1>
        {completedDate && <span style="font-size:0.75rem; color:#4A4A4A;">{completedDate}</span>}
      </div>
    </div>

    {isSabotaged ? (
      <!-- Card Sabotagem -->
      <section class="sabotage-card">
        <div class="sabotage-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="1.5">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
        <p class="sabotage-label">ANÁLISE INCONCLUSIVA</p>
        <h2 class="sabotage-title">Padrão de Resposta Irreal Detectado</h2>
        <p class="sabotage-desc">
          Identificamos respostas com padrão estatisticamente improvável. Para gerar um perfil preciso,
          responda com sinceridade às situações propostas.
        </p>
        <div class="sabotage-cta">
          <form method="POST">
            <input type="hidden" name="action" value="reset_assessment" />
            <button type="submit" class="btn-reset">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              Refazer Mapeamento
            </button>
          </form>
          <a href="/app/analises" class="sabotage-cancel">Cancelar</a>
        </div>
      </section>
    ) : (
      <div class="report-body">

        <!-- Veredito -->
        <section class="report-verdict">
          <p class="verdict-eyebrow">TIPO {dominant.tipo} — PERFIL PREDOMINANTE</p>
          <h2 class="verdict-title">{perfil.nome}</h2>
          <p class="verdict-desc">{perfil.resumo}</p>

          <!-- Radar Chart SVG 9 eixos -->
          <div class="radar-wrap" aria-hidden="true">
            <svg class="radar-svg" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg">
              {[20,40,60,80,100].map(r => {
                const s = r * 0.95;
                const pts = chartData.map((_,i) => {
                  const a = (Math.PI*2/9)*i - Math.PI/2;
                  return `${120+Math.cos(a)*s},${120+Math.sin(a)*s}`;
                }).join(' ');
                return <polygon points={pts} fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>;
              })}
              {chartData.map((_,i) => {
                const a = (Math.PI*2/9)*i - Math.PI/2;
                return <line x1="120" y1="120" x2={120+Math.cos(a)*95} y2={120+Math.sin(a)*95} stroke="rgba(255,255,255,0.07)" stroke-width="1"/>;
              })}
              <polygon
                points={chartData.map((d,i) => {
                  const a = (Math.PI*2/9)*i - Math.PI/2;
                  const r = (d.value/100)*95;
                  return `${120+Math.cos(a)*r},${120+Math.sin(a)*r}`;
                }).join(' ')}
                fill="rgba(212,175,55,0.13)"
                stroke="#D4AF37"
                stroke-width="2"
              />
              {chartData.map((d,i) => {
                const a  = (Math.PI*2/9)*i - Math.PI/2;
                const r  = (d.value/100)*95;
                const lx = 120+Math.cos(a)*110;
                const ly = 120+Math.sin(a)*110;
                return (
                  <>
                    <circle cx={120+Math.cos(a)*r} cy={120+Math.sin(a)*r} r="4" fill="#D4AF37"/>
                    <text x={lx} y={ly} text-anchor="middle" dominant-baseline="middle" fill="#C9A96E" font-size="10" font-family="Inter,sans-serif" font-weight="700">{d.label}</text>
                  </>
                );
              })}
            </svg>
          </div>
        </section>

        <!-- Distribuição por tipo -->
        <section class="report-section">
          <h3 class="section-title">Distribuição por Tipo
            <span style="font-size:0.65rem; font-weight:400; color:#3A3A3A; margin-left:8px; text-transform:none; letter-spacing:0;">clique para expandir</span>
          </h3>
          <div class="chart-container">
            {dimensions.map(d => (
              <div class="bar-group bar-group--clickable" data-tipo={d.tipo} role="button" tabindex="0" aria-label={`Ver detalhes do Tipo ${d.tipo}`}>
                <div class="bar-header">
                  <span class="bar-label">Tipo {d.tipo} — {enneagramDict[d.tipo].nome}</span>
                  <span class="bar-pct">{d.percent}%</span>
                </div>
                <div class="bar-track">
                  <div
                    class={`bar-fill ${d.tipo === dominant.tipo ? 'bar-fill--dominant' : ''}`}
                    style={`width:${d.percent}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- ── Arquitetura Decisória ── -->
        <section class="report-section">
          <h3 class="section-title">Arquitetura Decisória</h3>
          <p class="section-sub">Centros de Inteligência que guiam suas decisões</p>
          <div class="motor-grid">

            <div class="motor-card">
              <div class="motor-header">
                <span class="motor-icon">⚡</span>
                <div>
                  <p class="motor-label">MOTOR DE EXECUÇÃO</p>
                  <p class="motor-name">Ação</p>
                </div>
                <span class="motor-pct">{motorExecucao}%</span>
              </div>
              <div class="motor-track">
                <div class="motor-fill motor-fill--gold" style={`width:${motorExecucao}%`}></div>
              </div>
              <p class="motor-sub">Foco em resultados, território e ordem.</p>
            </div>

            <div class="motor-card">
              <div class="motor-header">
                <span class="motor-icon">❤</span>
                <div>
                  <p class="motor-label">MOTOR DE CONEXÃO</p>
                  <p class="motor-name">Pessoas</p>
                </div>
                <span class="motor-pct">{motorConexao}%</span>
              </div>
              <div class="motor-track">
                <div class="motor-fill motor-fill--crimson" style={`width:${motorConexao}%`}></div>
              </div>
              <p class="motor-sub">Foco em networking, empatia e influência.</p>
            </div>

            <div class="motor-card">
              <div class="motor-header">
                <span class="motor-icon">◆</span>
                <div>
                  <p class="motor-label">MOTOR DE VISÃO</p>
                  <p class="motor-name">Estratégia</p>
                </div>
                <span class="motor-pct">{motorVisao}%</span>
              </div>
              <div class="motor-track">
                <div class="motor-fill motor-fill--violet" style={`width:${motorVisao}%`}></div>
              </div>
              <p class="motor-sub">Foco em dados, inovação e planejamento.</p>
            </div>

          </div>
        </section>

        <!-- ── DNA de Ação Corporativa ── -->
        <section class="report-section">
          <h3 class="section-title">DNA de Ação Corporativa</h3>
          <p class="section-sub">Estilos Hornevianos — padrão de movimento sob pressão</p>
          <div class="dna-list">

            <div class="dna-row">
              <div class="dna-row-header">
                <div>
                  <span class="dna-badge dna-badge--gold">ASSERTIVO</span>
                  <span class="dna-name">Perfil Expansivo (Lobo)</span>
                </div>
                <span class="dna-pct">{dnaAssertivo}%</span>
              </div>
              <div class="dna-track">
                <div class="dna-fill dna-fill--gold" style={`width:${dnaAssertivo}%`}></div>
              </div>
              <p class="dna-desc">Move-se contra os obstáculos para expandir e dominar o ambiente.</p>
            </div>

            <div class="dna-row">
              <div class="dna-row-header">
                <div>
                  <span class="dna-badge dna-badge--slate">ESTRUTURADO</span>
                  <span class="dna-name">Perfil Conformista (Cordeiro)</span>
                </div>
                <span class="dna-pct">{dnaEstruturado}%</span>
              </div>
              <div class="dna-track">
                <div class="dna-fill dna-fill--slate" style={`width:${dnaEstruturado}%`}></div>
              </div>
              <p class="dna-desc">Move-se com o sistema para garantir estabilidade e aprovação.</p>
            </div>

            <div class="dna-row">
              <div class="dna-row-header">
                <div>
                  <span class="dna-badge dna-badge--violet">ESTRATEGISTA</span>
                  <span class="dna-name">Perfil Observador (Estrategista)</span>
                </div>
                <span class="dna-pct">{dnaEstrategista}%</span>
              </div>
              <div class="dna-track">
                <div class="dna-fill dna-fill--violet" style={`width:${dnaEstrategista}%`}></div>
              </div>
              <p class="dna-desc">Move-se para longe do caos para analisar, planejar e agir com precisão.</p>
            </div>

          </div>
        </section>

        <!-- Dinâmica de Estresse e Segurança -->
        <section class="report-section">
          <h3 class="section-title">Dinâmica de Movimento</h3>
          <div class="movement-grid">
            <div class="movement-card movement-card--stress">
              <p class="movement-label">⚠ Sob Estresse</p>
              <p class="movement-type">Tipo {perfil.estresse}</p>
              <p class="movement-name">{perfilEstresse.nome}</p>
              <p class="movement-desc">Quando pressionado, você pode assumir os padrões negativos deste tipo.</p>
            </div>
            <div class="movement-card movement-card--security">
              <p class="movement-label">✦ Em Segurança</p>
              <p class="movement-type">Tipo {perfil.seguranca}</p>
              <p class="movement-name">{perfilSeguranca.nome}</p>
              <p class="movement-desc">Em ambientes de confiança, você expressa as qualidades mais elevadas deste tipo.</p>
            </div>
          </div>
        </section>

        <!-- Vício Central -->
        <section class="report-section">
          <h3 class="section-title">Padrão de Sombra</h3>
          <div class="shadow-card">
            <p class="shadow-label">VÍCIO CENTRAL</p>
            <p class="shadow-vicio">{perfil.vicio}</p>
            <p class="shadow-desc">
              O vício central é o padrão automático que emerge quando o Tipo {dominant.tipo} opera
              fora de sua zona de consciência. Reconhecê-lo é o primeiro passo para a calibragem executiva.
            </p>
          </div>
        </section>

        <!-- Recomendação de Leitura -->
        {recommendedBook && (
          <section class="report-section">
            <h3 class="section-title">Recomendação de Leitura — {perfil.nome}</h3>
            <div class="book-card">
              <div class="book-cover-wrap">
                {recommendedBook.cover_url
                  ? <img src={recommendedBook.cover_url} alt={recommendedBook.title} class="book-cover" />
                  : <div class="book-cover-placeholder"><span>MQ</span></div>
                }
              </div>
              <div class="book-info">
                <p class="book-eyebrow">LEITURA RECOMENDADA</p>
                <p class="book-title">{recommendedBook.title}</p>
                <p class="book-desc">A leitura certa para o estágio de desenvolvimento do Tipo {dominant.tipo}. Cada página foi calibrada para ampliar sua consciência executiva.</p>
                <a
                  href={`/app/detalhes?id=${recommendedBook.id}`}
                  class="book-cta"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  ADQUIRIR LIVRO FÍSICO
                </a>
              </div>
            </div>
          </section>
        )}

      </div>
    )}

  </div>
</AppLayout>

<!-- ── Modal Deep Dive ── -->
<div id="type-modal" style="display:none;" class="modal-overlay">
  <div class="modal-card">
    <button id="close-modal" class="modal-close" aria-label="Fechar">✕</button>
    <p id="modal-eyebrow" class="modal-eyebrow"></p>
    <h3 id="modal-title" class="modal-title"></h3>
    <p id="modal-desc" class="modal-desc"></p>
  </div>
</div>

<script define:vars={{ dict: enneagramDict }}>
  var modal     = document.getElementById('type-modal');
  var mEyebrow  = document.getElementById('modal-eyebrow');
  var mTitle    = document.getElementById('modal-title');
  var mDesc     = document.getElementById('modal-desc');
  var closeBtn  = document.getElementById('close-modal');

  function openModal(tipo) {
    var entry = dict[Number(tipo)];
    if (!entry || !modal) return;
    mEyebrow.textContent = 'TIPO ' + tipo + ' — ANÁLISE EXECUTIVA';
    mTitle.textContent   = entry.nome;
    mDesc.textContent    = entry.detalhes || entry.resumo;
    modal.style.display  = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.bar-group--clickable').forEach(function(row) {
    row.addEventListener('click', function() { openModal(row.dataset.tipo); });
    row.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') openModal(row.dataset.tipo); });
  });

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (modal)    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
</script>

