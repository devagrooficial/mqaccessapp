---
import AppLayout from '@/layouts/AppLayout.astro';
import { supabase } from '@/lib/supabase';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

// ── INTERCEPTAÇÃO DO FORMULÁRIO VIA SSR (POST) ──────────────────────────────
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();

    // Coleta todas as respostas do formulário
    // Cada campo tem o nome "answer_[question_id]_[tipo]" e valor 0-3
    const entries = [...formData.entries()];
    const answers: { question_id: string; tipo: string; resposta: number }[] = [];

    for (const [key, value] of entries) {
      if (key.startsWith('answer_')) {
        // Formato: answer_[uuid]_[tipo]
        const parts = key.split('_');
        // UUID tem 5 partes separadas por hífens — tipo é o último segmento
        // key: answer_{uuid}_{tipo}  → parts: ['answer', ...uuidParts, tipo]
        const tipo = parts[parts.length - 1];
        // Reconstrói o uuid removendo 'answer_' e '_tipo' do final
        const withoutPrefix = key.slice('answer_'.length);
        const question_id = withoutPrefix.slice(0, withoutPrefix.lastIndexOf('_'));
        answers.push({ question_id, tipo, resposta: parseInt(value.toString(), 10) });
      }
    }

    if (answers.length === 0) throw new Error('Nenhuma resposta recebida.');

    // 1. Cria o registro do assessment
    const { data: assessment, error: assessmentError } = await supabase
      .from('egogram_assessments')
      .insert({ user_id: user.id, status: 'completed', completed_at: new Date().toISOString() })
      .select('id')
      .single();

    if (assessmentError || !assessment) throw new Error(assessmentError?.message ?? 'Erro ao criar avaliação.');

    // 2. Bulk insert das respostas vinculadas ao assessment
    const answersPayload = answers.map((a) => ({
      assessment_id: assessment.id,
      question_id: a.question_id,
      tipo: a.tipo,
      resposta: a.resposta,
    }));

    const { error: answersError } = await supabase
      .from('egogram_answers')
      .insert(answersPayload);

    if (answersError) throw new Error(answersError.message);

    // 3. Redireciona para o resultado
    return Astro.redirect(`/app/egograma/resultado?id=${assessment.id}`);
  } catch (err: any) {
    console.error('[EGOGRAMA] Erro no POST:', err.message);
  }
}

// ── BUSCA DAS PERGUNTAS (GET) ────────────────────────────────────────────────
const { data: questions, error: questionsError } = await supabase
  .from('egogram_questions')
  .select('id, texto, tipo, sequencia')
  .order('sequencia', { ascending: true });

if (questionsError || !questions) {
  console.error('[EGOGRAMA] Erro ao buscar perguntas:', questionsError?.message);
}

const totalQuestions = questions?.length ?? 0;
---

<AppLayout title="Egograma — Mapeamento dos Estados de Ego" activeNav="home">
  <div class="ego-page">

    <!-- Header -->
    <header class="ego-header">
      <a href="/app/analise-detalhes" class="ego-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Voltar
      </a>
      <div class="ego-header__meta">
        <span class="ego-badge">EGOGRAMA</span>
        <span class="ego-header__count">{totalQuestions} questões · ~15 min</span>
      </div>
    </header>

    <!-- Hero -->
    <section class="ego-hero">
      <div class="ego-hero__icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="1.5">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          <path d="M16 3.5C17.5 4.5 18 6 18 8"/>
          <path d="M8 3.5C6.5 4.5 6 6 6 8"/>
        </svg>
      </div>
      <h1 class="ego-hero__title">Mapeamento dos Estados de Ego</h1>
      <p class="ego-hero__desc">
        Responda com honestidade. Não há respostas certas ou erradas — cada resposta
        revela como você realmente opera nas relações de alta performance.
      </p>
      <div class="ego-scale-legend">
        <span>Nunca</span>
        <span>Às vezes</span>
        <span>Frequentemente</span>
        <span>Sempre</span>
      </div>
    </section>

    <!-- Formulário -->
    {questions && questions.length > 0 ? (
      <form id="ego-form" method="POST" class="ego-form">

        {questions.map((q, index) => (
          <div class="ego-question" id={`q-${q.sequencia}`}>
            <div class="ego-question__header">
              <span class="ego-question__num">{String(index + 1).padStart(2, '0')}</span>
              <p class="ego-question__text">{q.texto}</p>
            </div>

            <div class="ego-options" role="radiogroup" aria-label={`Pergunta ${index + 1}`}>
              {[
                { label: 'Nunca',          value: 0 },
                { label: 'Às vezes',       value: 1 },
                { label: 'Frequentemente', value: 2 },
                { label: 'Sempre',         value: 3 },
              ].map((opt) => (
                <label class="ego-option">
                  <input
                    type="radio"
                    name={`answer_${q.id}_${q.tipo}`}
                    value={opt.value}
                    required
                    class="ego-option__input"
                  />
                  <span class="ego-option__btn">{opt.label}</span>
                </label>
              ))}
            </div>
          </div>
        ))}

        <!-- Progress bar -->
        <div class="ego-progress-wrap">
          <div class="ego-progress-bar">
            <div class="ego-progress-fill" id="progress-fill" style="width: 0%"></div>
          </div>
          <span class="ego-progress-label">
            <span id="progress-answered">0</span> / {totalQuestions} respondidas
          </span>
        </div>

        <!-- Submit -->
        <div class="ego-submit-wrap">
          <button type="submit" class="ego-submit" id="ego-submit-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            Concluir Avaliação
          </button>
          <p class="ego-submit__hint">Certifique-se de responder todas as questões antes de enviar.</p>
        </div>
      </form>
    ) : (
      <div class="ego-empty">
        <p>Nenhuma questão encontrada. Verifique o banco de dados.</p>
      </div>
    )}

  </div>
</AppLayout>

<script>
  // Progresso em tempo real conforme o usuário responde
  const form = document.getElementById('ego-form') as HTMLFormElement | null;
  const fill = document.getElementById('progress-fill') as HTMLElement | null;
  const answeredLabel = document.getElementById('progress-answered') as HTMLElement | null;
  const submitBtn = document.getElementById('ego-submit-btn') as HTMLButtonElement | null;

  if (form) {
    const groups = new Map<string, boolean>();
    const radios = form.querySelectorAll<HTMLInputElement>('input[type="radio"]');

    // Inicializa grupos
    radios.forEach((r) => { if (!groups.has(r.name)) groups.set(r.name, false); });
    const total = groups.size;

    const update = () => {
      // Atualiza grupos respondidos
      radios.forEach((r) => { if (r.checked) groups.set(r.name, true); });
      const answered = [...groups.values()].filter(Boolean).length;
      const pct = total > 0 ? (answered / total) * 100 : 0;
      if (fill) fill.style.width = `${pct}%`;
      if (answeredLabel) answeredLabel.textContent = String(answered);

      // Habilita submit apenas se tudo respondido
      if (submitBtn) submitBtn.disabled = answered < total;
    };

    radios.forEach((r) => r.addEventListener('change', update));

    // Loading state no submit
    form.addEventListener('submit', () => {
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Calculando resultado…';
      }
    });

    update();
  }

  // Destaca a pergunta ao selecionar resposta
  document.querySelectorAll<HTMLLabelElement>('.ego-option').forEach((label) => {
    const input = label.querySelector('input');
    if (!input) return;
    input.addEventListener('change', () => {
      // Remove active de irmãos
      label.closest('.ego-options')?.querySelectorAll('.ego-option').forEach((l) => {
        l.classList.remove('ego-option--selected');
      });
      label.classList.add('ego-option--selected');

      // Scroll suave para a próxima pergunta
      const currentQ = label.closest('.ego-question');
      const nextQ = currentQ?.nextElementSibling;
      if (nextQ && nextQ.classList.contains('ego-question')) {
        setTimeout(() => {
          nextQ.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 150);
      }
    });
  });
</script>

<style>
  .ego-page {
    padding: 24px 16px 60px;
    max-width: 720px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
  }

  /* ── Header ── */
  .ego-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 40px;
  }
  .ego-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #4A4A4A;
    text-decoration: none;
    transition: color 200ms ease;
  }
  .ego-back:hover { color: #D4AF37; }
  .ego-header__meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ego-badge {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 4px 10px;
    border-radius: 4px;
    background: rgba(212, 175, 55, 0.08);
    border: 1px solid rgba(212, 175, 55, 0.2);
    color: #D4AF37;
  }
  .ego-header__count {
    font-size: 0.75rem;
    color: #4A4A4A;
  }

  /* ── Hero ── */
  .ego-hero {
    text-align: center;
    margin-bottom: 56px;
  }
  .ego-hero__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(212, 175, 55, 0.06);
    border: 1px solid rgba(212, 175, 55, 0.15);
    margin-bottom: 24px;
  }
  .ego-hero__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    color: #F5F5F5;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .ego-hero__desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #A0A0A0;
    max-width: 560px;
    margin: 0 auto 28px;
  }
  .ego-scale-legend {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .ego-scale-legend span {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #4A4A4A;
    padding: 4px 10px;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
  }

  /* ── Questão ── */
  .ego-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .ego-question {
    padding: 32px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .ego-question:last-of-type {
    border-bottom: none;
  }
  .ego-question__header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 20px;
  }
  .ego-question__num {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #D4AF37;
    opacity: 0.5;
    flex-shrink: 0;
    padding-top: 3px;
  }
  .ego-question__text {
    font-size: 1rem;
    line-height: 1.55;
    color: #F5F5F5;
    font-weight: 400;
  }

  /* ── Opções de Rádio (botões premium) ── */
  .ego-options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  @media (min-width: 480px) {
    .ego-options { grid-template-columns: repeat(4, 1fr); }
  }

  .ego-option {
    cursor: pointer;
  }
  .ego-option__input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  .ego-option__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 8px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.07);
    background-color: #0A0A0A;
    color: #A0A0A0;
    font-size: 0.8125rem;
    font-weight: 500;
    text-align: center;
    transition: border-color 200ms ease, background-color 200ms ease, color 200ms ease;
    user-select: none;
  }
  .ego-option:hover .ego-option__btn {
    border-color: rgba(212,175,55,0.25);
    color: #F5F5F5;
  }
  .ego-option__input:checked + .ego-option__btn,
  .ego-option--selected .ego-option__btn {
    background-color: rgba(212, 175, 55, 0.1);
    border-color: #D4AF37;
    color: #D4AF37;
    font-weight: 600;
  }

  /* ── Barra de Progresso ── */
  .ego-progress-wrap {
    padding: 32px 0 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ego-progress-bar {
    width: 100%;
    height: 2px;
    background-color: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
  }
  .ego-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #8C6D3F, #D4AF37);
    border-radius: 2px;
    transition: width 300ms ease;
  }
  .ego-progress-label {
    font-size: 0.75rem;
    color: #4A4A4A;
    text-align: right;
  }

  /* ── Submit ── */
  .ego-submit-wrap {
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .ego-submit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 40px;
    background-color: #D4AF37;
    color: #000;
    border: none;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background-color 200ms ease;
  }
  .ego-submit:hover:not(:disabled) { background-color: #E8D5A3; }
  .ego-submit:disabled {
    background-color: #1A1A1A;
    color: #4A4A4A;
    cursor: not-allowed;
  }
  .ego-submit__hint {
    font-size: 0.75rem;
    color: #4A4A4A;
    text-align: center;
  }

  /* ── Empty State ── */
  .ego-empty {
    text-align: center;
    padding: 80px 0;
    color: #4A4A4A;
    font-size: 0.875rem;
  }
</style>
