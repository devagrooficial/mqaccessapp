---
import AppLayout from '@/layouts/AppLayout.astro';
---

<AppLayout title="Minhas Compras">
  <div class="lib-wrap" x-data="{ tab: 'digital' }">
    <div class="lib-page-header">
      <h1 class="lib-page-title">Minha Biblioteca</h1>
      <p class="lib-page-sub">Seus ativos de alto desempenho</p>
    </div>

    <div class="lib-tabbar" role="tablist">
      <button class="lib-tab" :class="tab==='digital' && 'lib-tab--active'" @click="tab='digital'">DIGITAL</button>
      <button class="lib-tab" :class="tab==='eventos' && 'lib-tab--active'" @click="tab='eventos'">EVENTOS</button>
      <button class="lib-tab" :class="tab==='livros'  && 'lib-tab--active'" @click="tab='livros'">LIVROS</button>
    </div>

    <!-- DIGITAL -->
    <div x-show="tab==='digital'" x-transition class="lib-grid">
      <a href="/app/player" class="lib-card card-reveal">
        <div class="lib-thumb lib-thumb--a">
          <img src="/protocolo-clevel-thumb.png" alt="Protocolo C-Level" class="lib-thumb-img" loading="lazy" />
          <svg class="lib-play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <div class="lib-prog-bar"><div class="lib-prog-fill" style="width:75%"></div></div>
          <span class="lib-prog-label">75%</span>
        </div>
        <div class="lib-body">
          <p class="lib-tag">MASTERCLASS</p>
          <h2 class="lib-title">Protocolo C-Level: A Arquitetura da Decisão</h2>
          <p class="lib-meta">6h 20min · 18 aulas</p>
        </div>
      </a>
      <a href="/app/player" class="lib-card card-reveal">
        <div class="lib-thumb lib-thumb--b">
          <img src="/negociacao-alto-ticket-thumb.png" alt="Negociação de Alto Ticket" class="lib-thumb-img" loading="lazy" />
          <svg class="lib-play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <div class="lib-prog-bar"><div class="lib-prog-fill" style="width:12%"></div></div>
          <span class="lib-prog-label">12%</span>
        </div>
        <div class="lib-body">
          <p class="lib-tag">MÓDULO BÔNUS</p>
          <h2 class="lib-title">Negociação de Alto Ticket: O Poder do Rapport</h2>
          <p class="lib-meta">2h 45min · 9 aulas</p>
        </div>
      </a>
      <a href="/app/player" class="lib-card card-reveal">
        <div class="lib-thumb lib-thumb--c">
          <img src="/escala-exponencial-thumb.png" alt="Escala Exponencial" class="lib-thumb-img" loading="lazy" />
          <svg class="lib-play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span class="lib-badge-new">NOVO</span>
          <div class="lib-prog-bar"><div class="lib-prog-fill" style="width:0%"></div></div>
          <span class="lib-prog-label">Não iniciado</span>
        </div>
        <div class="lib-body">
          <p class="lib-tag">INTENSIVO</p>
          <h2 class="lib-title">Escala Exponencial para Software Houses</h2>
          <p class="lib-meta">4h 10min · 14 aulas</p>
        </div>
      </a>
    </div>

    <!-- EVENTOS -->
    <div x-show="tab==='eventos'" x-transition class="lib-grid">
      <div class="lib-card lib-event card-reveal">
        <div class="lib-event-head">
          <p class="lib-tag lib-tag--gold">15 AGO 2026</p>
          <span class="lib-badge-confirmed">CONFIRMADO</span>
        </div>
        <h2 class="lib-title lib-title--lg">Summit MQ · São Paulo</h2>
        <p class="lib-venue">Grand Hyatt · Av. das Nações Unidas, 13.301</p>
        <div class="lib-qr-row">
          <div class="lib-qr">
            <div class="lib-qr-c lib-qr-c--tl"></div>
            <div class="lib-qr-c lib-qr-c--tr"></div>
            <div class="lib-qr-c lib-qr-c--bl"></div>
            <div class="lib-qr-dots"></div>
          </div>
          <div>
            <p class="lib-qr-label">INGRESSO VIP</p>
            <p class="lib-qr-name">Mario Quirino</p>
            <p class="lib-qr-code">#MQ-2026-0041</p>
          </div>
        </div>
        <a href="/app/ingresso" class="lib-event-btn" style="display:flex;align-items:center;justify-content:center;text-decoration:none;">Ver Ingresso Completo</a>
      </div>
    </div>

    <!-- LIVROS -->
    <div x-show="tab==='livros'" x-transition class="lib-grid lib-grid--books">
      <div class="lib-card lib-book-card card-reveal">
        <div class="lib-book-cover">
          <div class="lib-book-spine"></div>
          <div class="lib-book-front">
            <p class="lib-book-author">MARIO QUIRINO</p>
            <h3 class="lib-book-name">A Engenharia do Networking</h3>
            <span class="lib-book-badge">1ª EDIÇÃO</span>
          </div>
        </div>
        <div class="lib-body">
          <span class="lib-status-transit">→ Em transporte</span>
          <h2 class="lib-title">A Engenharia do Networking</h2>
          <p class="lib-meta">Previsão: 3–5 dias úteis</p>
          <a href="/app/rastreio-livro" class="lib-track">Rastrear pedido →</a>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

<style>
  .lib-wrap { padding: 0 0 100px; }
  .lib-page-header { padding: 28px 20px 0; }
  .lib-page-title { font-family:'Playfair Display',serif; font-size:1.75rem; font-weight:700; color:#F5F5F5; margin-bottom:4px; }
  .lib-page-sub { font-size:.8125rem; color:#3A3A3A; }

  .lib-tabbar { display:flex; border-bottom:1px solid rgba(255,255,255,0.06); padding:20px 20px 0; margin-bottom:28px; }
  .lib-tab { background:none; border:none; cursor:pointer; font-family:'Inter',sans-serif; font-size:.625rem; font-weight:700; letter-spacing:.14em; color:#3A3A3A; padding:0 0 12px; margin-right:28px; border-bottom:2px solid transparent; transition:color 200ms,border-color 200ms; position:relative; bottom:-1px; }
  .lib-tab--active { color:#F5F5F5; border-bottom-color:#C9A96E; }

  .lib-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; padding:0 20px; }
  .lib-grid--books { grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); }

  .lib-card { background:#0A0A0A; border:1px solid rgba(255,255,255,0.05); border-radius:14px; overflow:hidden; text-decoration:none; display:flex; flex-direction:column; transition:border-color 300ms,transform 250ms; }
  .lib-card:hover { border-color:rgba(201,169,110,0.2); transform:translateY(-2px); }

  .lib-thumb { position:relative; aspect-ratio:16/9; display:flex; align-items:center; justify-content:center; overflow:hidden; background:#060606; }
  .lib-thumb--a { background:linear-gradient(140deg,#0D0B09,#1A1510); }
  .lib-thumb--b { background:linear-gradient(140deg,#08100D,#0F1E18); }
  .lib-thumb--c { background:linear-gradient(140deg,#080A10,#10131E); }
  .lib-thumb-img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center; filter:brightness(0.4) saturate(0.6); transition:filter 350ms ease; }
  .lib-card:hover .lib-thumb-img { filter:brightness(0.55) saturate(0.7); }
  .lib-play { color:rgba(201,169,110,0.5); }
  .lib-badge-new { position:absolute; top:10px; right:10px; font-size:.55rem; font-weight:700; letter-spacing:.12em; background:#C9A96E; color:#000; padding:3px 7px; border-radius:4px; }
  .lib-prog-bar { position:absolute; bottom:0; left:0; right:0; height:2px; background:rgba(255,255,255,0.06); }
  .lib-prog-fill { height:100%; background:#C9A96E; }
  .lib-prog-label { position:absolute; bottom:6px; left:12px; font-size:.6rem; color:rgba(255,255,255,0.35); }

  .lib-body { padding:14px 16px 16px; }
  .lib-tag { font-size:.55rem; font-weight:700; letter-spacing:.14em; color:#3A3A3A; margin-bottom:6px; }
  .lib-tag--gold { color:#C9A96E; }
  .lib-title { font-family:'Playfair Display',serif; font-size:1rem; font-weight:700; color:#E0E0E0; margin-bottom:5px; line-height:1.3; }
  .lib-title--lg { font-size:1.25rem; }
  .lib-meta { font-size:.75rem; color:#3A3A3A; }

  /* Event */
  .lib-event { padding:20px; cursor:default; }
  .lib-event-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
  .lib-badge-confirmed { font-size:.55rem; font-weight:700; letter-spacing:.1em; background:rgba(34,197,94,.1); color:#22c55e; border:1px solid rgba(34,197,94,.2); padding:3px 8px; border-radius:20px; }
  .lib-venue { font-size:.75rem; color:#3A3A3A; margin-bottom:18px; }
  .lib-qr-row { display:flex; gap:14px; align-items:center; margin-bottom:18px; }
  .lib-qr { width:64px; height:64px; border:1px solid rgba(255,255,255,0.08); border-radius:6px; background:#0D0D0D; padding:6px; position:relative; flex-shrink:0; }
  .lib-qr-c { position:absolute; width:14px; height:14px; border:2px solid #C9A96E; }
  .lib-qr-c--tl { top:4px; left:4px; border-right:none; border-bottom:none; }
  .lib-qr-c--tr { top:4px; right:4px; border-left:none; border-bottom:none; }
  .lib-qr-c--bl { bottom:4px; left:4px; border-right:none; border-top:none; }
  .lib-qr-dots { position:absolute; inset:5px; background-image:radial-gradient(circle,rgba(201,169,110,.3) 1px,transparent 1px); background-size:4px 4px; }
  .lib-qr-label { font-size:.55rem; font-weight:700; letter-spacing:.12em; color:#C9A96E; margin-bottom:3px; }
  .lib-qr-name  { font-size:.8125rem; font-weight:600; color:#E0E0E0; margin-bottom:2px; }
  .lib-qr-code  { font-size:.65rem; color:#3A3A3A; font-family:monospace; }
  .lib-event-btn { width:100%; height:40px; background:transparent; border:1px solid rgba(201,169,110,.2); color:#C9A96E; font-family:'Inter',sans-serif; font-size:.75rem; font-weight:600; letter-spacing:.08em; border-radius:8px; cursor:pointer; transition:background 200ms,border-color 200ms; }
  .lib-event-btn:hover { background:rgba(201,169,110,.06); border-color:#C9A96E; }

  /* Book */
  .lib-book-card { flex-direction:row; }
  .lib-book-cover { width:90px; flex-shrink:0; display:flex; background:#0D0B08; }
  .lib-book-spine { width:18px; background:linear-gradient(180deg,#C9A96E,#8C6D3F); flex-shrink:0; }
  .lib-book-front { flex:1; padding:12px 8px; display:flex; flex-direction:column; justify-content:flex-end; }
  .lib-book-author { font-size:.45rem; letter-spacing:.1em; color:#C9A96E; margin-bottom:3px; }
  .lib-book-name   { font-family:'Playfair Display',serif; font-size:.65rem; font-weight:700; color:#E0E0E0; line-height:1.3; margin-bottom:5px; }
  .lib-book-badge  { font-size:.4rem; font-weight:700; letter-spacing:.1em; background:rgba(201,169,110,.1); color:#C9A96E; border:1px solid rgba(201,169,110,.2); padding:2px 5px; border-radius:3px; display:inline-block; }
  .lib-status-transit { display:inline-flex; align-items:center; gap:5px; font-size:.6rem; font-weight:600; letter-spacing:.08em; background:rgba(234,179,8,.1); color:#eab308; border:1px solid rgba(234,179,8,.2); padding:3px 8px; border-radius:20px; margin-bottom:8px; }
  .lib-track { display:block; font-size:.75rem; color:#C9A96E; text-decoration:none; margin-top:8px; }
</style>
