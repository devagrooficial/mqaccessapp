---
import AppLayout from '@/layouts/AppLayout.astro';

const user     = Astro.locals.user;
const supabase = Astro.locals.supabase; // ← SSR client com cookies (passa no RLS)

let userName = "Carregando...";
let userEmail = user?.email || "";
let avatarInitials = "MQ";

if (user) {
  // Busca o nome na tabela profiles
  const { data: profile } = await supabase
    .from('profiles')
    .select('full_name')
    .eq('id', user.id)
    .single();

  if (profile?.full_name) {
    userName = profile.full_name;
    // Pega a primeira letra do primeiro e último nome
    const nameParts = userName.trim().split(' ');
    if (nameParts.length >= 2) {
      avatarInitials = (nameParts[0][0] + nameParts[nameParts.length - 1][0]).toUpperCase();
    } else {
      avatarInitials = userName.substring(0, 2).toUpperCase();
    }
  } else {
    userName = "Usuário MQ";
    avatarInitials = userEmail.substring(0, 2).toUpperCase();
  }
}

const menuItems = [
  { label: 'Editar Perfil',      href: '/app/editar-perfil' },
  { label: 'Minhas Anotações',  href: '/app/anotacoes' },
  { label: 'Favoritos',         href: '/app/favoritos' },
  { label: 'Notificações',      href: '/app/notificacoes' },
  { label: 'Link de Afiliação', href: '#', badge: 'AGUARDE', disabled: true },
  { label: 'Termos de Uso',     href: '/termos' },
  { label: 'Ajuda',             href: '/ajuda' },
  { label: 'Suporte',           href: '/suporte' },
];
---

<AppLayout title="Perfil" activeNav="perfil">
  <div class="perfil-page">

    <!-- Header do perfil -->
    <div class="perfil-header">
      <div class="perfil-avatar">
        <span class="perfil-avatar__initials">{avatarInitials}</span>
      </div>
      <div class="perfil-identity">
        <h1 class="perfil-name">{userName}</h1>
        <p class="perfil-email">{userEmail}</p>
        <span class="badge-gold">Membro PRO</span>
      </div>
    </div>

    <!-- Menu de Navegação -->
    <nav class="flex flex-col mt-4">
      {menuItems.map((item, index) => {
        const isLast     = index === menuItems.length - 1;
        const borderCls  = !isLast ? 'border-b border-white/5' : '';

        // ── Item desativado (em breve) ─────────────────────────────────────────
        if (item.disabled) return (
          <div class={`flex justify-between items-center py-4 opacity-50 cursor-not-allowed pointer-events-none select-none ${borderCls}`}>
            <div class="flex items-center gap-2">
              <span class="font-sans text-sm text-white/50">{item.label}</span>
              {item.badge && (
                <span class="border border-neutral-600 text-neutral-400 bg-neutral-800/50 text-[10px] uppercase px-2 py-0.5 rounded">
                  {item.badge}
                </span>
              )}
            </div>
            {/* Sem seta — reforça que não há ação */}
          </div>
        );

        // ── Item ativo normal ────────────────────────────────────────────────────
        return (
          <a
            href={item.href}
            class={`flex justify-between items-center py-4 text-white/80 hover:text-white transition-colors ${borderCls}`}
          >
            <div class="flex items-center gap-2">
              <span class="font-sans text-sm">{item.label}</span>
              {item.badge && (
                <span class="border border-[#D4AF37]/30 text-[#D4AF37] text-[10px] uppercase px-2 py-0.5 rounded">
                  {item.badge}
                </span>
              )}
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/20">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </a>
        );
      })}

      <!-- Botão Sair -->
      <a 
        href="/auth/logout" 
        class="flex justify-between items-center py-4 text-red-500 hover:text-red-400 transition-colors border-t border-white/5 btn-logout-trigger"
      >
        <span class="font-sans text-sm">Sair</span>
      </a>
    </nav>

  </div>
</AppLayout>

<style>
  .perfil-page { padding: 24px 16px 32px; max-width: 640px; margin: 0 auto; }

  /* Header do perfil */
  .perfil-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
    padding: 20px;
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
  }

  .perfil-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(201,169,110,0.15), rgba(201,169,110,0.05));
    border: 1px solid rgba(201,169,110,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .perfil-avatar__initials {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #C9A96E;
  }

  .perfil-identity { display: flex; flex-direction: column; gap: 4px; }
  .perfil-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #F5F5F5;
  }
  .perfil-email { font-size: 0.8125rem; color: #4A4A4A; }


</style>
