---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Captura o código do ingresso gerado no checkout
const ticketCode = Astro.url.searchParams.get('code') ?? '';
---

<BaseLayout title="Lugar Reservado · MQ Access">
  <div class="sc-shell">

    <!-- Partículas decorativas -->
    <div class="sc-particles" aria-hidden="true">
      <span class="sc-particle sc-particle--1"></span>
      <span class="sc-particle sc-particle--2"></span>
      <span class="sc-particle sc-particle--3"></span>
    </div>

    <div class="sc-card" id="sc-card">

      <!-- Ícone de sucesso -->
      <div class="sc-icon-wrap">
        <div class="sc-icon-ring sc-icon-ring--outer"></div>
        <div class="sc-icon-ring sc-icon-ring--inner"></div>
        <svg class="sc-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10" stroke-width="2"/>
        </svg>
      </div>

      <!-- Header -->
      <div class="sc-header">
        <p class="sc-tag">CONFIRMAÇÃO DE INGRESSO</p>
        <h1 class="sc-title">Seu Lugar Está<br/>Reservado</h1>
        <p class="sc-subtitle">Sua cadeira no evento foi confirmada. O ingresso digital já está disponível na sua conta.</p>
      </div>

      <!-- Detalhes do ingresso -->
      <div class="sc-receipt">
        <div class="sc-receipt-item">
          <span class="sc-receipt-label">Ingresso</span>
          <span class="sc-receipt-value">Evento Presencial MQ</span>
        </div>
        <div class="sc-receipt-item">
          <span class="sc-receipt-label">Formato</span>
          <span class="sc-receipt-value">Presencial · Ingresso Digital</span>
        </div>
        <div class="sc-receipt-item">
          <span class="sc-receipt-label">Status</span>
          <span class="sc-receipt-value sc-receipt-value--gold">● Confirmado</span>
        </div>
      </div>

      <!-- QR Code Dinâmico -->
      <div class="sc-qr-wrap" aria-label="Ingresso digital (QR Code)">
        {ticketCode ? (
          <>
            <img
              src={`https://api.qrserver.com/v1/create-qr-code/?size=160x160&color=C9A96E&bgcolor=050505&data=${encodeURIComponent(ticketCode)}`}
              alt={`QR Code do Ingresso ${ticketCode}`}
              class="sc-qr-img"
              width="120"
              height="120"
              loading="eager"
            />
            <p class="sc-qr-code">{ticketCode}</p>
          </>
        ) : (
          <p class="sc-qr-label">INGRESSO DIGITAL</p>
        )}
      </div>

      <!-- CTA -->
      <a href="/app/compras" class="sc-cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M2 9a1 1 0 011-1h1a2 2 0 000-4H3a1 1 0 01-1-1V2a1 1 0 011-1h18a1 1 0 011 1v1a1 1 0 01-1 1h-1a2 2 0 000 4h1a1 1 0 011 1v1a1 1 0 01-1 1H3a1 1 0 01-1-1V9z"/>
        </svg>
        IR PARA MINHAS COMPRAS
      </a>

    </div>

    <!-- Rodapé mínimo -->
    <p class="sc-footer">MQ ACCESS · Plataforma Exclusiva</p>

  </div>
</BaseLayout>

<style>
  .sc-shell {
    min-height: 100dvh;
    background: #000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    font-family: 'Inter', sans-serif;
    position: relative;
    overflow: hidden;
  }

  /* Partículas douradas flutuantes */
  .sc-particles { position: absolute; inset: 0; pointer-events: none; }
  .sc-particle {
    position: absolute;
    width: 2px; height: 2px;
    border-radius: 50%;
    background: #C9A96E;
    animation: float-up 6s ease-in-out infinite;
    opacity: 0;
  }
  .sc-particle--1 { left: 20%; animation-delay: 0s; animation-duration: 7s; }
  .sc-particle--2 { left: 55%; animation-delay: 2s; animation-duration: 9s; }
  .sc-particle--3 { left: 80%; animation-delay: 4s; animation-duration: 6s; }
  @keyframes float-up {
    0%   { transform: translateY(100vh) scale(0); opacity: 0; }
    10%  { opacity: 0.6; }
    90%  { opacity: 0.4; }
    100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
  }

  /* Card central */
  .sc-card {
    width: 100%;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    animation: fade-in-up 0.7s ease both;
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Ícone */
  .sc-icon-wrap {
    position: relative;
    width: 80px; height: 80px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 32px;
  }
  .sc-icon-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(201,169,110,0.2);
    animation: pulse-ring 2.5s ease-out infinite;
  }
  .sc-icon-ring--outer { width: 80px; height: 80px; animation-delay: 0s; }
  .sc-icon-ring--inner { width: 60px; height: 60px; animation-delay: 0.4s; }
  @keyframes pulse-ring {
    0%   { transform: scale(0.95); opacity: 0.6; }
    70%  { transform: scale(1.1);  opacity: 0; }
    100% { transform: scale(0.95); opacity: 0; }
  }
  .sc-icon {
    position: relative; z-index: 1;
    color: #C9A96E;
    filter: drop-shadow(0 0 12px rgba(201,169,110,0.3));
  }

  /* Header */
  .sc-header { margin-bottom: 28px; }
  .sc-tag {
    font-size: .6rem; font-weight: 700; letter-spacing: .2em;
    color: #C9A96E; margin-bottom: 12px;
  }
  .sc-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.25rem; font-weight: 700;
    color: #F5F5F5; margin-bottom: 12px; line-height: 1.1;
  }
  .sc-subtitle {
    font-size: .9rem; font-weight: 300;
    color: #5A5A5A; line-height: 1.65; max-width: 360px;
  }

  /* Receipt */
  .sc-receipt {
    width: 100%;
    background: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex; flex-direction: column; gap: 10px;
    margin-bottom: 28px;
  }
  .sc-receipt-item {
    display: flex; justify-content: space-between; align-items: center;
  }
  .sc-receipt-label { font-size: .75rem; color: #3A3A3A; }
  .sc-receipt-value { font-size: .8125rem; font-weight: 500; color: #A0A0A0; }
  /* QR Code */
  .sc-qr-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    margin: 20px 0;
    padding: 20px 24px;
    background: rgba(201,169,110,.04);
    border: 1px solid rgba(201,169,110,.15);
    border-radius: 12px;
    width: 100%;
  }
  .sc-qr-img {
    width: 120px; height: 120px;
    border-radius: 8px;
    display: block;
  }
  .sc-qr-code {
    font-family: 'Courier New', Courier, monospace;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .1em;
    color: #C9A96E;
  }
  .sc-qr-label {
    font-size: .6rem; letter-spacing: .15em; color: #C9A96E;
  }

  .sc-receipt-value--gold { color: #C9A96E; }

  /* CTA */
  .sc-cta {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; max-width: 360px; height: 54px;
    background: #C9A96E; color: #000;
    font-size: .8125rem; font-weight: 700; letter-spacing: .12em;
    border-radius: 8px; text-decoration: none;
    transition: background 250ms;
    margin-bottom: 16px;
  }
  .sc-cta:hover { background: #E8D5A3; }

  .sc-secondary {
    font-size: .75rem; color: #2E2E2E;
    text-decoration: none; transition: color 200ms;
  }
  .sc-secondary:hover { color: #6A6A6A; }

  .sc-footer {
    position: absolute; bottom: 24px;
    font-size: .6rem; letter-spacing: .1em;
    color: #1A1A1A;
  }
</style>
