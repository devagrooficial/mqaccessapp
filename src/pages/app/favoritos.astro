---
import AppLayout from '../../layouts/AppLayout.astro';
import { supabase } from '../../lib/supabase';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/auth/login');
}

// ── INTERCEPTAÇÃO SSR: Deletar Favorito (POST) ────────────────────────────
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const favoriteId = formData.get('favoriteId') as string;

    if (!favoriteId) throw new Error('ID não informado');

    const { error: deleteError } = await supabase
      .from('user_favorites')
      .delete()
      .eq('id', favoriteId)
      .eq('user_id', user.id); // garante isolamento por RLS

    if (deleteError) throw deleteError;

    return new Response(JSON.stringify({ success: true }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' },
    });
  } catch (err: any) {
    return new Response(JSON.stringify({ error: err.message ?? 'Erro desconhecido' }), {
      status: 400,
      headers: { 'Content-Type': 'application/json' },
    });
  }
}

// ── BUSCA FAVORITOS + JOIN COM SCHEMA REAL ────────────────────────────────
type Favorito = {
  id: string;
  lesson_id: string;
  created_at: string;
  title: string | null;
  description: string | null;
  duration_seconds: number | null;
};

let favoritos: Favorito[] = [];

const { data, error } = await supabase
  .from('user_favorites')
  .select(`
    id,
    lesson_id,
    created_at,
    course_lessons (
      title,
      description,
      duration_seconds
    )
  `)
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

if (error) {
  console.error('[MQ] Erro ao buscar favoritos:', error.message);
} else if (data) {
  favoritos = data.map((f: any) => ({
    id: f.id,
    lesson_id: f.lesson_id,
    created_at: f.created_at,
    title: f.course_lessons?.title ?? null,
    description: f.course_lessons?.description ?? null,
    duration_seconds: f.course_lessons?.duration_seconds ?? null,
  }));
}

// ── Helpers ───────────────────────────────────────────────────────────────
function formatDuration(seconds: number | null): string {
  if (!seconds) return '—';
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${s < 10 ? '0' : ''}${s}`;
}

function formatDate(iso: string): string {
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  }).format(new Date(iso));
}
---

<AppLayout title="Meus Favoritos">
  <div class="fav-page">

    <!-- HEADER -->
    <header class="fav-header">
      <a href="/app/perfil" class="fav-back-btn" aria-label="Voltar para Perfil">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <div>
        <h1 class="fav-title">Favoritos</h1>
        {favoritos.length > 0 && (
          <p class="fav-count">{favoritos.length} aula{favoritos.length !== 1 ? 's' : ''} salva{favoritos.length !== 1 ? 's' : ''}</p>
        )}
      </div>
    </header>

    <!-- CARD PRINCIPAL -->
    <div class="fav-card">

      {favoritos.length === 0 ? (

        <!-- EMPTY STATE -->
        <div class="fav-empty" id="empty-state">
          <div class="fav-empty__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <h2 class="fav-empty__title">Nenhum conteúdo salvo</h2>
          <p class="fav-empty__text">
            Explore os módulos e salve os materiais que mais impactam o seu projeto.
          </p>
        </div>

      ) : (

        <!-- LISTA -->
        <ul class="fav-list" id="favorites-list">
          {favoritos.map((fav) => (
            <li class="fav-item" id={`fav-${fav.id}`}>

              <!-- Info da aula -->
              <div class="fav-item__info">
                <div class="fav-item__meta">
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span>{formatDuration(fav.duration_seconds)}</span>
                  <span class="fav-item__dot">·</span>
                  <span>{formatDate(fav.created_at)}</span>
                </div>
                <h3 class="fav-item__title">
                  {fav.title ?? 'Aula indisponível'}
                </h3>
                {fav.description && (
                  <p class="fav-item__desc">{fav.description}</p>
                )}
              </div>

              <!-- Ações -->
              <div class="fav-item__actions">
                <button
                  class="btn-remover"
                  data-id={fav.id}
                  title="Remover dos favoritos"
                  aria-label="Remover dos favoritos"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                </button>
                <a href={`/app/aulas/${fav.lesson_id}`} class="btn-assistir">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  Assistir
                </a>
              </div>

            </li>
          ))}
        </ul>

      )}

    </div>
  </div>
</AppLayout>

<script>
  function initFavoritesList() {
    document.querySelectorAll<HTMLButtonElement>('.btn-remover').forEach(btn => {
      // Clona para limpar listeners residuais de navegações anteriores
      const fresh = btn.cloneNode(true) as HTMLButtonElement;
      btn.replaceWith(fresh);

      fresh.addEventListener('click', async () => {
        const favId = fresh.getAttribute('data-id');
        const listItem = document.getElementById(`fav-${favId}`);

        // Loading state no botão
        fresh.disabled = true;
        fresh.innerHTML = `<svg style="animation:spin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity=".25"/><path fill="currentColor" opacity=".75" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>`;

        try {
          const formData = new FormData();
          formData.append('favoriteId', favId ?? '');

          const response = await fetch(window.location.pathname, {
            method: 'POST',
            body: formData,
          });

          if (!response.ok) {
            const json = await response.json();
            throw new Error(json.error || 'Falha ao remover');
          }

          // Animação de saída
          if (listItem) {
            listItem.style.transition = 'opacity 250ms ease, transform 250ms ease';
            listItem.style.opacity = '0';
            listItem.style.transform = 'scale(0.96)';

            setTimeout(() => {
              listItem.remove();

              // Se a lista ficou vazia, recarrega para exibir o empty state
              const list = document.getElementById('favorites-list');
              if (!list || list.children.length === 0) {
                window.location.reload();
              }
            }, 260);
          }
        } catch (err: any) {
          console.error('[MQ] Erro ao remover favorito:', err?.message ?? err);
          alert('Erro ao remover. Tente novamente.');
          fresh.disabled = false;
        }
      });
    });
  }

  initFavoritesList();
  document.addEventListener('astro:page-load', initFavoritesList);
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* ── Container ── */
  .fav-page {
    padding: 24px 16px 48px;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .fav-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .fav-back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.5);
    transition: background-color 200ms ease, color 200ms ease;
    flex-shrink: 0;
  }
  .fav-back-btn:hover {
    background-color: rgba(255,255,255,0.1);
    color: #ffffff;
  }

  .fav-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #F5F5F5;
    line-height: 1.2;
  }

  .fav-count {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.3);
    margin-top: 4px;
  }

  /* ── Card ── */
  .fav-card {
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    overflow: hidden;
    min-height: 320px;
  }

  /* ── Empty State ── */
  .fav-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 56px 24px;
    gap: 12px;
  }

  .fav-empty__icon {
    color: rgba(255,255,255,0.1);
    margin-bottom: 8px;
  }

  .fav-empty__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
  }

  .fav-empty__text {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.3);
    line-height: 1.65;
    max-width: 300px;
  }

  /* ── Lista ── */
  .fav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  /* ── Item ── */
  .fav-item {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background-color 200ms ease;
  }
  .fav-item:last-child { border-bottom: none; }
  .fav-item:hover { background-color: rgba(255,255,255,0.02); }

  .fav-item__info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    min-width: 0;
  }

  .fav-item__meta {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #D4AF37;
  }

  .fav-item__dot {
    color: rgba(255,255,255,0.2);
    font-weight: 400;
  }

  .fav-item__title {
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    line-height: 1.35;
    /* Trunca se muito longo */
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .fav-item__desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.3);
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  /* ── Ações ── */
  .fav-item__actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .btn-remover {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: none;
    background-color: rgba(0,0,0,0.2);
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    transition: background-color 200ms ease, color 200ms ease;
  }
  .btn-remover:hover {
    background-color: rgba(239,68,68,0.12);
    color: #f87171;
  }
  .btn-remover:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .btn-assistir {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0 16px;
    height: 36px;
    border-radius: 10px;
    background-color: rgba(212,175,55,0.08);
    border: 1px solid rgba(212,175,55,0.2);
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #D4AF37;
    white-space: nowrap;
    transition: background-color 200ms ease, border-color 200ms ease;
  }
  .btn-assistir:hover {
    background-color: rgba(212,175,55,0.15);
    border-color: rgba(212,175,55,0.4);
  }
</style>
