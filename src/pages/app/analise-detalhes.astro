---
import AppLayout from '@/layouts/AppLayout.astro';
---

<AppLayout title="Detalhes do Egograma" activeNav="analises">
  <div class="analise-detalhes-page">
    
    <!-- Header -->
    <div class="analises-header">
      <a href="/app/analises" class="analises-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Voltar para Análises
      </a>
      <div class="header-tags">
        <span class="status-badge status-badge--pending">PENDENTE</span>
      </div>
    </div>

    <!-- Hero Section -->
    <section class="analise-hero">
      <h1 class="analise-hero__title">Mapeamento dos Estados de Ego</h1>
      <p class="analise-hero__desc">
        Identifique se você está operando predominantemente como Pai (Crítico/Protetor), Adulto (Racional) ou Criança (Rebelde/Livre) em momentos de alta pressão e negociações estratégicas.
      </p>
    </section>

    <!-- O Que Você Recebe -->
    <section class="analise-benefits">
      <h2 class="benefits-title">O que você vai descobrir</h2>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <h3 class="benefit-card__title">Gráfico de Barras</h3>
          <p class="benefit-card__desc">Visualização clara dos seus estados predominantes.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3 class="benefit-card__title">Análise Detalhada</h3>
          <p class="benefit-card__desc">Texto explicativo sobre seus gatilhos comportamentais.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </div>
          <h3 class="benefit-card__title">Plano de Ação</h3>
          <p class="benefit-card__desc">Diretrizes executivas para equilibrar sua tomada de decisão.</p>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <div class="analise-cta">
      <a href="/app/pergunta" class="btn-start">
        INICIAR MAPEAMENTO (15 MIN)
      </a>
    </div>

  </div>
</AppLayout>

<style>
  .analise-detalhes-page {
    padding: 24px 16px 40px;
    max-width: 768px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
  }

  .analises-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
  }
  .analises-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: #4A4A4A;
    text-decoration: none;
    transition: color 200ms;
  }
  .analises-back:hover { color: #C9A96E; }

  .status-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    border-radius: 4px;
  }
  .status-badge--pending {
    background-color: #2A2A2A;
    color: #A0A0A0;
  }

  /* Hero */
  .analise-hero {
    margin-bottom: 48px;
    text-align: center;
  }
  .analise-hero__title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .analise-hero__desc {
    font-size: 1rem;
    line-height: 1.6;
    color: #A0A0A0;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Benefits */
  .analise-benefits {
    margin-bottom: 48px;
  }
  .benefits-title {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4A4A4A;
    margin-bottom: 24px;
    text-align: center;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .benefit-card {
    background-color: #0A0A0A;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }
  .benefit-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
    margin-bottom: 16px;
  }
  .benefit-card__title {
    font-size: 1rem;
    font-weight: 600;
    color: #F5F5F5;
    margin-bottom: 8px;
  }
  .benefit-card__desc {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: #A0A0A0;
  }

  /* CTA */
  .btn-start {
    display: block;
    width: 100%;
    background-color: #D4AF37;
    color: #000;
    padding: 16px 24px;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: background-color 200ms ease;
  }
  .btn-start:hover {
    background-color: #F5F5F5;
  }
</style>
