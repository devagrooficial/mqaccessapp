---
import AuthLayout from '@/layouts/AuthLayout.astro';
---

<AuthLayout title="Entrar">
  <div class="auth-form-card">
    <div class="auth-form-header">
      <img src="/images/logohorizontal.png" class="h-12 w-auto mx-auto mb-8" alt="MQ ACCESS" />
      <h1 class="auth-form-title">Bem-vindo de volta</h1>
      <p class="auth-form-subtitle">Acesse sua conta MQ ACCESS</p>
    </div>

    <form class="auth-form" id="login-form" novalidate>
      <div class="form-group">
        <label class="form-label" for="email">E-mail</label>
        <input
          type="email"
          id="email"
          name="email"
          class="input"
          placeholder="seu@email.com"
          autocomplete="email"
          required
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Senha</label>
        <input
          type="password"
          id="password"
          name="password"
          class="input"
          placeholder="••••••••"
          autocomplete="current-password"
          required
        />
        <a href="/auth/esqueceu-senha" class="form-link-right">Esqueceu a senha?</a>
      </div>

      <button type="submit" class="btn-primary btn-full" id="login-submit">
        Entrar
      </button>
    </form>

    <p class="auth-switch-text">
      Ainda não tem conta?
      <a href="/auth/cadastro" class="auth-switch-link">Criar conta</a>
    </p>
  </div>
</AuthLayout>

<script>
  document.getElementById('login-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email    = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value.trim();

    if (email === 'admin' && password === 'admin') {
      // Feedback visual antes do redirect
      const btn = document.getElementById('login-submit') as HTMLButtonElement;
      if (btn) { btn.textContent = 'Autenticando…'; btn.disabled = true; }
      setTimeout(() => { window.location.href = '/app/home'; }, 600);
    } else {
      // Inline error — sem alert nativo
      let err = document.getElementById('login-error');
      if (!err) {
        err = document.createElement('p');
        err.id = 'login-error';
        err.style.cssText = 'font-size:.8rem;color:#ef4444;text-align:center;margin-top:-4px;font-family:Inter,sans-serif;';
        document.getElementById('login-form')?.appendChild(err);
      }
      err.textContent = 'Credenciais inválidas. Use admin / admin para demonstração.';
    }
  });
</script>

<style>
  .auth-form-card {
    background-color: #0A0A0A;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 32px;
  }

  .auth-form-header {
    margin-bottom: 28px;
    text-align: center;
  }

  .auth-form-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 8px;
  }

  .auth-form-subtitle {
    font-size: 0.875rem;
    color: #A0A0A0;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }

  .form-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #A0A0A0;
    font-family: 'Inter', sans-serif;
  }

  .form-link-right {
    position: absolute;
    right: 0;
    top: 0;
    font-size: 0.75rem;
    color: #C9A96E;
    transition: color 200ms ease;
  }

  .form-link-right:hover {
    color: #E8D5A3;
  }

  .btn-full {
    width: 100%;
    margin-top: 8px;
    height: 48px;
    font-size: 0.9375rem;
  }

  .auth-switch-text {
    text-align: center;
    font-size: 0.8125rem;
    color: #4A4A4A;
    margin-top: 20px;
  }

  .auth-switch-link {
    color: #C9A96E;
    font-weight: 500;
    transition: color 200ms ease;
  }

  .auth-switch-link:hover {
    color: #E8D5A3;
  }
</style>
