---
import AuthLayout from '@/layouts/AuthLayout.astro';
---

<AuthLayout title="Criar Conta">
  <div class="auth-form-card">
    <div class="auth-form-header">
      <img src="/images/logohorizontal.png" class="h-12 w-auto mx-auto mb-8" alt="MQ ACCESS" />
      <h1 class="auth-form-title" id="form-title">Crie sua conta</h1>
      <p class="auth-form-subtitle" id="form-subtitle">Junte-se à plataforma de executivos</p>
    </div>

    <!-- Estado: aguardando confirmação de e-mail (oculto por padrão) -->
    <div class="confirm-state" id="confirm-state" style="display:none;">
      <div class="confirm-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <polyline points="2,4 12,13 22,4"/>
        </svg>
      </div>
      <p class="confirm-desc">
        Enviamos um e-mail de confirmação para <strong id="confirm-email"></strong>.<br/>
        Clique no link para ativar sua conta e fazer login.
      </p>
      <p class="confirm-hint">Não recebeu? Verifique a pasta de spam.</p>
      <a href="/auth/login" class="btn-primary btn-full confirm-btn">Ir para o Login</a>
    </div>

    <!-- Formulário de cadastro -->
    <form class="auth-form" id="cadastro-form" novalidate>
      <div class="form-group">
        <label class="form-label" for="name">Nome completo</label>
        <input type="text" id="name" name="name" class="input" placeholder="Seu nome" autocomplete="name" required />
      </div>

      <div class="form-group">
        <label class="form-label" for="email">E-mail</label>
        <input type="email" id="email" name="email" class="input" placeholder="seu@email.com" autocomplete="email" required />
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Senha</label>
        <input type="password" id="password" name="password" class="input" placeholder="Mínimo 8 caracteres" autocomplete="new-password" required />
      </div>

      <div class="form-group">
        <label class="form-label" for="confirm-password">Confirmar senha</label>
        <input type="password" id="confirm-password" name="confirm-password" class="input" placeholder="Repita a senha" autocomplete="new-password" required />
      </div>

      <!-- Erro dinâmico injetado pelo JS -->
      <p id="cadastro-error" class="auth-error" role="alert" style="display:none;"></p>

      <button type="submit" class="btn-primary btn-full" id="cadastro-submit">
        Criar Minha Conta
      </button>
    </form>

    <p class="auth-switch-text">
      Já tem uma conta?
      <a href="/auth/login" class="auth-switch-link">Entrar</a>
    </p>
  </div>
</AuthLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  function initCadastroForm() {
    const form      = document.getElementById('cadastro-form') as HTMLFormElement | null;
    const btnSubmit = document.getElementById('cadastro-submit') as HTMLButtonElement | null;
    const errorEl   = document.getElementById('cadastro-error') as HTMLParagraphElement | null;

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const fullName  = (document.getElementById('name') as HTMLInputElement)?.value.trim() ?? '';
      const email     = (document.getElementById('email') as HTMLInputElement)?.value.trim() ?? '';
      const password  = (document.getElementById('password') as HTMLInputElement)?.value ?? '';
      const confirm   = (document.getElementById('confirm-password') as HTMLInputElement)?.value ?? '';

      // Limpa erro anterior
      if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

      // Validações client-side
      if (!fullName || !email || !password) {
        if (errorEl) { errorEl.textContent = 'Preencha todos os campos.'; errorEl.style.display = 'block'; }
        return;
      }
      if (password !== confirm) {
        if (errorEl) { errorEl.textContent = 'As senhas não coincidem. Verifique e tente novamente.'; errorEl.style.display = 'block'; }
        return;
      }
      if (password.length < 8) {
        if (errorEl) { errorEl.textContent = 'A senha deve ter pelo menos 8 caracteres.'; errorEl.style.display = 'block'; }
        return;
      }

      // Loading state
      if (btnSubmit) { btnSubmit.textContent = 'Criando conta…'; btnSubmit.disabled = true; }

      const { data, error } = await supabase.auth.signUp({
        email,
        password,
        options: { data: { full_name: fullName } },
      });

      if (error) {
        const msg = error.message.toLowerCase().includes('already registered')
          ? 'Este e-mail já está cadastrado. Tente fazer login.'
          : error.message;
        if (errorEl) { errorEl.textContent = msg; errorEl.style.display = 'block'; }
        if (btnSubmit) { btnSubmit.textContent = 'Criar Minha Conta'; btnSubmit.disabled = false; }
        return;
      }

      if (data.user && data.session) {
        // Sessão imediata (confirmação desabilitada no Supabase) — entra direto
        if (btnSubmit) { btnSubmit.textContent = '✓ Conta criada! Redirecionando…'; }
        window.location.href = '/app/home';
      } else if (data.user && !data.session) {
        // Supabase exige confirmação de e-mail — exibe estado de aguardo
        const confirmState = document.getElementById('confirm-state');
        const confirmEmail = document.getElementById('confirm-email');
        const formTitle    = document.getElementById('form-title');
        const formSubtitle = document.getElementById('form-subtitle');

        if (confirmEmail) confirmEmail.textContent = email;
        if (confirmState) confirmState.style.display = 'flex';
        if (form) form.style.display = 'none';
        if (formTitle) formTitle.textContent = 'Verifique seu e-mail';
        if (formSubtitle) formSubtitle.textContent = 'Um link de confirmação foi enviado';
      }
    });
  }

  initCadastroForm();
  document.addEventListener('astro:page-load', initCadastroForm);
</script>

<style>
  .auth-form-card {
    background-color: #0A0A0A;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 32px;
  }
  .auth-form-header { margin-bottom: 28px; text-align: center; }
  .auth-form-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #F5F5F5;
    margin-bottom: 8px;
  }
  .auth-form-subtitle { font-size: 0.875rem; color: #A0A0A0; }
  .auth-form { display: flex; flex-direction: column; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 0.8125rem; font-weight: 500; color: #A0A0A0; }
  .btn-full { width: 100%; margin-top: 8px; height: 48px; font-size: 0.9375rem; }
  .auth-switch-text { text-align: center; font-size: 0.8125rem; color: #4A4A4A; margin-top: 20px; }
  .auth-switch-link { color: #C9A96E; font-weight: 500; transition: color 200ms ease; }
  .auth-switch-link:hover { color: #E8D5A3; }
  .auth-error {
    font-size: 0.8rem;
    color: #ef4444;
    text-align: center;
    font-family: 'Inter', sans-serif;
    margin-top: -4px;
  }
  /* Estado de aguardar confirmação de e-mail */
  .confirm-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    padding: 8px 0 16px;
  }
  .confirm-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(201, 169, 110, 0.08);
    border: 1px solid rgba(201, 169, 110, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C9A96E;
  }
  .confirm-desc { font-size: 0.875rem; color: #A0A0A0; line-height: 1.65; }
  .confirm-desc strong { color: #E8D5A3; font-weight: 500; }
  .confirm-hint { font-size: 0.75rem; color: #3A3A3A; margin-top: -8px; }
  .confirm-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    margin-top: 4px;
  }
</style>
