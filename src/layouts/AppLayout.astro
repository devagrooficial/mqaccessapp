---
// AppLayout.astro — Layout protegido do app
// Bottom Navigation (mobile) + Sidebar mínima (desktop)
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
  activeNav?: 'home' | 'compras' | 'perfil';
}

const { title, description, activeNav: activeNavProp } = Astro.props;

// Auto-detect rota ativa pelo pathname — prop manual é fallback
const currentPath = Astro.url.pathname;
const activeNav = activeNavProp ??
  (currentPath.startsWith('/app/compras') ? 'compras' :
   currentPath.startsWith('/app/perfil')  ? 'perfil'  : 'home');

const navItems = [
  { id: 'home',    label: 'Home',    href: '/app/home',    icon: 'home' },
  { id: 'compras', label: 'Compras', href: '/app/compras', icon: 'bag'  },
  { id: 'perfil',  label: 'Perfil',  href: '/app/perfil',  icon: 'user' },
];
---

<BaseLayout title={title} description={description}>
  <div class="app-shell">


    <!-- Sidebar mínima — Desktop (≥ 768px) -->
    <aside class="app-sidebar hidden md:flex" aria-label="Navegação principal">
      <a href="/app/home" class="sidebar-logo" aria-label="MQ ACCESS">
        <img src="/images/logosquad.png" class="w-10 h-10 object-contain mx-auto mb-10 rounded-md border border-[#D4AF37]/20 shadow-[0_0_15px_rgba(212,175,55,0.1)]" alt="MQ" />
      </a>

      <nav class="sidebar-nav">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`sidebar-nav__item ${activeNav === item.id ? 'active' : ''}`}
            aria-label={item.label}
            aria-current={activeNav === item.id ? 'page' : undefined}
            title={item.label}
          >
            {item.icon === 'home' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z" />
                <path d="M9 21V12h6v9" />
              </svg>
            )}
            {item.icon === 'bag' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                <line x1="3" y1="6" x2="21" y2="6" />
                <path d="M16 10a4 4 0 01-8 0" />
              </svg>
            )}
            {item.icon === 'user' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            )}
          </a>
        ))}
      </nav>

      <!-- Botão Sair — rodapé da sidebar -->
      <a href="/auth/login" class="sidebar-logout" title="Sair" aria-label="Sair da conta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      </a>
    </aside>


    <!-- Área de conteúdo principal -->
    <main class="app-main flex-1 min-h-dvh overflow-x-hidden pb-24 md:pb-8 md:ml-16">
      <slot />
    </main>


    <!-- Bottom Navigation — Mobile (< 768px) -->
    <nav class="app-bottom-nav flex md:hidden" aria-label="Navegação principal">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`bottom-nav__item ${activeNav === item.id ? 'active' : ''}`}
          aria-label={item.label}
          aria-current={activeNav === item.id ? 'page' : undefined}
        >
          <span class="bottom-nav__icon" aria-hidden="true">
            {item.icon === 'home' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z" />
                <path d="M9 21V12h6v9" />
              </svg>
            )}
            {item.icon === 'bag' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                <line x1="3" y1="6" x2="21" y2="6" />
                <path d="M16 10a4 4 0 01-8 0" />
              </svg>
            )}
            {item.icon === 'user' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            )}
          </span>
          <span class="bottom-nav__label">{item.label}</span>
        </a>
      ))}
    </nav>

  </div>
</BaseLayout>

<style>
  .app-shell {
    display: flex;
    min-height: 100dvh;
    background-color: #000000;
  }

  /* === Sidebar — Desktop === */
  /* display controlado via Tailwind: hidden md:flex */
  .app-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 64px;
    background-color: #0A0A0A;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    flex-direction: column;
    align-items: center;
    padding: 20px 0;
    z-index: 100;
  }

  /* Responsividade gerenciada via Tailwind: hidden md:flex / md:hidden / pb-24 md:pb-8 md:ml-16 */

  .sidebar-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    margin-bottom: 32px;
    text-decoration: none;
  }

  .sidebar-logo__mq {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #F5F5F5;
  }

  .sidebar-logo__a {
    font-family: 'Playfair Display', serif;
    font-size: 0.6875rem;
    color: #C9A96E;
    letter-spacing: 0.05em;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
  }

  .sidebar-nav__item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    color: #4A4A4A;
    transition: color 200ms ease, background-color 200ms ease;
    position: relative;
  }

  .sidebar-nav__item:hover {
    color: #A0A0A0;
    background-color: rgba(255, 255, 255, 0.04);
  }

  .sidebar-nav__item.active {
    color: #C9A96E;
    background-color: rgba(201, 169, 110, 0.08);
  }

  /* Botão Sair */
  .sidebar-logout {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    color: #2A2A2A;
    margin-top: auto;
    text-decoration: none;
    transition: color 200ms ease, background-color 200ms ease;
  }
  .sidebar-logout:hover {
    color: #ef4444;
    background-color: rgba(239, 68, 68, 0.08);
  }

  /* === Área de conteúdo === */
  /* Layout controlado por Tailwind: flex-1 min-h-dvh overflow-x-hidden pb-24 md:pb-8 md:ml-16 */

  /* === Bottom Navigation — Mobile === */
  /* display controlado via Tailwind: flex md:hidden */
  .app-bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 72px;
    background-color: #0A0A0A;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    align-items: center;
    justify-content: space-around;
    padding: 0 8px;
    padding-bottom: env(safe-area-inset-bottom, 0);
    z-index: 100;
  }

  .bottom-nav__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex: 1;
    height: 100%;
    color: #4A4A4A;
    text-decoration: none;
    transition: color 200ms ease;
  }

  .bottom-nav__item.active {
    color: #C9A96E;
  }

  .bottom-nav__label {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
</style>
